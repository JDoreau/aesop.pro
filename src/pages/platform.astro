---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = 'Imprimatur — the Aesop data practice portal | Aesop Analytics'
const description = 'Imprimatur turns an engagement into a living system: your data estate mapped, every metric’s owner and definition visible, and an oracle that answers from your governed data — with a citation for every claim.'
const ogDescription = "Trust you can see, and keep. Your estate mapped, governed, and answerable — with a citation for every claim.";
---

<BaseLayout title={title} description={description} path="/platform" ogDescription={ogDescription}>

<!-- ── HERO ── -->
<section class="phero">
  <div class="phero-in">
    <div class="eyebrow reveal">Aesop Imprimatur&trade; · the data practice portal</div>
    <h1 class="reveal" style="animation-delay:.08s">Trust you can <span class="em">see</span> — and keep.</h1>
    <p class="phero-sub reveal" style="animation-delay:.16s">An <em>imprimatur</em> is the old seal that a thing is true and free of error. <strong>Imprimatur</strong> is the platform that grants your data its own: your whole estate mapped, every metric's owner and definition in plain view, and an oracle that answers about it — grounded only in your governed data, with a citation for every claim.</p>
    <div class="btn-row reveal" style="animation-delay:.24s">
      <a href="/diagnostic/" class="btn">See it on your estate</a>
      <a href="/services/" class="btn ghost">How the engagement works</a>
    </div>
    <div class="phero-note reveal" style="animation-delay:.38s">Built on a deterministic core — it computes, it doesn't guess.</div>
  </div>
</section>

<!-- ── TRANSITION ── -->
<div class="promise">
  <div class="promise-in">
    <p>Most governance dies in a slide deck.<span class="dot"></span>This one stays alive in the work.</p>
  </div>
</div>

<!-- ── THE THREE PARTS ── -->
<section class="parts">
  <div class="wrap">
    <div class="sec-label">What it is</div>
    <h2>Three parts, one continuous system.</h2>
    <p class="intro">Imprimatur takes the estate from raw systems to a question you can ask in plain English — and every step is auditable, because none of it is guesswork.</p>
    <div class="part-cards">

      <div class="part-card">
        <div class="pc-step">01</div>
        <div class="pc-name">Auto-Doc</div>
        <div class="pc-line">Map the estate automatically</div>
        <div class="pc-desc">Point it at your BI files, your warehouse catalog, or a simple export. It reads what actually exists — tables, fields, metrics, and the lineage between them — and builds a typed map of your estate. No manual documentation, no months of interviews to draw the picture.</div>
      </div>

      <div class="part-card hl">
        <div class="pc-step">02</div>
        <div class="pc-name">The Record</div>
        <div class="pc-line">Governance you can see</div>
        <div class="pc-desc">The map becomes a navigable, canonical record. Every metric, who owns it, where it's defined, which reports disagree, and — most tellingly — what no one owns at all. The gaps render in red. That red is the work, and for the first time it's visible to the people who can fix it.</div>
      </div>

      <div class="part-card">
        <div class="pc-step">03</div>
        <div class="pc-name">The Oracle</div>
        <div class="pc-line">Answers you can trust</div>
        <div class="pc-desc">Ask a plain question — "which numbers does no one own?", "is this metric trustworthy?" — and the oracle answers from your governed estate alone, with a citation behind every claim. It cannot invent a number or an owner: if the answer isn't in your data, it says so.</div>
      </div>

    </div>
  </div>
</section>

<!-- ── FROM ESTATE TO ANSWERS ── -->
<section class="flow">
  <div class="flow-in">
    <div class="flow-head">
      <h2>From a pile of systems to a question you can ask.</h2>
      <p>The same pipeline runs for a 50-table startup or a 50,000-table enterprise — it reads the catalog, it doesn't guess what you have.</p>
    </div>
    <div class="flow-steps">
      <div class="flow-step"><div class="fs-n">1</div><div class="fs-name">Connect</div><div class="fs-desc">A read-only export or catalog from each system. We ask for a key, never a copy of your data.</div></div>
      <div class="flow-arrow" aria-hidden="true">→</div>
      <div class="flow-step"><div class="fs-n">2</div><div class="fs-name">Map</div><div class="fs-desc">Every table, field, metric and lineage edge, normalized into one typed map of the estate.</div></div>
      <div class="flow-arrow" aria-hidden="true">→</div>
      <div class="flow-step"><div class="fs-n">3</div><div class="fs-name">Govern</div><div class="fs-desc">Owners, definitions, and the gaps surfaced — what's contested, what's unowned, what's never been governed.</div></div>
      <div class="flow-arrow" aria-hidden="true">→</div>
      <div class="flow-step"><div class="fs-n">4</div><div class="fs-name">Answer</div><div class="fs-desc">A record anyone can navigate and an oracle anyone can ask — every claim traceable to its source.</div></div>
    </div>
  </div>
</section>

<!-- ── CONTINUITY (ties to the method) ── -->
<section class="cont">
  <div class="wrap">
    <div class="cont-grid">
      <div class="cont-left">
        <div class="sec-label">Why it matters</div>
        <h2>The engagement establishes trust. Imprimatur keeps it.</h2>
        <p>A Reporting Clarity Assessment maps your estate and names the gaps. Historically, that picture started going stale the day it was delivered — definitions drift, new reports appear, owners change roles. Imprimatur is the living version of that work: it updates as the estate changes, so the governance you paid for is still true a year later.</p>
        <p>Between engagements, Imprimatur is what your team navigates and the oracle is who they ask. It's the difference between a one-time clean-up and a practice that sustains itself.</p>
        <a href="/services/" class="cont-link">See the TRUST method behind it</a>
      </div>
      <div class="cont-right">
        <div class="cont-card">
          <div class="cc-k">An engagement, made continuous</div>
          <div class="cc-row"><span class="cc-was">A report that ages</span><span class="cc-arrow">→</span><span class="cc-now">A record that updates</span></div>
          <div class="cc-row"><span class="cc-was">A spreadsheet of owners</span><span class="cc-arrow">→</span><span class="cc-now">Owners visible in context</span></div>
          <div class="cc-row"><span class="cc-was">"Ask the analyst"</span><span class="cc-arrow">→</span><span class="cc-now">Ask the estate directly</span></div>
          <div class="cc-row"><span class="cc-was">Trust you took on faith</span><span class="cc-arrow">→</span><span class="cc-now">Trust with a citation</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── TRUST & SAFETY ── -->
<section class="safe">
  <div class="wrap">
    <div class="sec-label" style="color:var(--twine)">Built to be trusted</div>
    <h2>Why you can stand behind every number it shows.</h2>
    <div class="safe-grid">
      <div class="safe-item">
        <div class="si-h">It computes, it doesn't guess</div>
        <p>The map, the lineage, and every governance finding are produced by deterministic code reading your own systems — not by a model's opinion. The same inputs always give the same answer, and you can audit how it was reached.</p>
      </div>
      <div class="safe-item">
        <div class="si-h">The oracle cites or refuses</div>
        <p>The oracle answers only from your governed estate and attaches the source to every claim. It is built so it cannot fabricate a number, an owner, or a definition — the honest "that isn't governed yet" is a feature, not a failure.</p>
      </div>
      <div class="safe-item">
        <div class="si-h">Your data stays in your governance</div>
        <p>We work from metadata and exports, not a copy of your warehouse. The platform is model-agnostic and can run inside your own walls — sensitive estates never have to leave the building to be mapped and answered.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── FINAL CTA ── -->
<section class="final-cta">
  <div class="eyebrow" style="color:var(--twine);letter-spacing:.28em;font-size:11.5px;font-weight:600;text-transform:uppercase;margin-bottom:24px">See it for real</div>
  <h2>Watch your own estate become a living record.</h2>
  <p>Start with a free 30-minute diagnostic. If there's a fit, the first engagement maps your estate into Imprimatur — and you see your governance, gaps and all, the way leadership has always wanted to.</p>
  <div class="btn-row" style="justify-content:center">
    <a href="/diagnostic/" class="btn" style="color:var(--navy)">Book a diagnostic</a>
    <a href="/work/" class="btn ghost">See recent work</a>
  </div>
</section>

<style>
/* ── shared primitives (mirrors the homepage) ── */
.btn { display:inline-block; background:var(--twine); color:#fff; font-family:"DM Sans",sans-serif; font-weight:600; letter-spacing:.03em; padding:15px 28px; border-radius:4px; font-size:15px; transition:transform .18s,background .18s; }
.btn:hover { transform:translateY(-2px); background:var(--sepia); }
.btn.ghost { background:transparent; color:var(--cream); border:1.5px solid rgba(243,239,230,.3); }
.btn.ghost:hover { border-color:var(--twine); color:var(--twine); background:transparent; transform:translateY(-2px); }
.btn-row { display:flex; flex-wrap:wrap; gap:12px; }
h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; }

/* ── HERO ── */
.phero { background:var(--navy); color:var(--cream); overflow:hidden; position:relative; }
.phero::after { content:"æ"; position:absolute; right:-3%; top:-16%; font-family:"Abril Fatface",serif; font-size:min(46vw,520px); line-height:1; color:rgba(193,140,93,.07); pointer-events:none; user-select:none; }
.phero-in { max-width:1080px; margin:0 auto; padding:96px 32px 84px; position:relative; z-index:2; }
.phero h1 { font-family:"Newsreader",Georgia,serif; font-weight:500; font-size:clamp(40px,6.2vw,76px); line-height:1.05; max-width:16ch; margin-bottom:26px; color:var(--cream); letter-spacing:-.01em; }
.phero h1 .em { color:var(--twine); }
.phero-sub { font-size:clamp(16px,1.8vw,20px); line-height:1.6; color:#C4BDAE; max-width:58ch; margin-bottom:38px; font-weight:300; }
.phero-note { margin-top:48px; display:flex; align-items:center; gap:12px; color:#8FA4B8; font-size:12px; font-weight:500; letter-spacing:.1em; text-transform:uppercase; }
.phero-note::before { content:''; display:block; width:28px; height:1px; background:var(--info); }

/* ── TRANSITION BAR ── */
.promise { background:var(--paper-2); border-bottom:1px solid var(--rule); }
.promise-in { max-width:1080px; margin:0 auto; padding:30px 32px; text-align:center; }
.promise p { font-family:"DM Sans",sans-serif; font-weight:500; font-size:clamp(17px,2.2vw,24px); color:var(--navy); line-height:1.4; max-width:44ch; margin:0 auto; }
.dot { display:inline-block; width:4px; height:4px; border-radius:50%; background:var(--twine); margin:0 9px; vertical-align:middle; }

/* ── THREE PARTS ── */
.parts { padding:80px 0; background:var(--paper); }
.parts h2 { font-size:clamp(26px,3.6vw,40px); line-height:1.1; color:var(--navy); margin-bottom:14px; max-width:22ch; }
.parts .intro { font-size:17px; color:var(--slate); font-weight:300; max-width:60ch; margin-bottom:48px; line-height:1.6; }
.part-cards { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
@media(max-width:820px){ .part-cards { grid-template-columns:1fr; } }
.part-card { background:#fff; border:1px solid var(--line); border-radius:6px; padding:30px 26px; display:flex; flex-direction:column; gap:10px; transition:transform .2s,box-shadow .2s,border-color .2s; }
.part-card:hover { transform:translateY(-3px); box-shadow:0 16px 40px -20px rgba(15,31,56,.2); border-color:var(--navy-mist); }
.part-card.hl { border-top:3px solid var(--twine); }
.pc-step { font-family:"Abril Fatface",serif; font-size:30px; color:var(--twine); line-height:1; }
.pc-name { font-size:21px; font-weight:700; color:var(--navy); letter-spacing:-.01em; }
.pc-line { font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--twine); }
.pc-desc { font-size:15px; color:var(--slate); line-height:1.6; font-weight:300; margin-top:4px; }

/* ── FLOW ── */
.flow { background:var(--navy); padding:80px 0; }
.flow-in { max-width:1080px; margin:0 auto; padding:0 32px; }
.flow-head { max-width:760px; margin-bottom:48px; }
.flow-head h2 { font-size:clamp(26px,3.6vw,42px); color:#fff; line-height:1.1; margin-bottom:14px; }
.flow-head p { font-size:16.5px; color:#C4BDAE; font-weight:300; line-height:1.6; }
.flow-steps { display:flex; align-items:stretch; gap:10px; }
@media(max-width:860px){ .flow-steps { flex-direction:column; } .flow-arrow { transform:rotate(90deg); } }
.flow-step { flex:1; background:var(--navy-2); border-radius:6px; padding:24px 20px; }
.flow-step:hover { background:var(--navy-3); transition:background .2s; }
.fs-n { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:22px; color:var(--twine); width:38px; height:38px; display:flex; align-items:center; justify-content:center; border:1.5px solid rgba(193,140,93,.35); border-radius:8px; margin-bottom:14px; }
.fs-name { font-size:15px; font-weight:700; color:#fff; margin-bottom:8px; letter-spacing:.02em; }
.fs-desc { font-size:13.5px; color:#B8C2D0; line-height:1.55; font-weight:300; }
.flow-arrow { display:flex; align-items:center; color:var(--twine); font-size:22px; font-weight:400; }

/* ── CONTINUITY ── */
.cont { padding:80px 0; background:var(--paper); }
.cont-grid { display:grid; grid-template-columns:1.05fr .95fr; gap:56px; align-items:center; }
@media(max-width:820px){ .cont-grid { grid-template-columns:1fr; gap:32px; } }
.cont-left h2 { font-size:clamp(26px,3.4vw,40px); color:var(--navy); margin-bottom:18px; line-height:1.12; max-width:18ch; }
.cont-left p { font-size:17px; color:var(--slate); line-height:1.65; font-weight:300; margin-bottom:16px; }
.cont-link { display:inline-flex; align-items:center; gap:6px; margin-top:10px; font-size:13.5px; font-weight:700; color:var(--navy); letter-spacing:.04em; text-transform:uppercase; }
.cont-link::after { content:"→"; }
.cont-link:hover { color:var(--twine); }
.cont-card { background:var(--navy); border-radius:8px; padding:32px 30px; border-top:3px solid var(--twine); }
.cc-k { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.18em; color:var(--twine); margin-bottom:20px; }
.cc-row { display:grid; grid-template-columns:1fr auto 1fr; align-items:center; gap:12px; padding:13px 0; border-bottom:1px solid rgba(255,255,255,.08); }
.cc-row:last-child { border-bottom:none; }
.cc-was { font-size:14px; color:#8FA4B8; font-weight:300; text-align:right; }
.cc-arrow { color:var(--twine); font-size:14px; }
.cc-now { font-size:14px; color:#fff; font-weight:500; }

/* ── TRUST & SAFETY ── */
.safe { padding:80px 0; background:var(--paper-2); border-top:1px solid var(--rule); border-bottom:1px solid var(--rule); }
.safe h2 { font-size:clamp(26px,3.4vw,40px); color:var(--navy); margin-bottom:40px; line-height:1.12; max-width:24ch; }
.safe-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
@media(max-width:820px){ .safe-grid { grid-template-columns:1fr; gap:20px; } }
.safe-item { border-top:2px solid var(--twine); padding-top:18px; }
.si-h { font-size:17px; font-weight:700; color:var(--navy); margin-bottom:10px; letter-spacing:-.01em; }
.safe-item p { font-size:15px; color:var(--slate); line-height:1.6; font-weight:300; }

/* ── FINAL CTA ── */
.final-cta { background:var(--navy); border-top:3px solid var(--twine); text-align:center; padding:92px 32px; }
.final-cta h2 { font-size:clamp(28px,4.4vw,50px); color:#fff; margin-bottom:20px; line-height:1.06; }
.final-cta p { color:#A8B4C0; font-size:18px; font-weight:300; max-width:50ch; margin:0 auto 34px; line-height:1.6; }
</style>

<script is:inline>
if(!window.matchMedia("(prefers-reduced-motion: reduce)").matches){
const io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.style.animation='rise .7s cubic-bezier(.2,.7,.2,1) forwards';io.unobserve(e.target);}});},{threshold:.1});
document.querySelectorAll('.part-card,.flow-step,.safe-item,.cc-row').forEach((el,i)=>{el.style.opacity='0';el.style.animationDelay=(i*.05)+'s';io.observe(el);});
}
</script>

</BaseLayout>
