---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Book a Reporting Trust Diagnostic | Aesop Analytics";
const description = "Schedule a free 30-minute Reporting Trust Diagnostic. No pitch, no slide deck — just an honest conversation about your data situation.";
---

<BaseLayout title={title} description={description} path="/diagnostic">

  <section class="diag-hero">
    <div class="wrap">
      <div class="eyebrow">Free · 30 minutes · No pitch</div>
      <h1>Reporting Trust Diagnostic</h1>
      <p class="dek">A short, honest conversation about your reporting situation. We'll ask a few questions about your data environment and what isn't working. You'll leave with a clear sense of whether there's a fit — and what a useful first step looks like, whether that's with us or not.</p>
      <ul class="promises">
        <li>No slide deck, no sales presentation</li>
        <li>If there's no fit, we'll say so — and suggest alternatives</li>
        <li>Typically leads to a scoped proposal or a set of quick wins you can act on yourself</li>
      </ul>
    </div>
  </section>

  <section class="cal-section">
    <div class="wrap">
      <div class="cal-wrap">
        <!-- Cal.com inline embed -->
        <div id="cal-embed" style="min-height:600px;width:100%;"></div>
      </div>
      <p class="cal-note">Prefer email? Reach us at <a href="mailto:hello@aesopanalytics.com">hello@aesopanalytics.com</a> — we respond within one business day.</p>
    </div>
  </section>

  <section class="after-path" id="after">
    <div class="wrap">
      <div class="ap-eyebrow">No mystery, no maybe-we'll-call-you</div>
      <h2>What happens after the call</h2>
      <p class="ap-intro">Most consultations end with a vague “we'll follow up.” Ours doesn't. Here is the exact path, so you know what you're walking into before you book.</p>
      <div class="ap-steps">
        <div class="ap-step">
          <div class="ap-num">1</div>
          <div class="ap-name">A written recap — within 24 hours</div>
          <div class="ap-desc">You get a short email summarizing what we heard, in your words — the pain, the context, and where we'd expect the real problem to sit. Usually that's a definition-and-ownership problem, not a data-quality one. Speed is itself a signal.</div>
        </div>
        <div class="ap-step">
          <div class="ap-num">2</div>
          <div class="ap-name">An honest read — fit or not</div>
          <div class="ap-desc">If a <a href="/assessment">Reporting Clarity Assessment</a> is the right next step, the recap comes with a one-page scope: what we'd examine, the ten deliverables, and a single fixed fee agreed before any work begins. If it isn't, we say so and point you to a better path — a free resource, a different starting point, or “revisit in a few months.” We'd rather tell you honestly than sell you the wrong thing.</div>
        </div>
        <div class="ap-step">
          <div class="ap-num">3</div>
          <div class="ap-name">You decide — on your own clock</div>
          <div class="ap-desc">The scope stands alone. Reply to confirm and we send a short agreement — work typically starts within a few weeks. Want to adjust scope first? Just say so. No drip campaign, no pressure either way.</div>
        </div>
      </div>
      <p class="ap-foot">Either way, the quick wins we identify on the call are yours to act on — whether or not you ever do anything further with us.</p>
    </div>
  </section>

</BaseLayout>

<script is:inline>
(function (C, A, L) {
  let p = function (a, ar) { a.q.push(ar); };
  let d = C.document;
  C.Cal = C.Cal || function () {
    let cal = C.Cal; let ar = arguments;
    if (!cal.loaded) {
      cal.ns = {}; cal.q = cal.q || [];
      d.head.appendChild(d.createElement("script")).src = A;
      cal.loaded = true;
    }
    if (ar[0] === L) {
      const api = function () { p(api, arguments); };
      const namespace = ar[1];
      api.q = api.q || [];
      if (typeof namespace === "string") {
        cal.ns[namespace] = cal.ns[namespace] || api;
        p(cal.ns[namespace], ar);
        p(cal, ["initNamespace", namespace]);
      } else p(cal, ar);
      return;
    }
    p(cal, ar);
  };
})(window, "https://app.cal.com/embed/embed.js", "init");

Cal("init", "diagnostic", { origin: "https://cal.com" });

Cal.ns.diagnostic("inline", {
  elementOrSelector: "#cal-embed",
  calLink: "jonathan-doreau-9zngtx/30min",
  config: { layout: "month_view" },
});

Cal.ns.diagnostic("ui", {
  styles: { branding: { brandColor: "#C18C5D" } },
  hideEventTypeDetails: false,
});

// GA4 conversion: fire when a diagnostic is successfully booked.
Cal.ns.diagnostic("on", {
  action: "bookingSuccessful",
  callback: function () {
    if (typeof window.gtag === "function") {
      window.gtag("event", "diagnostic_booked", {
        event_category: "conversion",
        event_label: "Reporting Trust Diagnostic booked",
      });
    }
  },
});
</script>

<style>
  .diag-hero { background:var(--navy); padding:72px 0 56px; overflow:hidden; position:relative; }
  .diag-hero::after { content:"æ"; position:absolute; right:-2%; top:-20%; font-family:"Abril Fatface",serif; font-size:min(38vw,460px); line-height:1; color:rgba(193,140,93,.07); pointer-events:none; }
  .diag-hero .wrap { position:relative; z-index:2; max-width:760px; }
  .diag-hero .eyebrow { color:var(--twine); margin-bottom:16px; }
  .diag-hero h1 { font-family:"Newsreader",Georgia,serif; font-weight:500; font-size:clamp(34px,5vw,58px); line-height:1.05; color:#fff; margin-bottom:20px; letter-spacing:-.01em; }
  .diag-hero .dek { font-size:18px; color:#C4BDAE; font-weight:300; line-height:1.65; max-width:58ch; margin-bottom:28px; }
  .promises { list-style:none; display:flex; flex-direction:column; gap:10px; }
  .promises li { font-size:14px; color:#8FA4B8; padding-left:20px; position:relative; }
  .promises li::before { content:"–"; position:absolute; left:0; color:var(--twine); }

  .cal-section { padding:56px 0 80px; background:var(--paper); }
  .cal-section .wrap { max-width:900px; }
  .cal-wrap { background:#fff; border:1px solid var(--line); border-radius:8px; overflow:hidden; }
  .cal-note { margin-top:20px; font-size:14px; color:var(--muted); text-align:center; }
  .cal-note a { color:var(--sepia); text-decoration:underline; text-underline-offset:2px; }
  .cal-note a:hover { color:var(--twine); }

  .after-path { padding:72px 0 88px; background:var(--paper-2); border-top:1px solid var(--rule); }
  .after-path .wrap { max-width:1080px; }
  .ap-eyebrow { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.22em; color:var(--twine); margin-bottom:14px; }
  .after-path h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(28px,3.6vw,42px); line-height:1.1; color:var(--navy); margin-bottom:14px; }
  .ap-intro { font-size:17px; color:var(--muted); font-weight:300; line-height:1.65; max-width:62ch; margin-bottom:40px; }
  .ap-steps { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:20px; }
  .ap-step { background:#fff; border:1px solid var(--line); border-radius:6px; padding:28px 26px; }
  .ap-num { font-family:"Abril Fatface",serif; font-size:30px; color:var(--twine); line-height:1; margin-bottom:14px; }
  .ap-name { font-size:15px; font-weight:700; color:var(--navy); margin-bottom:10px; line-height:1.35; }
  .ap-desc { font-size:14px; color:var(--ink); line-height:1.65; font-weight:300; }
  .ap-desc a { color:var(--sepia); text-decoration:underline; text-underline-offset:2px; }
  .ap-desc a:hover { color:var(--twine); }
  .ap-foot { margin-top:28px; font-size:14px; color:var(--muted); font-style:italic; max-width:62ch; }
</style>
