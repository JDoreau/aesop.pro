---
import BaseLayout from "../layouts/BaseLayout.astro";
import OwlMark from "../components/OwlMark.astro";
import { featured } from "../data/insights.ts";
import { linkHref } from "../data/nav.ts";
const title = 'Reporting Modernization & Data Trust | Aesop Analytics'
const description = 'Governed data-practice software for 50-500 person companies, entered through reporting trust. We fix dashboard sprawl and KPI trust, then leave behind Manteia - a living system that keeps it that way. Principal-led. Nashville, TN.'
const ogDescription = "Most reporting problems are not visualization problems. They are ownership, definition, process, trust, and governance problems.";
---

<BaseLayout title={title} description={description} path="/" ogDescription={ogDescription}>

<!-- ── HERO ── -->
<section class="hero" id="top">
  <div class="hero-in">
    <div class="eyebrow reveal">Reporting Modernization · KPI Trust · Data Governance</div>
    <h1 class="reveal" style="animation-delay:.08s">Modern reporting for leaders who need numbers they can <span class="em">trust.</span></h1>
    <p class="hero-sub reveal" style="animation-delay:.16s">We help growing companies clean up dashboard sprawl, align KPI definitions, reduce manual reporting work, and build practical data governance — so decisions move faster and leadership can trust what they see. Then we leave behind Manteia — a living system that keeps it that way.</p>
    <div class="btn-row reveal" style="animation-delay:.24s">
      <a href="/diagnostic/" class="btn">Book a Reporting Trust Diagnostic</a>
      <a href="/resources/" class="btn ghost">Download the Health Check</a>
    </div>
    <div class="hero-note reveal" style="animation-delay:.38s">Jonathan Doreau · Nashville, TN · aesopanalytics.com</div>
  </div>
</section>

<!-- ── PROMISE ── -->
<div class="promise">
  <div class="promise-in">
    <p>Reporting should clarify decisions<span class="dot"></span>not create debates.</p>
  </div>
</div>

<!-- ── PAIN SECTION ── -->
<section class="pain">
  <div class="wrap">
    <div class="pain-grid">
      <div class="pain-left">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.22em;color:var(--twine);margin-bottom:16px">The real problem</div>
        <h2>The pain isn't bad dashboards. It's that no one trusts the numbers.</h2>
        <p>Most companies investing in BI tools still end up with the same problem: leadership is making decisions on data they don't fully believe. Different teams pull different numbers. KPIs have no agreed owner. Reporting is manually rebuilt every week. The dashboards exist — they're just not trusted.</p>
        <p>That's not a visualization problem. That's an ownership, definition, process, and governance problem. And no new tool fixes it until those are addressed first.</p>
        <div class="pov">"Most reporting problems are not visualization problems. They are ownership, definition, process, trust, and governance problems."</div>
      </div>
      <div class="pain-right">
        <div class="pain-label">Does this sound familiar?</div>
        <div class="pain-list">
          <div class="pain-item"><span class="pi">↯</span><span class="pt">Leadership sees different numbers in different reports</span></div>
          <div class="pain-item"><span class="pi">↯</span><span class="pt">Teams disagree on KPI definitions — Finance says one thing, Sales says another</span></div>
          <div class="pain-item"><span class="pi">↯</span><span class="pt">Analysts spend hours reconciling spreadsheets instead of producing insight</span></div>
          <div class="pain-item"><span class="pi">↯</span><span class="pt">Dashboards exist but aren't trusted — nobody uses them to make decisions</span></div>
          <div class="pain-item"><span class="pi">↯</span><span class="pt">No one knows which report is "official" or whose number is right</span></div>
          <div class="pain-item"><span class="pi">↯</span><span class="pt">Reporting requests pile up with no clear intake or prioritization process</span></div>
          <div class="pain-item"><span class="pi">↯</span><span class="pt">AI initiatives are stalled because the underlying data can't be trusted</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── TRUST METHOD ── -->
<section class="method" id="method">
  <div class="method-in">
    <div class="method-head">
      <h2>How every engagement works.</h2>
      <p>Every engagement follows the same five-phase process — a proven sequence for diagnosing, fixing, and governing reporting systems that have lost the trust of the people who use them.</p>
    </div>
    <div class="trust-steps">
      <div class="trust-step">
        <div class="ts-letter">1</div>
        <div class="ts-name">Triage the reporting estate</div>
        <div class="ts-desc">Catalog every dashboard, spreadsheet, and recurring report. Map owners, users, trust levels, and decision purpose. Find out what's used, what's ignored, and what's duplicated.</div>
      </div>
      <div class="trust-step">
        <div class="ts-letter">2</div>
        <div class="ts-name">Reconcile metric definitions</div>
        <div class="ts-desc">Identify conflicting KPIs. Document how metrics are currently calculated. Expose where Finance, Sales, and Ops are using different definitions for the same word — and why that breaks trust.</div>
      </div>
      <div class="trust-step">
        <div class="ts-letter">3</div>
        <div class="ts-name">Unify ownership &amp; source of truth</div>
        <div class="ts-desc">Assign business owners and technical owners to every metric. Designate the authoritative source system. Establish who approves definition changes and who gets notified.</div>
      </div>
      <div class="trust-step">
        <div class="ts-letter">4</div>
        <div class="ts-name">Standardize reporting practices</div>
        <div class="ts-desc">Create naming conventions, request intake, dashboard certification rules, and report retirement processes. Make it clear which reports are official and how people request changes.</div>
      </div>
      <div class="trust-step">
        <div class="ts-letter">5</div>
        <div class="ts-name">Transition to operating cadence</div>
        <div class="ts-desc">Embed the new process into the business. Establish governance meeting cadences, quality monitoring, and continuous improvement. The goal is a system that sustains itself.</div>
      </div>
    </div>
    <div class="method-cta">
      <p>This process is the backbone of every Reporting Clarity Assessment and Modernization Sprint.</p>
      <a href="/assessment/" class="btn">See how the Assessment works →</a>
    </div>
  </div>
</section>

<!-- ── OFFERS ── -->
<section class="offers" id="services">
  <div class="wrap">
    <div class="offers-label">The offer ladder</div>
    <h2>Start where the risk is lowest.</h2>
    <p class="intro">Every engagement begins with a focused assessment — not a six-month transformation. You get a clear picture of the problem and a practical roadmap before committing to anything larger.</p>
    <div class="offer-cards">

      <!-- Flagship -->
      <a href="/assessment/" class="offer-card flagship" style="text-decoration:none">
        <div class="oc-tag">★ Flagship first offer</div>
        <div class="oc-name">Reporting Clarity Assessment</div>
        <div class="oc-desc">A structured 2–3 week review of your reporting estate: inventory, metric conflicts, KPI gaps, data source map, manual burden analysis, and a prioritized 30/60/90-day modernization roadmap. You'll know exactly where trust is breaking down and what to fix first.</div>
        <div class="oc-meta">
          <span class="oc-pill">$5,000–$9,500</span>
          <span class="oc-pill">2–3 weeks</span>
          <span class="oc-pill">10 deliverables</span>
        </div>
        <div class="oc-link">See what's included →</div>
      </a>

      <!-- Sprint -->
      <a href="/services/#sprint" class="offer-card" style="text-decoration:none">
        <div class="oc-tag">Implementation</div>
        <div class="oc-name">Executive Reporting Modernization Sprint</div>
        <div class="oc-desc">Build or redesign a high-value reporting package — executive KPI dashboard, KPI dictionary, source-of-truth map, and reporting standards guide. Leadership gets a cleaner, trusted reporting system built around actual decisions.</div>
        <div class="oc-meta">
          <span class="oc-pill">$15,000–$40,000</span>
          <span class="oc-pill">4–8 weeks</span>
        </div>
        <div class="oc-link" style="color:var(--twine)">Learn more →</div>
      </a>

      <!-- Governance -->
      <a href="/services/#governance" class="offer-card" style="text-decoration:none">
        <div class="oc-tag">Governance</div>
        <div class="oc-name">Data Governance Starter Kit</div>
        <div class="oc-desc">A practical governance system — KPI dictionary, metric owner matrix, data owner RACI, reporting intake process, and an operating model that reduces metric confusion without creating bureaucracy.</div>
        <div class="oc-meta">
          <span class="oc-pill">$12,000–$35,000</span>
          <span class="oc-pill">4–6 weeks</span>
        </div>
        <div class="oc-link" style="color:var(--twine)">Learn more →</div>
      </a>

      <!-- Retainer -->
      <a href="/services/#retainer" class="offer-card" style="text-decoration:none">
        <div class="oc-tag">Ongoing support</div>
        <div class="oc-name">Fractional Analytics Operations Retainer</div>
        <div class="oc-desc">Senior analytics operating support on an ongoing basis — roadmap management, governance, dashboard improvements, stakeholder intake, and reporting leadership — without the cost of a full-time hire.</div>
        <div class="oc-meta">
          <span class="oc-pill">$3,500–$12,000/mo</span>
          <span class="oc-pill">Defined scope</span>
        </div>
        <div class="oc-link" style="color:var(--twine)">Learn more →</div>
      </a>

    </div>
    <div style="text-align:center;margin-top:36px">
      <p style="font-size:15px;color:var(--muted);margin-bottom:16px">Every engagement begins with a free 30-minute Reporting Trust Diagnostic to make sure there's a fit.</p>
      <a href="/diagnostic/" class="btn">Book a free diagnostic call</a>
    </div>
  </div>
</section>

<!-- ── THE PLATFORM ── -->
<section class="platform-tease">
  <div class="wrap">
    <div class="pt-head">
      <div class="sec-label" style="color:var(--twine)">New — the platform</div>
      <h2>The work no longer ends with a deck.</h2>
      <p>Every engagement now builds you <strong>Manteia</strong> — your data's living system of trust: your estate mapped, your governance visible, and an oracle you can ask in plain English, grounded in your own data with a citation for every claim.</p>
    </div>
    <div class="pt-parts">
      <div class="pt-part"><div class="ptn">Auto-Doc (Aesop Graphion)</div><div class="ptd">Maps your estate automatically — tables, metrics, and the lineage between them.</div></div>
      <div class="pt-part"><div class="ptn">The Record (Aesop Stoa)</div><div class="ptd">Governance you can see — owners, definitions, and the gaps rendered in red.</div></div>
      <div class="pt-part"><div class="ptn">The Oracle (Aesop Pythia)</div><div class="ptd">Answers grounded only in your governed data — it cites its source or says it doesn't know.</div></div>
    </div>
    <a href="/platform/" class="btn">Explore Manteia →</a>
  </div>
</section>

<!-- ── WHO WE SERVE ── -->
<section class="who">
  <div class="wrap">
    <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.22em;color:var(--twine);margin-bottom:16px">Ideal clients</div>
    <h2>Growing companies with real reporting chaos.</h2>
    <p class="intro">The best-fit clients are large enough to have real reporting pain but not so large that procurement and internal politics slow everything down. Typically 50–500 employees, operations-heavy, with no mature analytics operating model.</p>
    <div class="personas">
      <div class="persona"><div class="pn">COO</div><div class="pp">"I can't see what's happening across the business fast enough."</div></div>
      <div class="persona"><div class="pn">CFO</div><div class="pp">"Every department has a different number."</div></div>
      <div class="persona"><div class="pn">VP Operations</div><div class="pp">"We're running the business from spreadsheets and fire drills."</div></div>
      <div class="persona"><div class="pn">Head of Analytics</div><div class="pp">"We're drowning in requests and nobody agrees on definitions."</div></div>
      <div class="persona"><div class="pn">Revenue Operations</div><div class="pp">"Pipeline, forecast, and churn metrics don't line up."</div></div>
      <div class="persona"><div class="pn">Controller / VP Finance</div><div class="pp">"Why are these two reports showing different revenue?"</div></div>
    </div>
    <div class="not-grid" style="margin-top:44px">
      <div class="not-box is">
        <div class="nb-label">We are</div>
        <div class="not-item">A data-governance software company — we leave behind Manteia, a living system you own</div>
        <div class="not-item">A reporting modernization &amp; data trust specialist</div>
        <div class="not-item">Principal-led — you work directly with the principal, diagnosis through delivery, never a rotating junior team</div>
        <div class="not-item">Platform-agnostic — whatever fits, not what earns a margin</div>
      </div>
      <div class="not-box not">
        <div class="nb-label">We are not</div>
        <div class="not-item">A dashboard factory or generic BI contractor</div>
        <div class="not-item">A data engineering body shop</div>
        <div class="not-item">A tool reseller or platform partner</div>
        <div class="not-item">A vague AI consultant</div>
      </div>
    </div>
  </div>
</section>

<!-- ── RESULTS / PROOF ── -->
<section class="results">
  <div class="wrap">
    <div class="results-head">
      <div class="results-eyebrow">Proof</div>
      <h2>The work isn't finished when the dashboard goes live.</h2>
      <p>It's finished when leadership trusts the number, knows who owns it, and understands what decision it supports. Here's what that looked like across recent engagements — anonymized, with the sectors and result signals intact.</p>
    </div>
    <div class="results-grid">
      <a class="res-card" href="/work/#finance-banking">
        <div class="res-n">31</div>
        <div class="res-l">Portfolio KPIs governed with named owners</div>
        <div class="res-meta"><span class="res-sector">Finance &amp; Banking</span><span class="res-link">See the case →</span></div>
      </a>
      <a class="res-card" href="/work/#real-estate-operations">
        <div class="res-n">5</div>
        <div class="res-l">Governed dashboards on one Snowflake source</div>
        <div class="res-meta"><span class="res-sector">Real Estate Operations</span><span class="res-link">See the case →</span></div>
      </a>
      <a class="res-card" href="/work/#nonprofit-impact">
        <div class="res-n">~4<span class="res-unit"> hrs</span></div>
        <div class="res-l">Grant reporting, down from ~12 per grant</div>
        <div class="res-meta"><span class="res-sector">Nonprofit / Impact</span><span class="res-link">See the case →</span></div>
      </a>
    </div>
  </div>
</section>

<!-- ── STATS ── -->
<div class="stats">
  <div class="stats-in">
    <div><div class="stat-n">37<span style="font-size:.5em">+</span></div><div class="stat-l">Combined years in analytics, BI &amp; leadership</div></div>
    <div><div class="stat-n">6</div><div class="stat-l">Industries with deep domain expertise</div></div>
    <div><div class="stat-n">3</div><div class="stat-l">Complete data program modernizations</div></div>
    <div><div class="stat-n">26</div><div class="stat-l">Successful engagements</div></div>
  </div>
</div>

<!-- ── FEATURED INSIGHT ── -->
<section class="featured">
  <div class="wrap">
    <div class="featured-label">Featured study</div>
    <h2>Analysis held to the same standard as our client work.</h2>
    <p class="intro">Rigorous, even-handed, clear about what the data can and can't say.</p>
    <div class="study-card">
      <div class="stxt">
        <div class="stag">{featured.tag}</div>
        <h3>{featured.title}</h3>
        <p>{featured.desc}</p>
        <a href={linkHref(`/insights/${featured.slug}`)} class="study-btn">{featured.read}</a>
      </div>
      <div class="sviz">
        <img src={featured.image} alt={featured.imageAlt} loading="lazy" width="260" height="260" />
      </div>
    </div>
    <a href="/insights/" class="see-all">All insights &amp; field studies</a>
  </div>
</section>

<!-- ── ABOUT TEASER ── -->
<section class="about-tease">
  <div class="wrap">
    <div class="about-grid">
      <div class="about-mark" aria-hidden="true"><OwlMark body="var(--navy)" eyes="var(--twine)" style="width:clamp(110px,16vw,180px);height:auto;display:block;margin:0 auto;" /><span class="sm">Jonathan Doreau</span></div>
      <div class="about-right">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.22em;color:var(--twine);margin-bottom:16px">Who's behind it</div>
        <h2>Fifteen years turning messy data into decisions people trust.</h2>
        <p><strong>Jonathan Doreau</strong> has spent 15+ years as an analytics and BI leader across finance, healthcare and research (including an NIH-funded program), real estate, and nonprofit — building reporting systems from scratch, fixing environments that had lost trust, and translating messy data into governance that organizations actually use.</p>
        <p>Today, Jonathan runs Aesop as a principal-led practice — you work directly with him, diagnosis through delivery — drawing on a small circle of independent senior specialists for added depth behind the scenes. The common thread across every engagement: turning fragmented, distrusted reporting into systems people rely on when they make real decisions.</p>
        <div class="creds"><span class="cred-tag">SQL</span><span class="cred-tag">Power BI</span><span class="cred-tag">Tableau</span><span class="cred-tag">Snowflake</span><span class="cred-tag">KPI Design</span><span class="cred-tag">Governance</span><span class="cred-tag">Reporting Modernization</span></div>
        <a href="/about/" class="about-link">Full background</a>
      </div>
    </div>
  </div>
</section>

<!-- ── FINAL CTA ── -->
<section class="final-cta">
  <div class="eyebrow" style="color:var(--twine);letter-spacing:.28em;font-size:11.5px;font-weight:600;text-transform:uppercase;margin-bottom:24px">Start here</div>
  <h2>Find out where your reporting trust is breaking down.</h2>
  <p>A free 30-minute diagnostic call — no pitch, no slide deck. We identify the biggest reporting trust gaps in your organization and whether a Reporting Clarity Assessment would be useful. If it's not the right fit, we'll say so.</p>
  <div class="btn-row" style="justify-content:center">
    <a href="/diagnostic/" class="btn" style="color:var(--navy)">Book a Reporting Trust Diagnostic</a>
    <a href="/resources/" class="btn ghost">Download the Health Check</a>
  </div>
</section>

<!-- ── FOOTER ── -->

<style>
section { position:relative; }
/* Newsreader = primary display/header font. Abril retained as sparing accent only. */
/* ── HERO ── */
  .hero { background:var(--navy); color:var(--cream); overflow:hidden; min-height:88vh; display:flex; align-items:center; }
.hero::after { content:"æ"; position:absolute; right:-3%; top:-14%; font-family:"Abril Fatface",serif; font-size:min(48vw,580px); line-height:1; color:rgba(193,140,93,.07); pointer-events:none; user-select:none; }
.hero-in { max-width:1080px; margin:0 auto; padding:100px 32px 90px; position:relative; z-index:2; }
.hero h1 { font-family:"Newsreader",Georgia,serif; font-weight:500; font-size:clamp(42px,6.6vw,80px); line-height:1.05; max-width:18ch; margin-bottom:28px; color:var(--cream); letter-spacing:-.01em; }
.hero h1 .em { color:var(--twine); }
.hero .hero-sub { font-size:clamp(16px,1.8vw,20px); line-height:1.6; color:#C4BDAE; max-width:54ch; margin-bottom:40px; font-weight:300; }
.btn { display:inline-block; background:var(--twine); color:#fff; font-family:"DM Sans",sans-serif; font-weight:600; letter-spacing:.03em; padding:15px 28px; border-radius:4px; font-size:15px; transition:transform .18s,background .18s; }
.btn:hover { transform:translateY(-2px); background:var(--sepia); }
.btn.ghost { background:transparent; color:var(--cream); border:1.5px solid rgba(243,239,230,.3); margin-left:10px; }
.btn.ghost:hover { border-color:var(--twine); color:var(--twine); background:transparent; transform:translateY(-2px); }
.btn-row { display:flex; flex-wrap:wrap; gap:12px; }
.hero-note { margin-top:52px; display:flex; align-items:center; gap:12px; color:#8FA4B8; font-size:12px; font-weight:500; letter-spacing:.1em; text-transform:uppercase; }
.hero-note::before { content:''; display:block; width:28px; height:1px; background:var(--info); }
/* ── PROMISE BAR ── */
  .promise { background:var(--paper-2); border-bottom:1px solid var(--rule); }
.promise-in { max-width:1080px; margin:0 auto; padding:32px; text-align:center; }
.promise p { font-family:"DM Sans",sans-serif; font-weight:500; font-size:clamp(17px,2.2vw,25px); color:var(--navy); line-height:1.4; max-width:42ch; margin:0 auto; }
.dot { display:inline-block; width:4px; height:4px; border-radius:50%; background:var(--twine); margin:0 9px; vertical-align:middle; }
/* ── PAIN SECTION ── */
  .pain { padding:80px 0; background:var(--paper); }
.pain-grid { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start; }
@media(max-width:760px) {
  .pain-grid { grid-template-columns:1fr; gap:36px; }
}
.pain-left h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(28px,3.8vw,42px); line-height:1.1; color:var(--navy); margin-bottom:20px; }
.pain-left p { font-size:17px; color:var(--slate); line-height:1.65; font-weight:300; margin-bottom:16px; }
.pain-left .pov { font-family:"DM Sans",sans-serif; font-weight:500; font-style:italic; font-size:clamp(16px,2vw,20px); color:var(--navy); border-left:4px solid var(--twine); padding:8px 0 8px 22px; margin-top:28px; line-height:1.4; }
.pain-right { }
.pain-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.22em; color:var(--twine); margin-bottom:20px; }
.pain-list { display:flex; flex-direction:column; gap:0; border-top:2px solid var(--rule); }
.pain-item { display:flex; gap:14px; align-items:flex-start; padding:16px 0; border-bottom:1px solid var(--line); }
.pain-item .pi { font-size:18px; color:var(--contessa); flex-shrink:0; line-height:1.4; font-weight:700; }
.pain-item .pt { font-size:16px; color:var(--ink); line-height:1.5; font-weight:400; }
/* ── TRUST METHOD ── */
  .method { background:var(--navy); padding:80px 0; }
.method-in { max-width:1080px; margin:0 auto; padding:0 32px; }
.method-head { display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:end; margin-bottom:52px; }
@media(max-width:760px) {
  .method-head { grid-template-columns:1fr; gap:20px; }
}
.method-head h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:clamp(28px,3.8vw,44px); color:#fff; line-height:1.1; letter-spacing:-.01em; }
.method-head p { font-size:16.5px; color:#C4BDAE; font-weight:400; line-height:1.6; }
.trust-steps { display:grid; grid-template-columns:repeat(5,1fr); gap:3px; border-radius:6px; overflow:hidden; }
@media(max-width:860px) {
  .trust-steps { grid-template-columns:1fr 1fr; }
}
@media(max-width:500px) {
  .trust-steps { grid-template-columns:1fr; }
}
.trust-step { background:var(--navy-2); padding:28px 22px; position:relative; }
.trust-step:hover { background:var(--navy-3); transition:background .2s; }
.ts-letter { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:26px; color:var(--twine); line-height:1; margin-bottom:14px; display:inline-flex; align-items:center; justify-content:center; width:40px; height:40px; border:1.5px solid rgba(193,140,93,.35); border-radius:8px; }
.ts-name { font-size:14px; font-weight:700; color:#fff; margin-bottom:10px; letter-spacing:.02em; }
.ts-desc { font-size:13.5px; color:#B8C2D0; line-height:1.55; font-weight:400; }
.method-cta { margin-top:40px; text-align:center; }
.method-cta p { font-size:15px; color:#C4BDAE; margin-bottom:20px; font-weight:400; }
.method-cta .btn { padding:11px 24px; font-size:14px; }
/* ── OFFER STRIP ── */
  .offers { padding:80px 0; background:var(--paper-2); border-top:1px solid var(--rule); border-bottom:1px solid var(--rule); }
.offers-label { font-weight:700; text-transform:uppercase; letter-spacing:.22em; font-size:11px; color:var(--twine); margin-bottom:16px; }
