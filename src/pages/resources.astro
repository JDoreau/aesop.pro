      var bg = document.createElementNS(ns, 'circle'); bg.setAttribute('cx', '67'); bg.setAttribute('cy', '67'); bg.setAttribute('r', '' + r); bg.setAttribute('fill', 'none'); bg.setAttribute('stroke', '#EDE7DA'); bg.setAttribute('stroke-width', '12');
      var fg = document.createElementNS(ns, 'circle'); fg.setAttribute('cx', '67'); fg.setAttribute('cy', '67'); fg.setAttribute('r', '' + r); fg.setAttribute('fill', 'none'); fg.setAttribute('stroke', col); fg.setAttribute('stroke-width', '12'); fg.setAttribute('stroke-linecap', 'round'); fg.setAttribute('stroke-dasharray', '' + c); fg.setAttribute('stroke-dashoffset', '' + off);
      svg.appendChild(bg); svg.appendChild(fg);
      var num = el('div', 'rep-gauge-num'); var sc = el('div', 'rep-gauge-score', '' + total); sc.style.color = col; num.appendChild(sc); num.appendChild(el('div', 'rep-gauge-max', '/ 100'));
      wrap.appendChild(svg); wrap.appendChild(num); return wrap;
    }
    function render(total, s) {
      total = total || 0; s = s || scores(); var band = bandFor(total); report.innerHTML = '';
      var card = el('div', 'rep-scorecard'); card.appendChild(gauge(total, band));
      var head = el('div', 'rep-headline'); head.appendChild(el('div', 'rep-band-name', band.label)); head.appendChild(el('div', 'rep-band-blurb', band.blurb)); card.appendChild(head); report.appendChild(card);
      var ids = fired(s); var lead = ids.length ? DATA.patterns[ids[0]] : DATA.fallback;
      var diag = el('div', 'rep-diagnosis sev-' + lead.severity);
      diag.appendChild(el('div', 'rep-diag-kicker', 'Lead diagnosis')); diag.appendChild(el('div', 'rep-diag-title', lead.title)); diag.appendChild(el('div', 'rep-diag-body', lead.body)); report.appendChild(diag);
      var rest = ids.slice(1, 5);
      if (rest.length) {
        report.appendChild(el('div', 'rep-section-label', 'What else your scores point to'));
        var grid = el('div', 'rep-patterns');
        rest.forEach(function (id) { var p = DATA.patterns[id]; var cc = el('div', 'rep-pattern sev-' + p.severity); cc.appendChild(el('div', 'rep-pat-title', p.title)); cc.appendChild(el('div', 'rep-pat-body', p.body)); grid.appendChild(cc); });
        report.appendChild(grid);
      }
      report.appendChild(el('div', 'rep-section-label', 'Area-by-area read'));
      var areas = el('div', 'rep-areas');
      DATA.areas.forEach(function (ar) { var v = s[ar.key]; var cc = colorClass(v); var row = el('div', 'rep-area-row');
        var meta = el('div', 'rep-area-meta'); meta.appendChild(el('div', 'rep-area-name', ar.name));
        var bar = el('div', 'rep-area-bar'); var fill = el('div', 'rep-area-fill'); fill.style.width = (v * 10) + '%'; fill.style.background = cc === 'red' ? '#CE796B' : (cc === 'yellow' ? '#D4A844' : '#5E9A82'); bar.appendChild(fill); meta.appendChild(bar); row.appendChild(meta);
        row.appendChild(el('div', 'rep-area-chip ' + cc, v + '/10'));
        row.appendChild(el('div', 'rep-area-text', v <= 3 ? ar.low : (v <= 6 ? ar.mid : ar.high))); areas.appendChild(row); });
      report.appendChild(areas);
      var lows = DATA.areas.map(function (ar) { return { key: ar.key, name: ar.name, v: s[ar.key] }; }).filter(function (o) { return o.v <= 6; }).sort(function (x, y) { return x.v - y.v; }).slice(0, 3);
      report.appendChild(el('div', 'rep-section-label', 'Start here'));
      if (lows.length) { var ol = el('ol', 'rep-start'); lows.forEach(function (o) { var li = el('li'); var d = el('div'); d.appendChild(el('span', 'rep-start-name', o.name)); d.appendChild(el('span', 'rep-start-advice', DATA.advice[o.key])); li.appendChild(d); ol.appendChild(li); }); report.appendChild(ol); }
      else { report.appendChild(el('p', 'rep-diag-body', 'Every area is in solid shape. Keep governance scaled as you grow and re-run this each quarter to catch drift early.')); }
      var cta = el('div', 'rep-cta'); cta.appendChild(el('div', 'rep-cta-title', DATA.cta.title)); cta.appendChild(el('div', 'rep-cta-body', DATA.cta.body));
      var acts = el('div', 'rep-cta-actions'); var a1 = document.createElement('a'); a1.className = 'btn'; a1.href = '/diagnostic'; a1.textContent = 'Book a diagnostic'; acts.appendChild(a1);
      var pb = el('button', 'rep-print', 'Print or save as PDF'); pb.type = 'button'; pb.addEventListener('click', printReport); acts.appendChild(pb);
      cta.appendChild(acts); report.appendChild(cta);
    }
