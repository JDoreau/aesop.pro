---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = 'Free Resources: Reporting Trust Tools | Aesop Analytics'
const description = 'Free reporting trust tools - a 2-minute self-check, the full 30-question Health Check, a dashboard audit, a sample assessment, and a letter for your team. No email walls.'
const ogDescription = "Free tools for reporting trust: self-checks, a dashboard audit, a sample assessment deliverable, and more. No email required.";
---

<BaseLayout title={title} description={description} path="/resources" ogDescription={ogDescription}>

<!-- HERO -->
<section class="hero">
  <div class="hero-in">
    <div>
      <div class="eyebrow">Free resources</div>
      <span class="hero-free">100% Free · No email required</span>
      <h1>Free tools for reporting trust.</h1>
      <p>Self-checks, audits, and working examples — built from the same method we use in paid engagements. Start with the 2-minute self-check below, or go straight to the full toolkit.</p>
      <a href="#checklist" class="btn">Take the self-check →</a>
    </div>
    <!-- Score preview -->
    <div class="score-card">
      <h3>Example scoring preview</h3>
      <div class="score-area">
        <div class="sa-label"><span class="sa-name">KPI definitions</span><span class="sa-score red">2/10</span></div>
        <div class="sa-bar"><div class="sa-fill red" style="width:20%"></div></div>
      </div>
      <div class="score-area">
        <div class="sa-label"><span class="sa-name">Report ownership</span><span class="sa-score yellow">5/10</span></div>
        <div class="sa-bar"><div class="sa-fill yellow" style="width:50%"></div></div>
      </div>
      <div class="score-area">
        <div class="sa-label"><span class="sa-name">Data source clarity</span><span class="sa-score red">3/10</span></div>
        <div class="sa-bar"><div class="sa-fill red" style="width:30%"></div></div>
      </div>
      <div class="score-area">
        <div class="sa-label"><span class="sa-name">Executive alignment</span><span class="sa-score yellow">4/10</span></div>
        <div class="sa-bar"><div class="sa-fill yellow" style="width:40%"></div></div>
      </div>
      <div class="score-area">
        <div class="sa-label"><span class="sa-name">Dashboard usage</span><span class="sa-score green">7/10</span></div>
        <div class="sa-bar"><div class="sa-fill green" style="width:70%"></div></div>
      </div>
      <div style="font-size:12px;color:#4A6070;margin-top:14px;text-align:center;font-style:italic">Illustrative — your scores will differ</div>
    </div>
  </div>
</section>

<!-- THE TOOLKIT (resource directory) -->
<section class="toolkit">
  <div class="wrap">
    <div class="sec-label">The toolkit</div>
    <h2>Four free tools, one method.</h2>
    <div class="tool-grid">
      <a href="/resources/health-check/" class="tool-card">
        <div class="tc-tag">Self-assessment · ~10 min</div>
        <h3>Reporting Trust Health Check</h3>
        <p>The full version: 10 areas, 3 signal questions each, with a scored, printable report. The deeper read on where trust is breaking down.</p>
        <span class="tc-go">Take the Health Check →</span>
      </a>
      <a href="/resources/dashboard-audit/" class="tool-card">
        <div class="tc-tag">Audit · 30 questions</div>
        <h3>Dashboard Audit</h3>
        <p>Score one dashboard for clarity, trust, and decision-usefulness — and get fix hints for every weak answer.</p>
        <span class="tc-go">Run the audit →</span>
      </a>
      <a href="/resources/sample-assessment/" class="tool-card">
        <div class="tc-tag">Worked example</div>
        <h3>Sample Assessment</h3>
        <p>What a Reporting Clarity Assessment actually delivers — a complete anonymized example, findings to roadmap.</p>
        <span class="tc-go">Read the sample →</span>
      </a>
      <a href="/resources/trust-letter/" class="tool-card">
        <div class="tc-tag">For your team</div>
        <h3>The Reporting Trust Letter</h3>
        <p>A plain-language letter you can adapt and send internally to start the reporting-trust conversation.</p>
        <span class="tc-go">Get the letter →</span>
      </a>
    </div>
  </div>
</section>

<!-- QUICK SELF-CHECK (now the full Health Check) -->
<section class="covers" id="checklist">
  <div class="wrap">
    <div class="sec-label">The self-check · 10 areas · ~2 minutes</div>
    <h2>Where reporting trust breaks down — and how to measure it.</h2>
    <p class="intro">Rate ten areas of your reporting from 1 to 10 and get a scored read-out that interprets every area and the patterns between them — your TRUST Index, a lead diagnosis, and a prioritized place to start. It's a genuine diagnostic, generated right in your browser.</p>
    <div class="sc-teaser">
      <div class="sc-teaser-main">
        <div class="sc-teaser-kicker">Reporting Trust Health Check</div>
        <h3 class="sc-teaser-title">Get your TRUST Index — 0 to 100, with a real diagnosis.</h3>
        <p class="sc-teaser-body">We folded the old quick slider into one canonical instrument: ten areas, three signal questions each, a scored band, an area-by-area read, and a "start here" list you can print and bring to a diagnostic call. About two minutes for a fast pass.</p>
        <a href="/resources/health-check/" class="btn">Take the Health Check →</a>
      </div>
      <ul class="sc-teaser-list">
        <li>A 0–100 TRUST Index, band-gated so a high score means a genuinely trustworthy operation</li>
        <li>A lead diagnosis plus the patterns your scores point to</li>
        <li>An area-by-area read with a prioritized place to start</li>
        <li>A printable, branded report you can keep or share</li>
      </ul>
    </div>
  </div>
</section>

<!-- HOW TO USE -->
<section class="how-use">
  <div class="wrap">
    <div class="sec-label">How to use it</div>
    <h2>Three ways to put it to work.</h2>
    <div class="steps">
      <div class="step">
        <div class="sn">01</div>
        <h3>Score it yourself</h3>
        <p>Work through each area with the signal questions. Score 1–10. Areas below 5 are where trust is most at risk. Below 3 means the problem is likely already costing you decisions.</p>
      </div>
      <div class="step">
        <div class="sn">02</div>
        <h3>Score it as a team</h3>
        <p>Have your analytics team, finance lead, and a department head each score the same areas independently. The gaps between scores are often as revealing as the scores themselves.</p>
      </div>
      <div class="step">
        <div class="sn">03</div>
        <h3>Use it to prep for a diagnostic call</h3>
        <p>Bring your scores to the free Reporting Trust Diagnostic call. It makes the conversation significantly more productive — we can focus on the lowest-scoring areas and work out whether a structured assessment would be useful.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<div class="cta">
  <h2>Want help interpreting your score?</h2>
  <p>A free 30-minute diagnostic call — bring your Health Check scores and we'll identify the highest-impact areas together.</p>
  <a href="/diagnostic/" class="btn">Book a Reporting Trust Diagnostic →</a>
</div>

<style>
/* HERO */
  .hero { background:var(--navy); padding:72px 0 60px; overflow:hidden; position:relative; }
.hero::after { content:"æ"; position:absolute; right:-2%; top:-18%; font-family:"Abril Fatface",serif; font-size:min(40vw,480px); line-height:1; color:rgba(193,140,93,.07); pointer-events:none; }
.hero-in { max-width:1080px; margin:0 auto; padding:0 32px; position:relative; z-index:2; display:grid; grid-template-columns:1.1fr .9fr; gap:56px; align-items:center; }
@media(max-width:720px) {
  .hero-in { grid-template-columns:1fr; gap:32px; }
}
.hero h1 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(32px,5vw,56px); line-height:1.05; color:#fff; margin-bottom:18px; }
.hero p { font-size:17px; color:#C4BDAE; font-weight:300; line-height:1.6; margin-bottom:24px; max-width:48ch; }
.hero-free { display:inline-block; background:rgba(193,140,93,.15); border:1px solid rgba(193,140,93,.4); color:var(--twine); font-size:13px; font-weight:700; padding:6px 14px; border-radius:4px; margin-bottom:20px; letter-spacing:.04em; }
.btn { display:inline-block; background:var(--twine); color:#fff; font-family:"DM Sans",sans-serif; font-weight:600; padding:14px 26px; border-radius:4px; font-size:15px; transition:transform .18s,background .18s; }
.btn:hover { transform:translateY(-2px); background:var(--sepia); }
/* Score preview card */
  .score-card { background:var(--navy-2); border:1px solid var(--navy-3); border-radius:8px; padding:28px 24px; }
.score-card h3 { font-size:13px; font-weight:700; color:var(--twine); text-transform:uppercase; letter-spacing:.14em; margin-bottom:18px; }
.score-area { margin-bottom:12px; }
.sa-label { display:flex; justify-content:space-between; font-size:13px; margin-bottom:5px; }
.sa-name { color:#C4BDAE; font-weight:400; }
.sa-score { font-weight:700; }
.sa-score.red { color:var(--contessa); }
.sa-score.yellow { color:var(--warn); }
.sa-score.green { color:#7EB09B; }
.sa-bar { height:6px; background:rgba(255,255,255,.08); border-radius:3px; overflow:hidden; }
.sa-fill { height:100%; border-radius:3px; }
.sa-fill.red { background:var(--contessa); }
.sa-fill.yellow { background:var(--warn); }
.sa-fill.green { background:#7EB09B; }
/* THE TOOLKIT (resource directory) */
  .toolkit { padding:72px 0 8px; }
.toolkit h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(26px,3.4vw,40px); color:var(--navy); margin-bottom:28px; }
.tool-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
@media(max-width:640px) { .tool-grid { grid-template-columns:1fr; } }
.tool-card { display:block; background:#fff; border:1px solid var(--line); border-top:3px solid var(--twine); border-radius:6px; padding:24px 22px; transition:transform .15s, box-shadow .15s; }
.tool-card:hover { transform:translateY(-2px); box-shadow:0 14px 34px -24px rgba(15,31,56,.35); }
.tc-tag { font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.16em; color:var(--twine); margin-bottom:10px; }
.tool-card h3 { font-size:17px; font-weight:700; color:var(--navy); margin-bottom:8px; }
.tool-card p { font-size:14px; color:var(--slate); line-height:1.55; font-weight:300; margin-bottom:14px; }
.tc-go { font-size:13px; font-weight:700; color:var(--sepia); }
/* QUICK SELF-CHECK */
  .covers { padding:72px 0; }
.covers h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(26px,3.4vw,40px); color:var(--navy); margin-bottom:14px; }
.covers .intro { font-size:17px; color:var(--slate); font-weight:300; max-width:58ch; margin-bottom:44px; line-height:1.6; }
/* SELF-CHECK TEASER (handoff to the full Health Check) */
  .sc-teaser { display:grid; grid-template-columns:1.25fr .9fr; gap:34px; align-items:center; background:#fff; border:1px solid var(--line); border-top:3px solid var(--twine); border-radius:10px; padding:32px 34px; box-shadow:0 14px 34px -24px rgba(15,31,56,.35); }
@media(max-width:720px) { .sc-teaser { grid-template-columns:1fr; gap:24px; padding:26px 22px; } }
.sc-teaser-kicker { font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.16em; color:var(--twine); margin-bottom:11px; }
.sc-teaser-title { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:clamp(20px,2.4vw,27px); color:var(--navy); line-height:1.18; margin-bottom:13px; }
.sc-teaser-body { font-size:14.5px; color:var(--slate); line-height:1.6; font-weight:300; margin-bottom:22px; max-width:54ch; }
.sc-teaser-list { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:13px; }
.sc-teaser-list li { position:relative; padding-left:26px; font-size:13.5px; color:var(--slate); line-height:1.5; font-weight:300; }
.sc-teaser-list li::before { content:"✓"; position:absolute; left:0; top:1px; color:var(--sepia); font-weight:700; }
/* HOW TO USE IT */
  .how-use { background:var(--paper-2); border-top:1px solid var(--rule); border-bottom:1px solid var(--rule); padding:64px 0; }
.how-use h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(24px,3.2vw,36px); color:var(--navy); margin-bottom:36px; }
.steps { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
@media(max-width:640px) {
  .steps { grid-template-columns:1fr; }
}
.step { background:#fff; border:1px solid var(--line); border-radius:6px; padding:22px 20px; }
.step .sn { font-family:"Abril Fatface",serif; font-size:32px; color:var(--twine); opacity:.5; line-height:1; margin-bottom:8px; }
.step h3 { font-size:16px; font-weight:700; color:var(--navy); margin-bottom:8px; }
.step p { font-size:14px; color:var(--slate); line-height:1.55; font-weight:300; }
/* CTA */
  .cta { border-top:3px solid var(--twine); background:var(--paper-2); padding:72px 32px; text-align:center; border-bottom:1px solid var(--rule); }
.cta h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(24px,3.4vw,38px); color:var(--navy); margin-bottom:16px; }
.cta p { font-size:17px; color:var(--slate); font-weight:300; max-width:46ch; margin:0 auto 28px; line-height:1.6; }

</style>

</BaseLayout>
