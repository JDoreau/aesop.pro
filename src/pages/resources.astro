    var ran = false;
    var BANDCOLOR = { critical: '#CE796B', concern: '#D4A844', stable: '#C18C5D', strong: '#5E9A82' };
    function colorClass(v) { return v <= 3 ? 'red' : (v <= 6 ? 'yellow' : 'green'); }
    function scores() { var s = {}; sliders.forEach(function (sl) { s[sl.dataset.area] = parseInt(sl.value, 10); }); return s; }
    function bandFor(t) { for (var i = 0; i < DATA.bands.length; i++) { if (t >= DATA.bands[i].min && t <= DATA.bands[i].max) return DATA.bands[i]; } return DATA.bands[DATA.bands.length - 1]; }
    function el(tag, cls, txt) { var e = document.createElement(tag); if (cls) e.className = cls; if (txt != null) e.textContent = txt; return e; }
    function fired(s) {
      function lo(k) { return s[k] <= 3; } function hi(k) { return s[k] >= 7; }
      var total = 0, lowCount = 0; KEYS.forEach(function (k) { total += s[k]; if (s[k] <= 3) lowCount++; }); var avg = total / KEYS.length;
      var R = []; function add(id, cond) { if (cond) R.push(id); }
      add('systemic', avg <= 3.6);
      add('foundation', lo('kpi') && lo('source'));
      add('conflicting', lo('source') && lo('duplication'));
      add('accountability', lo('ownership') && lo('governance'));
      add('manual_errors', lo('manual') && lo('quality'));
      add('build_abandon', lo('usage') && lo('duplication'));
      add('exec_blind', lo('exec') && lo('usage'));
      add('premature_ai', lo('ai') && (lo('kpi') || lo('source')));
      add('fragile', hi('kpi') && hi('source') && s['governance'] <= 4);
      add('last_mile', hi('kpi') && hi('quality') && (lo('usage') || lo('exec')));
      add('governance_ahead', hi('governance') && (lo('kpi') || lo('source')));
      add('weak_link', lowCount === 1 && avg >= 6.5);
      add('healthy', avg >= 7.5 && lowCount === 0);
      R.sort(function (x, y) { return DATA.patterns[y].priority - DATA.patterns[x].priority; });
      return R;
    }
    function gauge(total, band) {
      var pct = Math.round((total - 10) / 90 * 100); pct = Math.max(0, Math.min(100, pct));
      var col = BANDCOLOR[band.key] || '#C18C5D';
