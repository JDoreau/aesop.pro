---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = 'Free Reporting Trust Health Check | Aesop Analytics'
const description = 'A free reporting trust self-check. Rate 10 areas - KPI definitions, ownership, governance, data quality - and get an instant scored report. No email required.'
const ogDescription = "Score your reporting environment across 10 diagnostic areas. Know where trust is breaking down before you start fixing it.";
---

<BaseLayout title={title} description={description} path="/resources" ogDescription={ogDescription}>

<!-- HERO -->
<section class="hero">
  <div class="hero-in">
    <div>
      <div class="eyebrow">Free resource</div>
      <span class="hero-free">100% Free · No email required</span>
      <h1>The Reporting Trust Health Check</h1>
      <p>Score your reporting environment across 10 diagnostic areas. Understand exactly where trust is breaking down — before you spend a dollar fixing it.</p>
      <a href="#checklist" class="btn">Take the Health Check →</a>
    </div>
    <!-- Score preview -->
    <div class="score-card">
      <h3>Example scoring preview</h3>
      <div class="score-area">
        <div class="sa-label"><span class="sa-name">KPI definitions</span><span class="sa-score red">2/10</span></div>
        <div class="sa-bar"><div class="sa-fill red" style="width:20%"></div></div>
      </div>
      <div class="score-area">
        <div class="sa-label"><span class="sa-name">Report ownership</span><span class="sa-score yellow">5/10</span></div>
        <div class="sa-bar"><div class="sa-fill yellow" style="width:50%"></div></div>
      </div>
      <div class="score-area">
        <div class="sa-label"><span class="sa-name">Data source clarity</span><span class="sa-score red">3/10</span></div>
        <div class="sa-bar"><div class="sa-fill red" style="width:30%"></div></div>
      </div>
      <div class="score-area">
        <div class="sa-label"><span class="sa-name">Executive alignment</span><span class="sa-score yellow">4/10</span></div>
        <div class="sa-bar"><div class="sa-fill yellow" style="width:40%"></div></div>
      </div>
      <div class="score-area">
        <div class="sa-label"><span class="sa-name">Dashboard usage</span><span class="sa-score green">7/10</span></div>
        <div class="sa-bar"><div class="sa-fill green" style="width:70%"></div></div>
      </div>
      <div style="font-size:12px;color:#4A6070;margin-top:14px;text-align:center;font-style:italic">Illustrative — your scores will differ</div>
    </div>
  </div>
</section>

<!-- WHAT IT COVERS -->
<section class="covers" id="checklist">
  <div class="wrap">
    <div class="sec-label">10 diagnostic areas</div>
    <h2>Where reporting trust breaks down — and how to measure it.</h2>
    <p class="intro">Rate each area from 1 (not in place) to 10 (fully in place), then run your assessment. You will get a scored read-out that interprets every area and the patterns between them - a genuine diagnostic, generated in your browser. Nothing you enter is sent anywhere.</p>
    <div class="area-grid">
      <div class="area-card" data-area="kpi">
        <div class="area-n">01</div>
        <div class="area-body">
          <h3>KPI Definitions</h3>
          <p>Are your key metrics defined in writing? Do Finance and Operations use the same definition for "revenue," "active customer," and "churn"? Does every KPI have a formula and an owner?</p>
          <div class="sample">Signal question: "If I asked three people what our 'monthly active users' means, would I get the same answer?"</div>
        </div>
        <div class="area-rate">
          <label class="ar-rate-label" for="rng-kpi">How in-place is this today? <span><span class="ar-val" data-val>5</span><span class="ar-out">/10</span></span></label>
          <input class="ar-slider" type="range" id="rng-kpi" min="1" max="10" step="1" value="5" data-area="kpi" aria-label="KPI Definitions score, 1 to 10" />
          <div class="ar-scale"><span>Undefined</span><span>Defined &amp; owned</span></div>
        </div>
      </div>
      <div class="area-card" data-area="source">
        <div class="area-n">02</div>
        <div class="area-body">
          <h3>Data Source Clarity</h3>
          <p>Do people know which system is the authoritative source for each critical metric? Is there a documented source-of-truth for customer data, financial data, operational data?</p>
          <div class="sample">Signal question: "When Finance and Sales disagree on pipeline, which system wins — and does everyone accept that?"</div>
        </div>
        <div class="area-rate">
          <label class="ar-rate-label" for="rng-source">How in-place is this today? <span><span class="ar-val" data-val>5</span><span class="ar-out">/10</span></span></label>
          <input class="ar-slider" type="range" id="rng-source" min="1" max="10" step="1" value="5" data-area="source" aria-label="Data Source Clarity score, 1 to 10" />
          <div class="ar-scale"><span>No source of truth</span><span>Single source of truth</span></div>
        </div>
      </div>
      <div class="area-card" data-area="ownership">
        <div class="area-n">03</div>
        <div class="area-body">
          <h3>Report Ownership</h3>
          <p>Does every report have a named owner responsible for its accuracy? Is there a process for updating or retiring reports? Can you identify which reports are "official"?</p>
          <div class="sample">Signal question: "If a number in the weekly operations report is wrong, who is responsible for fixing it?"</div>
        </div>
        <div class="area-rate">
          <label class="ar-rate-label" for="rng-ownership">How in-place is this today? <span><span class="ar-val" data-val>5</span><span class="ar-out">/10</span></span></label>
          <input class="ar-slider" type="range" id="rng-ownership" min="1" max="10" step="1" value="5" data-area="ownership" aria-label="Report Ownership score, 1 to 10" />
          <div class="ar-scale"><span>Nobody owns it</span><span>Clear owners</span></div>
        </div>
      </div>
      <div class="area-card" data-area="usage">
        <div class="area-n">04</div>
        <div class="area-body">
          <h3>Dashboard Usage</h3>
          <p>Are your dashboards actually used to make decisions — or do they exist because someone built them? Can you name which dashboard leadership opens before each key meeting?</p>
          <div class="sample">Signal question: "Show me the last time a leadership decision was explicitly made because of a dashboard."</div>
        </div>
        <div class="area-rate">
          <label class="ar-rate-label" for="rng-usage">How in-place is this today? <span><span class="ar-val" data-val>5</span><span class="ar-out">/10</span></span></label>
          <input class="ar-slider" type="range" id="rng-usage" min="1" max="10" step="1" value="5" data-area="usage" aria-label="Dashboard Usage score, 1 to 10" />
          <div class="ar-scale"><span>Unused</span><span>Drives decisions</span></div>
        </div>
      </div>
      <div class="area-card" data-area="manual">
        <div class="area-n">05</div>
        <div class="area-body">
          <h3>Manual Reporting Effort</h3>
          <p>How much time do analysts spend each week building reports in spreadsheets that could be automated? Is manual reporting growing, shrinking, or stable?</p>
          <div class="sample">Signal question: "How many person-hours per week are spent assembling the Monday morning report pack?"</div>
        </div>
        <div class="area-rate">
          <label class="ar-rate-label" for="rng-manual">How in-place is this today? <span><span class="ar-val" data-val>5</span><span class="ar-out">/10</span></span></label>
          <input class="ar-slider" type="range" id="rng-manual" min="1" max="10" step="1" value="5" data-area="manual" aria-label="Manual Reporting Effort score, 1 to 10" />
          <div class="ar-scale"><span>All manual</span><span>Automated</span></div>
        </div>
      </div>
      <div class="area-card" data-area="quality">
        <div class="area-n">06</div>
        <div class="area-body">
          <h3>Data Quality</h3>
          <p>Are there known data quality problems that affect reports regularly? Is there a process for identifying and resolving data quality issues before they reach leadership?</p>
          <div class="sample">Signal question: "How often does someone catch a data error in a report after it's been distributed?"</div>
        </div>
        <div class="area-rate">
          <label class="ar-rate-label" for="rng-quality">How in-place is this today? <span><span class="ar-val" data-val>5</span><span class="ar-out">/10</span></span></label>
          <input class="ar-slider" type="range" id="rng-quality" min="1" max="10" step="1" value="5" data-area="quality" aria-label="Data Quality score, 1 to 10" />
          <div class="ar-scale"><span>Frequent errors</span><span>Trusted &amp; validated</span></div>
        </div>
      </div>
      <div class="area-card" data-area="governance">
        <div class="area-n">07</div>
        <div class="area-body">
          <h3>Governance</h3>
          <p>Is there a process for requesting new reports or dashboards? Is there a process for changing a KPI definition? Does anyone own the overall reporting operating model?</p>
          <div class="sample">Signal question: "What happens when two teams want the definition of 'on-time delivery' changed in opposite directions?"</div>
        </div>
        <div class="area-rate">
          <label class="ar-rate-label" for="rng-governance">How in-place is this today? <span><span class="ar-val" data-val>5</span><span class="ar-out">/10</span></span></label>
          <input class="ar-slider" type="range" id="rng-governance" min="1" max="10" step="1" value="5" data-area="governance" aria-label="Governance score, 1 to 10" />
          <div class="ar-scale"><span>No process</span><span>Governed</span></div>
        </div>
      </div>
      <div class="area-card" data-area="exec">
        <div class="area-n">08</div>
        <div class="area-body">
          <h3>Executive Decision Alignment</h3>
          <p>Do the reports your team produces match what leadership actually needs to make decisions? Are executives asking for data that doesn't exist in current reports?</p>
          <div class="sample">Signal question: "Does the CEO ever make a decision and then ask for data you don't have readily available?"</div>
        </div>
        <div class="area-rate">
          <label class="ar-rate-label" for="rng-exec">How in-place is this today? <span><span class="ar-val" data-val>5</span><span class="ar-out">/10</span></span></label>
          <input class="ar-slider" type="range" id="rng-exec" min="1" max="10" step="1" value="5" data-area="exec" aria-label="Executive Decision Alignment score, 1 to 10" />
          <div class="ar-scale"><span>Misaligned</span><span>Fully aligned</span></div>
        </div>
      </div>
      <div class="area-card" data-area="duplication">
        <div class="area-n">09</div>
        <div class="area-body">
          <h3>Report Duplication</h3>
          <p>How many reports serve overlapping purposes? Is anyone tracking how many dashboards exist and what each one is for? Could you retire 20% of your reports with no impact?</p>
          <div class="sample">Signal question: "How many different reports show monthly revenue — and do they all show the same number?"</div>
        </div>
        <div class="area-rate">
          <label class="ar-rate-label" for="rng-duplication">How in-place is this today? <span><span class="ar-val" data-val>5</span><span class="ar-out">/10</span></span></label>
          <input class="ar-slider" type="range" id="rng-duplication" min="1" max="10" step="1" value="5" data-area="duplication" aria-label="Report Duplication score, 1 to 10" />
          <div class="ar-scale"><span>Rampant duplication</span><span>Clean &amp; consolidated</span></div>
        </div>
      </div>
      <div class="area-card" data-area="ai">
        <div class="area-n">10</div>
        <div class="area-body">
          <h3>AI &amp; Data Readiness</h3>
          <p>If you wanted to adopt AI tools for analytics or forecasting, is your data foundation reliable enough to trust the outputs? Are your definitions and sources documented well enough to feed a model?</p>
          <div class="sample">Signal question: "If an AI tool asked 'what does a churned customer mean in your data?' — could you give a crisp, consistent answer?"</div>
        </div>
        <div class="area-rate">
          <label class="ar-rate-label" for="rng-ai">How in-place is this today? <span><span class="ar-val" data-val>5</span><span class="ar-out">/10</span></span></label>
          <input class="ar-slider" type="range" id="rng-ai" min="1" max="10" step="1" value="5" data-area="ai" aria-label="AI and Data Readiness score, 1 to 10" />
          <div class="ar-scale"><span>Not ready</span><span>AI-ready</span></div>
        </div>
      </div>
    </div>
    <div class="hc-runrow">
      <button type="button" class="hc-run" id="hc-run">Run my assessment &rarr;</button>
      <button type="button" class="hc-reset" id="hc-reset">Reset answers</button>
      <span class="hc-livehint" id="hc-livehint">Rate all ten areas, then run your full diagnostic.</span>
    </div>
    <div class="hc-report" id="hc-report" aria-live="polite" hidden></div>
    <button type="button" class="hc-jump" id="hc-jump" hidden aria-label="Jump to your results">Your score <strong id="hc-jump-score">--</strong> / 100</button>
  </div>
</section>

<!-- HOW TO USE -->
<section class="how-use">
  <div class="wrap">
    <div class="sec-label">How to use it</div>
    <h2>Three ways to put it to work.</h2>
    <div class="steps">
      <div class="step">
        <div class="sn">01</div>
        <h3>Score it yourself</h3>
        <p>Work through each area with the signal questions. Score 1–10. Areas below 5 are where trust is most at risk. Below 3 means the problem is likely already costing you decisions.</p>
      </div>
      <div class="step">
        <div class="sn">02</div>
        <h3>Score it as a team</h3>
        <p>Have your analytics team, finance lead, and a department head each score the same areas independently. The gaps between scores are often as revealing as the scores themselves.</p>
      </div>
      <div class="step">
        <div class="sn">03</div>
        <h3>Use it to prep for a diagnostic call</h3>
        <p>Bring your scores to the free Reporting Trust Diagnostic call. It makes the conversation significantly more productive — we can focus on the lowest-scoring areas and work out whether a structured assessment would be useful.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<div class="cta">
  <h2>Want help interpreting your score?</h2>
  <p>A free 30-minute diagnostic call — bring your Health Check scores and we'll identify the highest-impact areas together.</p>
  <a href="/diagnostic" class="btn">Book a Reporting Trust Diagnostic →</a>
</div>

<style>
/* HERO */
  .hero { background:var(--navy); padding:72px 0 60px; overflow:hidden; position:relative; }
.hero::after { content:"æ"; position:absolute; right:-2%; top:-18%; font-family:"Abril Fatface",serif; font-size:min(40vw,480px); line-height:1; color:rgba(193,140,93,.07); pointer-events:none; }
.hero-in { max-width:1080px; margin:0 auto; padding:0 32px; position:relative; z-index:2; display:grid; grid-template-columns:1.1fr .9fr; gap:56px; align-items:center; }
@media(max-width:720px) {
  .hero-in { grid-template-columns:1fr; gap:32px; }
}
.hero h1 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(32px,5vw,56px); line-height:1.05; color:#fff; margin-bottom:18px; }
.hero p { font-size:17px; color:#C4BDAE; font-weight:300; line-height:1.6; margin-bottom:24px; max-width:48ch; }
.hero-free { display:inline-block; background:rgba(193,140,93,.15); border:1px solid rgba(193,140,93,.4); color:var(--twine); font-size:13px; font-weight:700; padding:6px 14px; border-radius:4px; margin-bottom:20px; letter-spacing:.04em; }
.btn { display:inline-block; background:var(--twine); color:#fff; font-family:"DM Sans",sans-serif; font-weight:600; padding:14px 26px; border-radius:4px; font-size:15px; transition:transform .18s,background .18s; }
.btn:hover { transform:translateY(-2px); background:var(--sepia); }
/* Score preview card */
  .score-card { background:var(--navy-2); border:1px solid var(--navy-3); border-radius:8px; padding:28px 24px; }
.score-card h3 { font-size:13px; font-weight:700; color:var(--twine); text-transform:uppercase; letter-spacing:.14em; margin-bottom:18px; }
.score-area { margin-bottom:12px; }
.sa-label { display:flex; justify-content:space-between; font-size:13px; margin-bottom:5px; }
.sa-name { color:#C4BDAE; font-weight:400; }
.sa-score { font-weight:700; }
.sa-score.red { color:var(--contessa); }
.sa-score.yellow { color:var(--warn); }
.sa-score.green { color:#7EB09B; }
.sa-bar { height:6px; background:rgba(255,255,255,.08); border-radius:3px; overflow:hidden; }
.sa-fill { height:100%; border-radius:3px; }
.sa-fill.red { background:var(--contessa); }
.sa-fill.yellow { background:var(--warn); }
.sa-fill.green { background:#7EB09B; }
/* WHAT IT COVERS */
  .covers { padding:72px 0; }
.covers h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(26px,3.4vw,40px); color:var(--navy); margin-bottom:14px; }
.covers .intro { font-size:17px; color:var(--slate); font-weight:300; max-width:58ch; margin-bottom:44px; line-height:1.6; }
.area-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
@media(max-width:640px) {
  .area-grid { grid-template-columns:1fr; }
}
.area-card { background:#fff; border:1px solid var(--line); border-radius:6px; padding:20px 18px; display:flex; gap:14px; }
.area-n { font-family:"Abril Fatface",serif; font-size:20px; color:var(--twine); min-width:30px; flex-shrink:0; line-height:1; }
.area-body h3 { font-size:15px; font-weight:700; color:var(--navy); margin-bottom:5px; }
.area-body p { font-size:13.5px; color:var(--muted); line-height:1.5; font-weight:300; }
.area-body .sample { font-size:12.5px; color:var(--muted); font-style:italic; margin-top:6px; line-height:1.45; border-left:2px solid var(--line); padding-left:8px; }
/* HOW TO USE IT */
  .how-use { background:var(--paper-2); border-top:1px solid var(--rule); border-bottom:1px solid var(--rule); padding:64px 0; }
.how-use h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(24px,3.2vw,36px); color:var(--navy); margin-bottom:36px; }
.steps { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
@media(max-width:640px) {
  .steps { grid-template-columns:1fr; }
}
.step { background:#fff; border:1px solid var(--line); border-radius:6px; padding:22px 20px; }
.step .sn { font-family:"Abril Fatface",serif; font-size:32px; color:var(--twine); opacity:.5; line-height:1; margin-bottom:8px; }
.step h3 { font-size:16px; font-weight:700; color:var(--navy); margin-bottom:8px; }
.step p { font-size:14px; color:var(--slate); line-height:1.55; font-weight:300; }
/* CTA */
  .cta { border-top:3px solid var(--twine); background:var(--paper-2); padding:72px 32px; text-align:center; border-bottom:1px solid var(--rule); }
.cta h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(24px,3.4vw,38px); color:var(--navy); margin-bottom:16px; }
.cta p { font-size:17px; color:var(--slate); font-weight:300; max-width:46ch; margin:0 auto 28px; line-height:1.6; }

</style>

<style is:global>
  /* ===== Interactive Health Check ===== */
  .area-rate { margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--line); }
  .ar-rate-label { display: flex; justify-content: space-between; align-items: baseline; font-size: 12.5px; font-weight: 600; color: var(--slate); margin-bottom: 9px; gap: 12px; }
  .ar-val { font-weight: 700; font-size: 14px; color: #5E9A82; }
  .ar-val.red { color: #CE796B; } .ar-val.yellow { color: #C79A3A; } .ar-val.green { color: #5E9A82; }
  .ar-out { color: var(--muted); font-weight: 600; font-size: 12px; }
  .ar-slider { width: 100%; accent-color: var(--twine); cursor: pointer; margin: 0; height: 22px; }
  .ar-slider:focus-visible { outline: 2px solid var(--twine); outline-offset: 3px; border-radius: 4px; }
  .ar-scale { display: flex; justify-content: space-between; font-size: 10.5px; color: var(--muted); margin-top: 3px; letter-spacing: .01em; }

  .hc-runrow { margin-top: 40px; display: flex; gap: 18px 22px; align-items: center; flex-wrap: wrap; }
  .hc-run { background: var(--twine); color: #fff; border: none; border-radius: 7px; padding: 15px 30px; font-family: inherit; font-size: 15.5px; font-weight: 600; letter-spacing: .02em; cursor: pointer; box-shadow: 0 8px 22px rgba(193,140,93,.28); transition: background .15s ease, transform .15s ease; }
  .hc-run:hover { background: var(--sepia); transform: translateY(-1px); }
  .hc-reset { background: none; border: none; color: var(--muted); font-family: inherit; font-size: 13px; text-decoration: underline; cursor: pointer; padding: 4px; }
  .hc-reset:hover { color: var(--slate); }
  .hc-livehint { font-size: 13px; color: var(--muted); }

  .hc-jump { position: fixed; right: 20px; bottom: 20px; z-index: 60; background: var(--navy); color: #fff; border: 1px solid rgba(255,255,255,.12); border-radius: 999px; padding: 11px 20px; font-family: inherit; font-size: 13px; font-weight: 600; letter-spacing: .02em; box-shadow: 0 8px 24px rgba(8,17,31,.28); cursor: pointer; transition: transform .15s ease, background .15s ease; }
  .hc-jump:hover { transform: translateY(-2px); background: var(--navy-3); }
  .hc-jump strong { color: var(--twine); font-size: 15px; margin: 0 2px; }

  /* report */
  .hc-report { margin-top: 30px; scroll-margin-top: 84px; }
  .hc-report.show { animation: repIn .5s ease; }
  @keyframes repIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
  .sev-critical { --acc: #CE796B; } .sev-warning { --acc: #C79A3A; } .sev-insight { --acc: #C18C5D; } .sev-positive { --acc: #5E9A82; }

  .rep-scorecard { display: flex; gap: 30px; align-items: center; flex-wrap: wrap; background: #fff; border: 1px solid var(--line); border-top: 3px solid var(--twine); border-radius: 12px; padding: 28px 32px; box-shadow: 0 12px 34px rgba(15,31,56,.07); }
  .rep-gauge { position: relative; width: 134px; height: 134px; flex-shrink: 0; }
  .rep-gauge svg { transform: rotate(-90deg); display: block; }
  .rep-gauge-num { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .rep-gauge-score { font-family: 'Abril Fatface', Georgia, serif; font-size: 42px; line-height: 1; color: var(--navy); }
  .rep-gauge-max { font-size: 11px; color: var(--muted); margin-top: 3px; letter-spacing: .04em; }
  .rep-headline { flex: 1; min-width: 240px; }
  .rep-band-name { font-family: 'Abril Fatface', Georgia, serif; font-size: 30px; color: var(--navy); line-height: 1.05; margin-bottom: 9px; }
  .rep-band-blurb { font-size: 14.5px; color: var(--slate); line-height: 1.55; }

  .rep-diagnosis { margin-top: 24px; background: #fff; border: 1px solid var(--line); border-left: 4px solid var(--acc); border-radius: 10px; padding: 24px 26px; }
  .rep-diag-kicker { font-size: 10.5px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: var(--acc); margin-bottom: 10px; }
  .rep-diag-title { font-family: 'Abril Fatface', Georgia, serif; font-size: 23px; color: var(--navy); line-height: 1.15; margin-bottom: 10px; }
  .rep-diag-body { font-size: 15px; color: var(--slate); line-height: 1.62; }

  .rep-section-label { font-size: 11px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--slate); margin: 32px 0 14px; }
  .rep-patterns { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .rep-pattern { background: #fff; border: 1px solid var(--line); border-top: 3px solid var(--acc); border-radius: 9px; padding: 18px 20px; }
  .rep-pat-title { font-weight: 700; font-size: 15px; color: var(--navy); margin-bottom: 7px; line-height: 1.3; }
  .rep-pat-body { font-size: 13px; color: var(--slate); line-height: 1.55; }

  .rep-areas { border: 1px solid var(--line); border-radius: 10px; overflow: hidden; }
  .rep-area-row { display: grid; grid-template-columns: 190px 50px 1fr; gap: 18px; align-items: center; padding: 14px 18px; border-bottom: 1px solid var(--line); }
  .rep-area-row:last-child { border-bottom: none; }
  .rep-area-meta { display: flex; flex-direction: column; gap: 6px; }
  .rep-area-name { font-weight: 600; font-size: 13.5px; color: var(--navy); }
  .rep-area-bar { height: 4px; background: var(--paper-2); border-radius: 2px; overflow: hidden; }
  .rep-area-fill { height: 100%; border-radius: 2px; }
  .rep-area-chip { font-weight: 700; font-size: 12.5px; text-align: center; padding: 3px 0; border-radius: 6px; }
  .rep-area-chip.red { background: #FBEDEA; color: #B5503F; } .rep-area-chip.yellow { background: #FAF1DE; color: #9A7320; } .rep-area-chip.green { background: #E9F2EE; color: #3F7B66; }
  .rep-area-text { font-size: 13px; color: var(--slate); line-height: 1.5; }

  .rep-start { counter-reset: step; list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .rep-start li { display: flex; gap: 14px; align-items: flex-start; padding: 14px 16px; background: var(--paper-2); border-radius: 8px; }
  .rep-start li::before { counter-increment: step; content: counter(step); flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%; background: var(--navy); color: #fff; font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
  .rep-start-name { font-weight: 700; color: var(--navy); font-size: 14px; display: block; margin-bottom: 2px; }
  .rep-start-advice { font-size: 13.5px; color: var(--slate); line-height: 1.5; }

  .rep-cta { margin-top: 32px; background: var(--navy); border-radius: 12px; padding: 30px 32px; }
  .rep-cta-title { font-family: 'Abril Fatface', Georgia, serif; font-size: 23px; color: #fff; line-height: 1.15; margin-bottom: 12px; }
  .rep-cta-body { font-size: 14px; color: #A9B8CC; line-height: 1.62; margin-bottom: 20px; max-width: 62ch; }
  .rep-cta-actions { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }
  .rep-print { background: transparent; border: 1px solid rgba(255,255,255,.3); color: #D6DDE8; border-radius: 6px; padding: 12px 18px; font-family: inherit; font-size: 13px; font-weight: 600; cursor: pointer; transition: border-color .15s ease, color .15s ease; }
  .rep-print:hover { border-color: #fff; color: #fff; }
  .rep-cta .btn { display: inline-block; background: var(--twine); color: #fff; font-family: inherit; font-weight: 600; padding: 14px 26px; border-radius: 4px; font-size: 15px; text-decoration: none; transition: transform .18s, background .18s; }
  .rep-cta .btn:hover { transform: translateY(-2px); background: var(--sepia); }

  @media (max-width: 720px) {
    .rep-patterns { grid-template-columns: 1fr; }
    .rep-area-row { grid-template-columns: 1fr auto; gap: 8px 14px; }
    .rep-area-text { grid-column: 1 / -1; }
  }
  @media (max-width: 600px) {
    .rep-scorecard { padding: 22px 20px; gap: 20px; }
    .rep-gauge { width: 112px; height: 112px; }
    .rep-diagnosis, .rep-cta { padding: 22px 20px; }
    .hc-jump { right: 14px; bottom: 14px; padding: 9px 16px; font-size: 12px; }
  }
  @media print {
    .hc-jump, .hc-runrow, .area-rate, .hc-livehint { display: none !important; }
    .hc-report { margin-top: 0; }
    .rep-pattern, .rep-diagnosis, .rep-cta, .rep-scorecard { break-inside: avoid; }
    .rep-cta { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }

  /* slider sits full-width beneath the card text */
  .area-card { flex-wrap: wrap; }
  .area-body { flex: 1 1 auto; min-width: 0; }
  .area-rate { flex-basis: 100%; }
</style>

<script>
  (function () {
    var DATA = {"areas":[{"key":"kpi","name":"KPI Definitions","lowA":"Undefined","highA":"Defined & owned","low":"Core metrics live in people's heads, so 'revenue' and 'active customer' mean different things to different teams.","mid":"The important metrics are defined, but coverage is patchy and not all of it is written down.","high":"Your key metrics carry written definitions, formulas, and owners - the single biggest protector of trust."},{"key":"source","name":"Data Source Clarity","lowA":"No source of truth","highA":"Single source of truth","low":"There is no agreed source of truth, so the same metric pulled from two systems gives two answers.","mid":"Sources are mostly known but undocumented, so reconciliation still eats time when systems disagree.","high":"Each critical metric has one authoritative source people accept, so disputes resolve fast."},{"key":"ownership","name":"Report Ownership","lowA":"Nobody owns it","highA":"Clear owners","low":"Reports exist with no one accountable for accuracy, so errors persist and trust quietly leaks.","mid":"Some reports have owners, but the line between official and someone's spreadsheet is blurry.","high":"Every official report has a named owner and a clear path to fix or retire it."},{"key":"usage","name":"Dashboard Usage","lowA":"Unused","highA":"Drives decisions","low":"Dashboards exist because they were built, not because anyone opens them to decide.","mid":"A few dashboards get used; the rest are decoration you are still paying to maintain.","high":"Leadership opens specific dashboards to make decisions - reporting that actually changes behavior."},{"key":"manual","name":"Manual Reporting Effort","lowA":"All manual","highA":"Automated","low":"Analysts burn real hours each week hand-assembling reports - expensive, error-prone, and the fastest ROI.","mid":"Some reporting is automated, but a stubborn manual core keeps the Monday-morning scramble alive.","high":"Reporting runs largely on rails, so analysts spend their time on analysis, not assembly."},{"key":"quality","name":"Data Quality","lowA":"Frequent errors","highA":"Trusted & validated","low":"Errors regularly reach leadership before anyone catches them, and each one costs hard-won trust.","mid":"Quality is decent but reactive - issues get caught after distribution, not stopped at the source.","high":"Validation happens before numbers reach leadership, so errors are rare and caught early."},{"key":"governance","name":"Governance","lowA":"No process","highA":"Governed","low":"No process for requesting reports or changing a KPI, and no owner - so definitions drift and change is chaotic.","mid":"A process exists but it is informal, and it strains the moment two teams want opposite changes.","high":"A lightweight intake and change process with a clear owner keeps everything else from decaying."},{"key":"exec","name":"Executive Decision Alignment","lowA":"Misaligned","highA":"Fully aligned","low":"The reports produced do not match what leadership needs, so execs keep asking for data that does not exist.","mid":"Reporting partially serves decisions, but there are visible gaps between what is built and what is used.","high":"Reports map cleanly to the decisions leadership actually makes."},{"key":"duplication","name":"Report Duplication","lowA":"Rampant duplication","highA":"Clean & consolidated","low":"Reports overlap and contradict - several 'monthly revenue' numbers float around and nobody is sure which is right.","mid":"Some consolidation has happened, but redundant reports still multiply faster than they are retired.","high":"Your report inventory is lean and intentional, with little overlap or contradiction."},{"key":"ai","name":"AI & Data Readiness","lowA":"Not ready","highA":"AI-ready","low":"Definitions and sources are not documented enough to trust AI - a model would inherit and amplify the ambiguity.","mid":"The foundation is partway there: enough to experiment, not enough to rely on.","high":"Clean definitions and sources give you a foundation AI can actually build on."}],"patterns":{"systemic":{"priority":100,"severity":"critical","title":"This is systemic, not a single broken report","body":"Your scores are low across definitions, ownership, and process at the same time. Piecemeal fixes will not hold here - this is the situation a structured reset is built for: triage what is broken, reconcile the numbers, and stand up an operating model that keeps them trustworthy."},"foundation":{"priority":95,"severity":"critical","title":"Your foundation is the root cause","body":"Both what your metrics mean and where they come from are unsettled. When that is true, every number downstream is contestable - and most of your other low scores are probably symptoms of this one. Fix definitions and sources first and several areas improve on their own."},"conflicting":{"priority":88,"severity":"critical","title":"You almost certainly have contradicting numbers in meetings","body":"Overlapping reports plus no agreed source of truth is the exact recipe for 'Finance says one number, Sales says another.' Name one authoritative source per metric and consolidate the duplicate reports feeding the confusion."},"exec_blind":{"priority":82,"severity":"warning","title":"Leadership is deciding without the reporting","body":"If executives are not served and dashboards are not opened, decisions are running on gut or private spreadsheets no matter what has been built. The fix is aligning reports to real decisions, not building more dashboards."},"accountability":{"priority":85,"severity":"warning","title":"Nothing is holding the line","body":"With no owners and no change process, even correct reports drift out of date and errors survive because catching them is nobody's job. Assigning owners and a lightweight change process is the cheapest high-impact move on this list."},"manual_errors":{"priority":80,"severity":"warning","title":"Your manual effort is producing your errors","body":"Heavy hand-assembly and frequent quality issues usually share a root cause. Automating your highest-effort report with validation built in tends to fix both the hours and the errors at once."},"build_abandon":{"priority":75,"severity":"warning","title":"You have a dashboard factory, not a reporting system","body":"Lots of overlapping dashboards that rarely get opened means effort is going into artifacts instead of decisions. Audit what is actually used, rebuild the few that matter, and retire the rest."},"premature_ai":{"priority":65,"severity":"warning","title":"AI would amplify what is broken","body":"With definitions or sources still shaky, adopting AI now means automating ambiguity at scale. Document the foundation first and AI becomes leverage instead of a risk multiplier."},"fragile":{"priority":60,"severity":"insight","title":"Strong data, no seatbelt","body":"Your definitions and sources are solid, but with little governance to protect them they will decay as you grow or as key people move on - the classic single-analyst risk. Locking in the process now is cheap insurance."},"last_mile":{"priority":58,"severity":"insight","title":"Trustworthy data that is not reaching decisions","body":"Your data is reliable; the gap is the last mile. Do not pour more into data quality - invest in delivery and in aligning reports to the decisions leaders actually make."},"governance_ahead":{"priority":45,"severity":"insight","title":"Process running ahead of the fundamentals","body":"You have governance, but it is protecting definitions and sources that are not settled yet. Process cannot substitute for a clear metric dictionary - shore up the fundamentals so governance has something solid to hold."},"weak_link":{"priority":50,"severity":"insight","title":"One weak link is dragging a strong system down","body":"Most areas are solid, but a single area is the outlier pulling overall trust down. A targeted fix there gives an outsized return - you do not need a broad overhaul."},"healthy":{"priority":40,"severity":"positive","title":"A mature reporting operating model","body":"The fundamentals are in place. The work now is keeping governance scaled as you grow and revisiting this assessment each quarter to catch drift before it spreads."}},"fallback":{"severity":"insight","title":"Functional, but inconsistent","body":"Your scores cluster in the middle - reporting works, but unevenly, and that inconsistency is what erodes confidence over time. The fastest gains are in your two or three lowest areas below."},"bands":[{"min":10,"max":30,"key":"critical","label":"Critical","blurb":"Decisions are likely being made on numbers nobody fully trusts. The patterns below show where the breakage starts."},{"min":31,"max":55,"key":"concern","label":"Concern","blurb":"Real gaps in definitions, ownership, or governance are creating friction that compounds as you grow."},{"min":56,"max":75,"key":"stable","label":"Stable","blurb":"Reporting works at a basic level. Targeted fixes in your lowest areas would raise trust and decision speed."},{"min":76,"max":100,"key":"strong","label":"Strong","blurb":"A well-governed, trusted reporting operation. Focus shifts to keeping it scaled and catching drift early."}],"advice":{"kpi":"Write formal definitions for your top 10 to 15 metrics, each with a formula and a named owner.","source":"Designate one authoritative source per critical metric and document it where people can find it.","ownership":"Give every official report a single named owner, and retire the ones nobody owns.","usage":"Audit which dashboards actually get opened, then cut or rebuild the ones that do not drive decisions.","manual":"Measure the weekly hours spent assembling reports, then automate the highest-effort one first.","quality":"Add validation checks at the source and a triage path before numbers reach leadership.","governance":"Stand up a lightweight intake and change process, and name an owner for the reporting model.","exec":"Map each leadership decision to the report that should support it, then close the gaps.","duplication":"Inventory every report and consolidate or retire the ones that overlap.","ai":"Document definitions and sources first - AI inherits whatever ambiguity you feed it."},"cta":{"title":"This is the self-check. The Assessment is the roadmap.","body":"Everything above is read from ten sliders. A Reporting Clarity Assessment is the same diagnosis done properly - we interview your team, trace the actual numbers, and hand you a prioritized, fixed-fee plan to close these exact gaps. You can act on the pointers above yourself, or we can do it with you."}};
    var KEYS = DATA.areas.map(function (a) { return a.key; });
    var sliders = Array.prototype.slice.call(document.querySelectorAll('.ar-slider'));
    if (!sliders.length) return;
    var runBtn = document.getElementById('hc-run');
    var resetBtn = document.getElementById('hc-reset');
    var report = document.getElementById('hc-report');
    var jump = document.getElementById('hc-jump');
    var jumpScore = document.getElementById('hc-jump-score');
    var hint = document.getElementById('hc-livehint');
