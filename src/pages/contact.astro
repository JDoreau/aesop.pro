---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = 'Contact Aesop Analytics | Book a Free Diagnostic Call'
const description = 'Book a free 30-minute Reporting Trust Diagnostic. No pitch, no pressure - just an honest conversation about your reporting situation and whether there\'s a fit.'
const ogDescription = "A short call to understand your situation. No pitch, no commitment.";
---

<BaseLayout title={title} description={description} path="/contact" ogDescription={ogDescription}>

<div class="contact-wrap">
  <div class="contact-intro">
    <div class="eyebrow">Contact</div>
    <h1>Tell us what your data isn't telling you.</h1>
    <p>Every engagement starts the same way: a short, honest conversation about your situation. No pitch, no slide deck. If there's a fit, we'll define what a first step looks like. If there isn't, we'll tell you that too — and point you somewhere better.</p>
    <p><strong>Response time:</strong> typically within one business day.</p>
    <div class="channels">
      <a href="mailto:hello@aesopanalytics.com" class="channel">
        <div class="ch-icon">@</div>
        <div class="ch-body">
          <div class="ch-label">Email</div>
          <div class="ch-value">hello@aesopanalytics.com</div>
          <div class="ch-sub">Best for initial outreach and detailed questions</div>
        </div>
        <span class="ch-arrow">→</span>
      </a>
      <a href="https://www.linkedin.com/company/90403604" target="_blank" rel="noopener" class="channel">
        <div class="ch-icon" style="font-family:'DM Sans',sans-serif;font-weight:700;font-size:13px;">in</div>
        <div class="ch-body">
          <div class="ch-label">LinkedIn</div>
          <div class="ch-value">Aesop Analytics</div>
          <div class="ch-sub">Follow the company page</div>
        </div>
        <span class="ch-arrow">→</span>
      </a>
    </div>
  </div>

  <div class="expectations">
    <h2>What to expect.</h2>
    <div class="exp-list">
      <div class="exp-item">
        <span class="en">01</span>
        <span class="et"><strong>Send a short message.</strong> You don't need to have it all figured out — a paragraph about your situation and what's not working is plenty. "Our reporting is a mess and nobody trusts the numbers" is a perfectly good starting point.</span>
      </div>
      <div class="exp-item">
        <span class="en">02</span>
        <span class="et"><strong>We'll schedule a 30-minute call.</strong> No agenda, no presentation. We'll ask questions about your data environment, your team, and what you're trying to accomplish. You'll ask whatever you need to ask.</span>
      </div>
      <div class="exp-item">
        <span class="en">03</span>
        <span class="et"><strong>Honest next steps.</strong> If there's a clear fit, we'll propose a scoped discovery engagement. If not, we'll tell you why and suggest alternatives. Either way you'll leave the call with something useful.</span>
      </div>
      <div class="exp-item">
        <span class="en">04</span>
        <span class="et"><strong>No pressure, no follow-up campaign.</strong> If you reach out and decide not to move forward, that's fine. One follow-up if we haven't heard back; after that the ball is in your court.</span>
      </div>
    </div>
  </div>

  <div class="contact-form-wrap">
    <div class="eyebrow">Send a message</div>
    <h2>Tell us what's going on.</h2>
    <p class="cf-sub">A paragraph about your situation is plenty. We respond within one business day.</p>

    <form id="contact-form" action="https://formspree.io/f/mojzdqlk" method="POST">
      <div class="cf-row cf-row-2">
        <div class="cf-field">
          <label for="cf-name">Your name</label>
          <input type="text" id="cf-name" name="name" autocomplete="name" required placeholder="Jane Smith" />
        </div>
        <div class="cf-field">
          <label for="cf-email">Work email</label>
          <input type="email" id="cf-email" name="email" autocomplete="email" required placeholder="jane@company.com" />
        </div>
      </div>
      <div class="cf-row cf-row-2">
        <div class="cf-field">
          <label for="cf-company">Company & role <span class="cf-opt">(optional)</span></label>
          <input type="text" id="cf-company" name="company" placeholder="e.g. Acme Inc — VP of Operations" />
        </div>
        <div class="cf-field">
          <label for="cf-website">Company website <span class="cf-opt">(optional)</span></label>
          <input type="text" id="cf-website" name="website" inputmode="url" autocomplete="url" placeholder="acme.com" />
        </div>
      </div>
      <div class="cf-field">
        <label for="cf-msg">What's not working?</label>
        <textarea id="cf-msg" name="message" rows="5" required placeholder="Our dashboards show different numbers depending on who pulls the report, and leadership has stopped trusting them..."></textarea>
      </div>
      <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
      <input type="hidden" name="_subject" value="New message via aesopanalytics.com" />
      <input type="hidden" name="_next" value="https://aesopanalytics.com/thanks" />
      <button type="submit" class="cf-btn" id="cf-submit">Send message</button>
      <div id="cf-status" class="cf-msg" role="status" aria-live="polite"></div>
      </form>
  </div>
</div>

<!-- GOOD FIT / LESS FIT -->
<div class="fit-section">
  <h2 class="fs-label">Is Aesop the right fit?</h2>
  <div class="fit-grid">
    <div class="fit-box good-box">
      <div class="fit-head good">Good fit</div>
      <div class="fit-item">Small to mid-sized companies or nonprofits (10–500 people) that have outgrown spreadsheets</div>
      <div class="fit-item">Organizations where a business owner is committed to seeing a project through</div>
      <div class="fit-item">Teams that want to understand and own their reporting, not just receive it</div>
      <div class="fit-item">Situations where the problem is clear but the solution isn't — yet</div>
      <div class="fit-item">Organizations already using Power BI, Tableau, or Snowflake (or evaluating them)</div>
    </div>
    <div class="fit-box less-box">
      <div class="fit-head less">Less ideal fit</div>
      <div class="fit-item">Large enterprises needing a team of 10+ consultants — that's not what this is</div>
      <div class="fit-item">Projects requiring significant custom software engineering (not BI/reporting work)</div>
      <div class="fit-item">Engagements where there's no internal owner accountable for adoption</div>
      <div class="fit-item">Organizations that have decided on a solution before understanding the problem</div>
    </div>
  </div>
</div>

<style>
/* PAGE */
  .contact-wrap { max-width:1080px; margin:0 auto; padding:80px 32px; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start; }
@media(max-width:760px) {
  .contact-wrap { grid-template-columns:1fr; gap:48px; padding:56px 28px; }
}
/* LEFT: intro */
.contact-intro h1 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(34px,5vw,56px); line-height:1.06; color:var(--navy); margin-bottom:24px; }
.contact-intro p { font-size:17.5px; color:var(--slate); line-height:1.65; font-weight:300; margin-bottom:20px; }
.contact-intro strong { color:var(--navy); font-weight:700; }
/* Channels */
  .channels { margin-top:36px; display:flex; flex-direction:column; gap:14px; }
.channel { display:flex; gap:16px; align-items:center; padding:18px 20px; background:#fff; border:1px solid var(--line); border-radius:6px; text-decoration:none; transition:border-color .18s,box-shadow .18s; }
.channel:hover { border-color:var(--navy); box-shadow:0 6px 20px -10px rgba(15,31,56,.18); }
.channel .ch-icon { width:40px; height:40px; background:var(--navy); border-radius:6px; display:flex; align-items:center; justify-content:center; font-family:"Abril Fatface",serif; font-size:18px; color:var(--twine); flex-shrink:0; }
.channel .ch-body { flex:1; }
.channel .ch-label { font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:.12em; color:var(--muted); margin-bottom:3px; }
.channel .ch-value { font-size:16px; font-weight:600; color:var(--navy); }
.channel .ch-sub { font-size:13px; color:var(--muted); font-weight:300; margin-top:2px; }
.channel .ch-arrow { color:var(--twine); font-size:18px; font-weight:700; }
/* RIGHT: expectations */
  .expectations { background:var(--navy); border-radius:8px; padding:40px 36px; color:var(--cream); position:relative; overflow:hidden; }
.expectations::after { content:"æ"; position:absolute; right:-16px; bottom:-44px; font-family:"Abril Fatface",serif; font-size:160px; color:rgba(193,140,93,.1); line-height:1; pointer-events:none; }
.expectations h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:22px; color:#fff; margin-bottom:24px; position:relative; z-index:1; }
.exp-list { display:flex; flex-direction:column; gap:20px; position:relative; z-index:1; }
.exp-item { display:flex; gap:14px; align-items:flex-start; }
.exp-item .en { font-family:"Abril Fatface",serif; font-size:20px; color:var(--twine); min-width:28px; line-height:1.1; flex-shrink:0; }
.exp-item .et { font-size:15.5px; color:#C4BDAE; line-height:1.55; font-weight:300; }
.exp-item .et strong { color:#fff; font-weight:600; }
/* Good fit section */
  .fit-section { max-width:1080px; margin:0 auto; padding:0 32px 80px; }
.fit-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
@media(max-width:660px) {
  .fit-grid { grid-template-columns:1fr; }
}
.fit-head { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.22em; margin-bottom:24px; }
.fit-head.good { color:var(--navy); }
.fit-head.less { color:var(--contessa); }
.fit-section > .fs-label { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(24px,3.2vw,34px); color:var(--navy); margin-bottom:32px; }
.fit-box { background:#fff; border:1px solid var(--line); border-radius:6px; padding:22px; }
.fit-box.good-box { border-top:3px solid var(--navy); }
.fit-box.less-box { border-top:3px solid rgba(206,118,107,.4); }
.fit-item { display:flex; gap:12px; align-items:flex-start; font-size:15.5px; color:var(--slate); padding:10px 0; border-bottom:1px solid var(--line); line-height:1.5; font-weight:300; }
.fit-item:last-child { border-bottom:none; }
.fit-item::before { font-weight:700; flex-shrink:0; margin-top:1px; }
.fit-box.good-box .fit-item::before { content:"✓"; color:var(--navy); }
.fit-box.less-box .fit-item::before { content:"→"; color:var(--contessa); }

/* CONTACT FORM */
  .contact-form-wrap { padding:52px 0 0; }
  .contact-form-wrap .eyebrow { margin-bottom:12px; }
  .contact-form-wrap h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:clamp(22px,3vw,32px); color:var(--navy); margin-bottom:8px; letter-spacing:-.01em; }
  .cf-sub { font-size:15.5px; color:var(--slate); margin-bottom:28px; }
  .cf-row-2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  @media(max-width:600px){ .cf-row-2 { grid-template-columns:1fr; } }
  .cf-field { margin-bottom:16px; }
  .cf-field label { display:block; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.14em; color:var(--slate); margin-bottom:7px; }
  .cf-opt { font-weight:400; text-transform:none; letter-spacing:0; color:var(--muted); font-size:11px; }
  .cf-field input, .cf-field textarea { width:100%; padding:13px 15px; border:1.5px solid var(--line); border-radius:5px; background:#fff; color:var(--ink); font-family:"DM Sans",sans-serif; font-size:15px; transition:border-color .18s; resize:vertical; }
  .cf-field input::placeholder, .cf-field textarea::placeholder { color:var(--muted); }
  .cf-field input:focus, .cf-field textarea:focus { outline:none; border-color:var(--twine); }
  .cf-btn { display:inline-block; background:var(--navy); color:#fff; font-family:"DM Sans",sans-serif; font-weight:600; font-size:15px; padding:14px 28px; border-radius:4px; border:none; cursor:pointer; transition:background .18s, transform .15s; margin-top:4px; }
  .cf-btn:hover { background:var(--navy-3); transform:translateY(-2px); }
  .cf-btn:disabled { opacity:.6; cursor:default; transform:none; }
  .cf-msg { display:none; margin-top:18px; padding:16px 18px; border-radius:5px; font-size:14.5px; line-height:1.55; }
  .cf-msg.show { display:block; }
  .cf-ok { background:rgba(193,140,93,.1); border:1px solid rgba(193,140,93,.35); color:var(--sepia); }
  .cf-err { background:rgba(206,118,107,.1); border:1px solid rgba(206,118,107,.35); color:var(--apple); }
</style>



<script>
  const form = document.getElementById('contact-form');
  const btn = document.getElementById('cf-submit');
  const statusEl = document.getElementById('cf-status');
  if (form && btn && statusEl) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Sending...';
      statusEl.className = 'cf-msg';
      statusEl.textContent = '';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.reset();
          statusEl.className = 'cf-msg cf-ok show';
          statusEl.textContent = 'Thanks - your message is in. We will be in touch within one business day.';
          btn.textContent = 'Message sent';
          if (typeof window.gtag === 'function') {
            window.gtag('event', 'generate_lead', { event_category: 'conversion', event_label: 'Contact form submitted' });
          }
        } else {
          let msg = 'Something went wrong. Please email hello@aesopanalytics.com.';
          try {
            const data = await res.json();
            if (data && data.errors && data.errors.length) {
              msg = data.errors.map((x) => x.message).join(', ');
            }
          } catch (err) {}
          statusEl.className = 'cf-msg cf-err show';
          statusEl.textContent = msg;
          btn.disabled = false;
          btn.textContent = original;
        }
      } catch (err) {
        statusEl.className = 'cf-msg cf-err show';
        statusEl.textContent = 'Network error. Please email hello@aesopanalytics.com.';
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  }
</script>
</BaseLayout>
