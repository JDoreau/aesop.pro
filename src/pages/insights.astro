---
import BaseLayout from "../layouts/BaseLayout.astro";
import { hero, pillarButtons, featured, sections, sidebarPillars } from "../data/insights.ts";
import type { Section } from "../data/insights.ts";
const title = 'Insights: Reporting Trust, KPIs & Dashboards | Aesop'
const description = 'Articles and field studies on reporting trust, KPI governance, dashboard design, and data strategy — for COOs, CFOs, and analytics leaders.'
const ogDescription = "Expert articles on reporting modernization, KPI trust, and data governance. Every dataset has a moral.";
// Count label derived from the rows, so it can never drift from the articles present.
const countLabel = (s: Section) => {
  const n = s.rows.length;
  const noun = s.pillar === 'field-study' ? 'study' : 'article';
  const plural = s.pillar === 'field-study' ? 'studies' : 'articles';
  return n + ' ' + (n === 1 ? noun : plural);
};
---

<BaseLayout title={title} description={description} path="/insights" ogDescription={ogDescription}>

<div class="page-hero">
  <div class="page-hero-in">
    <div class="eyebrow">{hero.eyebrow}</div>
    <h1>{hero.title}</h1>
    <p>{hero.intro}</p>
  </div>
</div>

<div class="pillars">
  <div class="pillar-in">
    <span class="pillar-label">Pillar:</span>
    {pillarButtons.map((p) => (
      <button class="pillar-btn" class:list={[{ on: p.cat === "all" }]} data-cat={p.cat}>{p.label}</button>
    ))}
  </div>
</div>

<div class="content">
  <div id="article-list">

    <a href={`/insights/${featured.slug}`} class="feat-card" data-cat={featured.cat}>
      <div class="ftxt">
        <div class="ftag">{featured.tag}</div>
        <h2>{featured.title}</h2>
        <p>{featured.desc}</p>
        <span class="fread">{featured.read}</span>
      </div>
      <div class="fviz">
        <svg viewBox="0 0 220 150" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <line x1="20" y1="130" x2="210" y2="130" stroke="#1E3555" stroke-width="1"/>
          <polyline points="20,120 60,105 100,82 140,55 180,32 210,16" fill="none" stroke="#C18C5D" stroke-width="2.5" stroke-linecap="round"/>
          <polyline points="20,120 60,116 100,108 140,100 180,94 210,90" fill="none" stroke="#6B8FAF" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="210" cy="16" r="3.5" fill="#C18C5D"/>
          <circle cx="210" cy="90" r="3.5" fill="#6B8FAF"/>
        </svg>
      </div>
    </a>

    {sections.map((s) => (
      <div class="pillar-section" data-pillar={s.pillar}>
        <div class="ps-head">{s.heading} <span class="ps-count">{countLabel(s)}</span></div>
        {s.rows.map((r) => (
          <a href={`/insights/${r.slug}`} class="art-row" data-cat={r.cat}>
            <span class="ar-num">æ</span>
            <div class="ar-body">
              <div class="ar-title">{r.title}</div>
              <div class="ar-desc">{r.desc}</div>
            </div>
            <div class="ar-meta"><span class="ar-pill">{r.pill}</span><span class="ar-time">{r.time}</span></div>
          </a>
        ))}
      </div>
    ))}

  </div>

  <aside class="sidebar">
    <div class="sb-block">
      <div class="sb-label">The five content pillars</div>
      <div class="pillar-list">
        {sidebarPillars.map((p) => (
          <div class="pl-item" data-cat={p.cat} role="button" tabindex="0">{p.label} <span class="pl-ct">{p.count}</span></div>
        ))}
      </div>
    </div>
    <div class="sb-block">
      <div class="sb-label">Free resource</div>
      <p>The Reporting Trust Health Check — 10 diagnostic areas, 5 signal questions each. Score your reporting environment in 30 minutes.</p>
      <a href="/resources" class="sb-btn">Take the Health Check →</a>
    </div>
    <div class="sb-block">
      <div class="sb-label">Work together</div>
      <p>If an article raised a question about your own reporting environment, that's usually worth a conversation.</p>
      <a href="/diagnostic" class="sb-btn">Book a free diagnostic →</a>
    </div>
  </aside>
</div>

<style>
/* PAGE HERO */
  .page-hero { background:var(--navy); padding:72px 0 56px; overflow:hidden; position:relative; }
.page-hero::after { content:"æ"; position:absolute; right:-2%; top:-20%; font-family:"Abril Fatface",serif; font-size:min(38vw,460px); line-height:1; color:rgba(193,140,93,.07); pointer-events:none; }
.page-hero-in { max-width:1080px; margin:0 auto; padding:0 32px; position:relative; z-index:2; }
.page-hero h1 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(38px,5.6vw,68px); line-height:1.04; color:#fff; margin-bottom:18px; }
.page-hero p { font-size:18px; color:#C4BDAE; font-weight:300; max-width:54ch; line-height:1.6; }
/* PILLAR TABS */
  .pillars { background:var(--paper-2); border-bottom:1px solid var(--rule); padding:16px 0; position:sticky; top:64px; z-index:10; }
.pillar-in { max-width:1080px; margin:0 auto; padding:0 32px; display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
.pillar-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.18em; color:var(--muted); margin-right:4px; white-space:nowrap; }
.pillar-btn { font-size:12px; font-weight:600; letter-spacing:.03em; padding:6px 13px; border-radius:20px; border:1px solid var(--rule); background:transparent; color:var(--muted); cursor:pointer; transition:all .15s; font-family:"DM Sans",sans-serif; white-space:nowrap; }
.pillar-btn:hover, .pillar-btn.on { background:var(--navy); color:#fff; border-color:var(--navy); }
/* MAIN LAYOUT */
  .content { max-width:1080px; margin:0 auto; padding:52px 32px 80px; display:grid; grid-template-columns:1fr 300px; gap:56px; align-items:start; }
@media(max-width:860px) {
  .content { grid-template-columns:1fr; }
  .sidebar { display:none; }
}
/* FEATURED */
  .feat-card { background:var(--navy); border-radius:8px; overflow:hidden; display:grid; grid-template-columns:1.1fr .9fr; margin-bottom:48px; text-decoration:none; }
@media(max-width:600px) {
  .feat-card { grid-template-columns:1fr; }
}
.feat-card .ftxt { padding:34px 30px; }
.feat-card .ftag { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.2em; color:var(--twine); margin-bottom:12px; }
.feat-card h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:22px; line-height:1.15; color:#fff; margin-bottom:12px; }
.feat-card p { font-size:14.5px; color:#B8BDCA; line-height:1.6; font-weight:300; margin-bottom:18px; }
.feat-card .fread { font-size:12.5px; font-weight:700; color:var(--twine); text-transform:uppercase; letter-spacing:.06em; }
.feat-card .fviz { background:var(--navy-2); display:flex; align-items:center; justify-content:center; padding:24px; min-height:180px; }
.feat-card .fviz svg { width:100%; max-width:220px; height:auto; }
/* PILLAR SECTIONS */
  .pillar-section { margin-bottom:44px; }
.ps-head { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.22em; color:var(--twine); padding:12px 0; border-bottom:2px solid var(--navy); margin-bottom:0; display:flex; align-items:center; justify-content:space-between; }
.ps-count { font-size:11px; font-weight:400; color:var(--muted); }
/* ARTICLE ROWS */
  .art-row { display:grid; grid-template-columns:28px 1fr auto; gap:16px; align-items:start; padding:20px 6px; border-bottom:1px solid var(--line); text-decoration:none; transition:background .15s; border-radius:4px; }
.art-row:hover { background:var(--paper-2); }
.art-row .ar-num { font-family:"Abril Fatface",serif; font-size:17px; color:var(--twine); text-align:center; padding-top:2px; }
.art-row .ar-body { }
.art-row .ar-title { font-size:16.5px; font-weight:700; color:var(--ink); margin-bottom:4px; line-height:1.3; }
.art-row .ar-desc { font-size:13.5px; color:var(--muted); line-height:1.5; font-weight:300; }
.art-row .ar-meta { text-align:right; flex-shrink:0; }
.ar-pill { display:inline-block; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--muted); background:var(--paper-2); padding:3px 8px; border-radius:20px; border:1px solid var(--line); white-space:nowrap; }
.ar-time { display:block; font-size:11px; color:var(--muted); margin-top:4px; }
@media(max-width:560px) {
  .art-row .ar-meta { display:none; }
  .art-row { grid-template-columns:28px 1fr; }
}
/* SIDEBAR */
  .sidebar { position:sticky; top:128px; }
.sb-block { background:#fff; border:1px solid var(--line); border-radius:6px; padding:22px; margin-bottom:16px; }
.sb-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.18em; color:var(--twine); margin-bottom:12px; }
.sb-block p { font-size:14px; color:var(--slate); line-height:1.55; font-weight:300; margin-bottom:12px; }
.sb-btn { display:inline-block; background:var(--navy); color:#fff; font-size:13px; font-weight:600; padding:10px 16px; border-radius:4px; text-decoration:none; transition:background .18s; }
.sb-btn:hover { background:var(--navy-3); }
.pillar-list { display:flex; flex-direction:column; gap:0; }
.pl-item { display:flex; justify-content:space-between; align-items:center; font-size:13.5px; color:var(--slate); padding:8px 0; border-bottom:1px solid var(--line); cursor:pointer; transition:color .15s; }
.pl-item:last-child { border-bottom:none; }
.pl-item:hover { color:var(--navy); }
.pl-ct { font-size:11px; font-weight:700; color:var(--muted); background:var(--paper-2); padding:2px 8px; border-radius:10px; }
/* FOOTER */
  footer { background:var(--navy-foot); color:#6A8099; padding:52px 0; }
</style>

<script>
  function applyFilter(cat) {
    const rows = document.querySelectorAll('.art-row');
    const feat = document.querySelector('.feat-card');
    const groups = document.querySelectorAll('.pillar-section');
    if (cat === 'all') {
      rows.forEach((r) => (r.style.display = ''));
      groups.forEach((g) => (g.style.display = ''));
      if (feat) feat.style.display = '';
      return;
    }
    if (feat) feat.style.display = feat.dataset.cat === cat ? '' : 'none';
    rows.forEach((r) => { r.style.display = r.dataset.cat === cat ? '' : 'none'; });
    groups.forEach((g) => {
      const hasVisible = Array.from(g.querySelectorAll('.art-row')).some((r) => r.dataset.cat === cat);
      g.style.display = hasVisible ? '' : 'none';
    });
  }
  function selectPillar(cat) {
    if (!cat) return;
    document.querySelectorAll('.pillar-btn').forEach((b) => b.classList.toggle('on', b.dataset.cat === cat));
    applyFilter(cat);
  }
  document.querySelectorAll('.pillar-btn').forEach((btn) => {
    btn.addEventListener('click', () => selectPillar(btn.dataset.cat));
  });
  document.querySelectorAll('.pl-item').forEach((item) => {
    item.addEventListener('click', () => selectPillar(item.dataset.cat));
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectPillar(item.dataset.cat); }
    });
  });
</script>

</BaseLayout>
