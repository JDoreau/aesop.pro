---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = 'Reporting Modernization Case Studies | Aesop Analytics'
const description = 'Anonymized reporting-modernization case studies across finance, healthcare, real estate, and nonprofits — with KPI governance and deliverable samples.'
const ogDescription = "Reporting modernization in practice. Anonymized case studies across healthcare, operations, finance, and nonprofit sectors.";

// Article schema for each anonymized case study. Content-only — no Review or
// AggregateRating until client-approved quotes and ratings are visible on-page.
const workSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://aesopanalytics.com/work/#healthcare-research",
    headline: "From spreadsheet chaos to a trusted executive reporting system for an NIH-funded research program",
    description: "How a research organization retired 14 reports, eliminated manual reporting time, and defined 23 KPIs in a governed reporting system.",
    mainEntityOfPage: "https://aesopanalytics.com/work/",
    author: { "@type": "Organization", name: "Aesop Analytics", url: "https://aesopanalytics.com/" },
    publisher: { "@type": "Organization", name: "Aesop Analytics", url: "https://aesopanalytics.com/" },
    about: ["Healthcare / Research", "Reporting modernization", "Data trust", "KPI governance"],
    keywords: ["healthcare reporting modernization", "research reporting", "KPI dictionary", "Power BI dashboards", "funder reporting", "reporting trust"],
    isAccessibleForFree: true,
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://aesopanalytics.com/work/#finance-banking",
    headline: "Rebuilding a fragmented reporting environment after a core banking system migration",
    description: "A finance reporting case study on reducing reconciliation load after a core system migration and defining 31 trusted KPIs.",
    mainEntityOfPage: "https://aesopanalytics.com/work/",
    author: { "@type": "Organization", name: "Aesop Analytics", url: "https://aesopanalytics.com/" },
    publisher: { "@type": "Organization", name: "Aesop Analytics", url: "https://aesopanalytics.com/" },
    about: ["Finance / Banking", "Reporting modernization", "Data trust", "KPI governance"],
    keywords: ["banking reporting modernization", "core banking migration reporting", "Tableau rebuild", "KPI governance", "source of truth", "finance analytics"],
    isAccessibleForFree: true,
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://aesopanalytics.com/work/#real-estate-operations",
    headline: "Standing up an analytics operating model from scratch for a growing property management company",
    description: "How a property management company eliminated manual weekly reporting and aligned occupancy definitions across operations, finance, and leasing.",
    mainEntityOfPage: "https://aesopanalytics.com/work/",
    author: { "@type": "Organization", name: "Aesop Analytics", url: "https://aesopanalytics.com/" },
    publisher: { "@type": "Organization", name: "Aesop Analytics", url: "https://aesopanalytics.com/" },
    about: ["Real Estate Operations", "Reporting modernization", "Data trust", "KPI governance"],
    keywords: ["real estate operations reporting", "property management analytics", "occupancy KPI", "Power BI", "Snowflake", "reporting operating model"],
    isAccessibleForFree: true,
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://aesopanalytics.com/work/#nonprofit-impact",
    headline: "Building a funder-ready impact reporting system for a workforce development nonprofit",
    description: "How a nonprofit cut grant reporting time from about 12 to 4 hours per grant with a unified impact reporting model.",
    mainEntityOfPage: "https://aesopanalytics.com/work/",
    author: { "@type": "Organization", name: "Aesop Analytics", url: "https://aesopanalytics.com/" },
    publisher: { "@type": "Organization", name: "Aesop Analytics", url: "https://aesopanalytics.com/" },
    about: ["Nonprofit / Impact", "Reporting modernization", "Data trust", "KPI governance"],
    keywords: ["nonprofit impact reporting", "funder reporting", "grant reporting", "Salesforce Power BI", "outcome measurement", "nonprofit analytics"],
    isAccessibleForFree: true,
  },
];
---

<BaseLayout title={title} description={description} path="/work" ogDescription={ogDescription} schema={workSchema}>

<!-- HERO -->
<div class="page-hero">
  <div class="page-hero-in">
    <div class="eyebrow">Work &amp; Portfolio</div>
    <h1>What the work actually looks like.</h1>
    <p>Anonymized case studies from reporting modernization, KPI governance, and dashboard rebuilds — across healthcare, operations, finance, and nonprofit sectors.</p>
    <div class="anon-note">
      All client details have been anonymized. Sector, size, problem type, work performed, and result signals are accurate; identifying details are not. These are representative founder-led transformations.
    </div>
  </div>
</div>

<!-- CASE STUDIES -->
<section class="case-studies">
  <div class="wrap">
    <div class="cs-grid">

      <!-- ══════════════════════════════════════════ -->
      <!-- CASE STUDY 1: Healthcare / NIH             -->
      <!-- ══════════════════════════════════════════ -->
      <div class="cs reveal" id="healthcare-research">
        <div class="cs-header">
          <div>
            <div class="cs-sector">Healthcare &amp; Research</div>
            <h2>From spreadsheet chaos to a trusted executive reporting system for an NIH-funded research program</h2>
            <div class="cs-context">~280 employees · Research organization · Washington, D.C. metro</div>
          </div>
          <div class="cs-tags">
            <span class="cs-tag">Reporting Modernization</span>
            <span class="cs-tag">KPI Design</span>
            <span class="cs-tag">Power BI</span>
          </div>
        </div>

        <div class="cs-body">
          <div class="cs-col">
            <h4>The situation</h4>
            <p>A federally-funded research organization running multiple concurrent grant programs had accumulated 40+ recurring reports — most of them manual Excel builds assembled by individual program managers each month. Leadership had no consistent view of program health across grants, and funder reporting required significant manual reconciliation every quarter.</p>
            <p>The core pain: <strong>the same headcount number appeared differently in three different reports</strong>, and nobody could say with authority which was right. Every external funder report required a full reconciliation cycle before submission.</p>
          </div>
          <div class="cs-col">
            <h4>The approach</h4>
            <p>Started with a full reporting inventory across all 40+ reports — documenting what each one was for, who owned it, how much manual time it required, and whether it was actually used to make decisions. Ran structured interviews with seven stakeholders across programs, finance, and executive leadership.</p>
            <p>Identified 14 reports as retirement candidates (unused or duplicated), rebuilt the 8 highest-value reports as governed Power BI dashboards, and built a KPI dictionary covering all 23 program-level metrics. Implemented a formal report request intake process.</p>
          </div>
        </div>

        <div class="outcomes">
          <div class="outcome">
            <div class="oc-n">14</div>
            <div class="oc-l">Reports retired — zero complaints from stakeholders</div>
          </div>
          <div class="outcome">
            <div class="oc-n">~12 hrs</div>
            <div class="oc-l">Manual reporting time eliminated per week across the team</div>
          </div>
          <div class="outcome">
            <div class="oc-n">23</div>
            <div class="oc-l">KPIs formally defined in a governed dictionary with named owners</div>
          </div>
        </div>

