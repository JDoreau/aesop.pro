---
// /resources/trust-letter — The Reporting Trust Letter signup page.
// Migrated from public/resources/trust-letter/index.html (legacy static HTML)
// into the Astro system: BaseLayout supplies head/Seo/GA4/Nav/Footer; this
// page keeps only its own content and styles. Formspree form xgobkdgd is the
// Trust Letter list (distinct from the contact form) — preserve exactly.
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout
  title="The Reporting Trust Letter — Aesop Analytics"
  description="A short letter for people who own the numbers. Practical notes on reporting trust, KPI clarity, dashboard design, and governance — roughly twice a month. No fluff, no pitch, unsubscribe anytime."
  ogTitle="The Reporting Trust Letter — Aesop Analytics"
  ogDescription="Practical notes on reporting trust, KPI definitions, and governed decision systems. Roughly twice a month. Every dataset has a moral."
  path="/resources/trust-letter"
>
  <!-- HERO + SIGNUP -->
  <section class="hero">
    <div class="hero-in">
      <div>
        <div class="eyebrow">The Reporting Trust Letter</div>
        <h1>For the people who <em>own the numbers.</em></h1>
        <p class="lede">A short letter on reporting trust, KPI clarity, dashboard design, and practical governance — written for the operators, analysts, and leaders who actually have to defend the figures in the room. Roughly twice a month.</p>
        <p class="moral">Every dataset has a moral.</p>
      </div>

      <div class="signup-card">
        <h2>Get the letter.</h2>
        <p class="sc-sub">No fluff, no sales sequence. Unsubscribe in one click anytime.</p>

        <form id="trustletter-form" action="https://formspree.io/f/xgobkdgd" method="POST">
          <div class="field">
            <label for="tl-name">First name</label>
            <input type="text" id="tl-name" name="name" placeholder="Jordan" autocomplete="given-name">
          </div>
          <div class="field">
            <label for="tl-email">Work email</label>
            <input type="email" id="tl-email" name="email" placeholder="you@company.com" autocomplete="email" required>
          </div>
          <!-- Tags the submission so it's identifiable in Formspree -->
          <input type="hidden" name="_subject" value="New Reporting Trust Letter subscriber">
          <input type="hidden" name="source" value="Reporting Trust Letter signup">
          <!-- Honeypot anti-spam field; bots fill it, humans don't see it -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true">
          <button type="submit" class="sc-btn" id="tl-submit">Subscribe →</button>
        </form>

        <div class="sc-msg ok" id="tl-ok">
          <span class="ok-h">You're on the list.</span>
          Check your inbox — the next letter will arrive when it's worth sending, not before. Thanks for reading.
        </div>
        <div class="sc-msg err" id="tl-err">
          Something went wrong submitting that. You can also just email <a href="mailto:hello@aesopanalytics.com">hello@aesopanalytics.com</a> and I'll add you manually.
        </div>

        <p class="sc-fine">By subscribing you agree to receive occasional emails from Aesop Analytics. We never share or sell your address. <a href="/contact/">Questions?</a></p>
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section class="what">
    <div class="what-in">
      <div class="sec-label">What's in it</div>
      <h2>Practical notes, not think-pieces.</h2>
      <p class="intro">Each letter is built around one idea you can use — drawn from real reporting environments, common failure patterns, and the field studies we publish. The kind of thing you'd want a sharp colleague to send you.</p>
      <div class="what-grid">
        <div class="what-card">
          <div class="wc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--twine)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>
          </div>
          <h3>The metric breakdown</h3>
          <p>How a specific KPI quietly goes wrong — duplicate definitions, missing owners, the source nobody validated — and the practical fix.</p>
        </div>
        <div class="what-card">
          <div class="wc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--twine)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          </div>
          <h3>The dashboard teardown</h3>
          <p>What makes a report trusted, ignored, or actively misleading — with concrete before-and-after thinking you can apply to your own.</p>
        </div>
        <div class="what-card">
          <div class="wc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--twine)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <h3>The governance angle</h3>
          <p>Lightweight ownership, standards, and cadence that make reporting easier to trust — not the enterprise theater that makes it harder to use.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IT IS / ISN'T -->
  <section class="promise">
    <div class="promise-in">
      <h2>An honest deal.</h2>
      <div class="promise-grid">
        <div class="promise-box is">
          <div class="pb-label">What it is</div>
          <div class="pb-item">One useful idea per letter, drawn from real reporting work</div>
          <div class="pb-item">Roughly twice a month — sent when there's something worth saying</div>
          <div class="pb-item">Plain language, steelmanned both ways, no hype</div>
          <div class="pb-item">First access to new field studies and resources</div>
        </div>
        <div class="promise-box isnt">
          <div class="pb-label">What it isn't</div>
          <div class="pb-item">A drip sequence engineered to sell you something</div>
          <div class="pb-item">A daily or weekly obligation cluttering your inbox</div>
          <div class="pb-item">Recycled buzzwords about unlocking data-driven synergy</div>
          <div class="pb-item">A list your address gets shared or sold from — ever</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER CTA -->
  <section class="foot-cta">
    <h2>Rather skip ahead?</h2>
    <p>If your reporting environment already has you asking hard questions, a free 30-minute diagnostic is the faster path.</p>
    <a href="/diagnostic/" class="btn">Book a Reporting Trust Diagnostic →</a>
  </section>
</BaseLayout>

<style>
  /* HERO + SIGNUP */
  .hero { background:var(--navy); padding:84px 0 80px; overflow:hidden; position:relative; }
  .hero::after { content:"æ"; position:absolute; right:-3%; top:-22%; font-family:"Abril Fatface",serif; font-size:min(46vw,540px); line-height:1; color:rgba(193,140,93,.07); pointer-events:none; }
  .hero-in { max-width:1080px; margin:0 auto; padding:0 32px; position:relative; z-index:2; display:grid; grid-template-columns:1fr .85fr; gap:64px; align-items:center; }
  @media(max-width:820px){ .hero-in { grid-template-columns:1fr; gap:40px; } }
  .eyebrow { font-weight:600; text-transform:uppercase; letter-spacing:.28em; font-size:11.5px; color:var(--twine); margin-bottom:22px; }
  .hero h1 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(36px,5.4vw,62px); line-height:1.03; color:#fff; margin-bottom:22px; }
  .hero h1 em { font-style:italic; color:var(--twine); }
  .hero .lede { font-size:19px; color:#C4BDAE; font-weight:300; line-height:1.62; margin-bottom:26px; max-width:46ch; }
  .hero .moral { font-family:"Abril Fatface",serif; font-size:16px; color:#8A9FB8; font-style:normal; }

  /* SIGNUP CARD */
  .signup-card { background:var(--navy-2); border:1px solid var(--navy-3); border-radius:10px; padding:36px 32px; box-shadow:0 30px 70px -40px rgba(0,0,0,.6); }
  .signup-card h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:23px; color:#fff; margin-bottom:8px; line-height:1.15; }
  .signup-card .sc-sub { font-size:14.5px; color:#8A9FB8; font-weight:300; margin-bottom:24px; line-height:1.5; }
  .field { margin-bottom:14px; }
  .field label { display:block; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.12em; color:#8A9FB8; margin-bottom:7px; }
  .field input { width:100%; padding:13px 15px; border:1px solid var(--navy-3); border-radius:5px; background:rgba(251,250,245,.04); color:#fff; font-family:"DM Sans",sans-serif; font-size:15px; transition:border-color .18s, background .18s; }
  .field input::placeholder { color:#5A6E86; }
  .field input:focus { outline:none; border-color:var(--twine); background:rgba(251,250,245,.07); }
  .sc-btn { width:100%; background:var(--twine); color:#fff; border:none; font-family:"DM Sans",sans-serif; font-weight:700; font-size:15px; letter-spacing:.02em; padding:15px; border-radius:5px; cursor:pointer; transition:background .18s, transform .15s; margin-top:6px; }
  .sc-btn:hover { background:var(--sepia); transform:translateY(-1px); }
  .sc-btn:disabled { opacity:.6; cursor:default; transform:none; }
  .sc-fine { font-size:12px; color:#5A6E86; line-height:1.5; margin-top:14px; text-align:center; }
  .sc-fine a { color:#8A9FB8; text-decoration:underline; text-underline-offset:2px; }
  /* Success / error states */
  .sc-msg { display:none; padding:18px 16px; border-radius:6px; font-size:14.5px; line-height:1.5; }
  .sc-msg.show { display:block; }
  .sc-msg.ok { background:rgba(193,140,93,.14); border:1px solid rgba(193,140,93,.4); color:#E4D2BB; }
  .sc-msg.err { background:rgba(206,118,107,.12); border:1px solid rgba(206,118,107,.4); color:#E6B9B2; }
  .sc-msg .ok-h { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:19px; color:#fff; margin-bottom:6px; display:block; }
  .sc-msg a { color:#E4D2BB; text-decoration:underline; text-underline-offset:2px; }

  /* WHAT YOU GET */
  .what { padding:76px 0; }
  .what-in { max-width:1080px; margin:0 auto; padding:0 32px; }
  .sec-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.22em; color:var(--twine); margin-bottom:16px; text-align:center; }
  .what h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(26px,3.6vw,40px); color:var(--navy); margin-bottom:14px; text-align:center; line-height:1.1; }
  .what .intro { font-size:17px; color:var(--slate); font-weight:300; max-width:54ch; margin:0 auto 48px; text-align:center; line-height:1.6; }
  .what-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
  @media(max-width:760px){ .what-grid { grid-template-columns:1fr; gap:16px; } }
  .what-card { background:#fff; border:1px solid var(--line); border-radius:8px; padding:28px 24px; transition:border-color .18s, box-shadow .18s; }
  .what-card:hover { border-color:var(--navy); box-shadow:0 16px 40px -28px rgba(15,31,56,.25); }
  .what-card .wc-icon { width:44px; height:44px; background:var(--paper-2); border:1px solid var(--rule); border-radius:8px; display:flex; align-items:center; justify-content:center; margin-bottom:18px; }
  .what-card .wc-icon svg { width:22px; height:22px; }
  .what-card h3 { font-size:16.5px; font-weight:700; color:var(--navy); margin-bottom:8px; }
  .what-card p { font-size:14.5px; color:var(--muted); line-height:1.55; font-weight:300; }

  /* WHAT IT IS / ISN'T */
  .promise { background:var(--paper-2); border-top:1px solid var(--rule); border-bottom:1px solid var(--rule); padding:72px 0; }
  .promise-in { max-width:760px; margin:0 auto; padding:0 32px; }
  .promise h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(24px,3.2vw,34px); color:var(--navy); margin-bottom:28px; text-align:center; }
  .promise-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
  @media(max-width:600px){ .promise-grid { grid-template-columns:1fr; } }
  .promise-box { background:#fff; border:1px solid var(--line); border-radius:8px; padding:24px 22px; }
  .promise-box.is { border-top:3px solid var(--navy); }
  .promise-box.isnt { border-top:3px solid rgba(206,118,107,.5); }
  .pb-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.18em; margin-bottom:16px; }
  .promise-box.is .pb-label { color:var(--navy); }
  .promise-box.isnt .pb-label { color:var(--contessa); }
  .pb-item { display:flex; gap:11px; align-items:flex-start; font-size:15px; color:var(--slate); padding:9px 0; line-height:1.5; font-weight:300; }
  .pb-item::before { font-weight:700; flex-shrink:0; margin-top:1px; }
  .promise-box.is .pb-item::before { content:"✓"; color:var(--navy); }
  .promise-box.isnt .pb-item::before { content:"✕"; color:var(--contessa); }

  /* FOOTER CTA */
  .foot-cta { padding:72px 32px; text-align:center; }
  .foot-cta h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(24px,3.4vw,36px); color:var(--navy); margin-bottom:14px; }
  .foot-cta p { font-size:17px; color:var(--slate); font-weight:300; max-width:46ch; margin:0 auto 26px; line-height:1.6; }
  .foot-cta .btn { display:inline-block; background:var(--navy); color:var(--cream); padding:14px 28px; border-radius:5px; font-size:14.5px; font-weight:600; transition:background .2s, transform .15s; }
  .foot-cta .btn:hover { background:var(--navy-3); transform:translateY(-1px); }
</style>

<script>
  // AJAX submit so subscribers stay on-page and see a success state
  const form = document.getElementById('trustletter-form') as HTMLFormElement | null;
  const okMsg = document.getElementById('tl-ok');
  const errMsg = document.getElementById('tl-err');
  const btn = document.getElementById('tl-submit') as HTMLButtonElement | null;
  if (form && okMsg && errMsg && btn) {
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      btn.disabled = true; btn.textContent = 'Subscribing…';
      okMsg.classList.remove('show'); errMsg.classList.remove('show');
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' },
        });
        if (res.ok) {
          form.style.display = 'none';
          okMsg.classList.add('show');
        } else {
          errMsg.classList.add('show');
          btn.disabled = false; btn.textContent = 'Subscribe →';
        }
      } catch {
        errMsg.classList.add('show');
        btn.disabled = false; btn.textContent = 'Subscribe →';
      }
    });
  }
</script>
