---
// /resources/health-check - the Reporting Trust Health Check.
// Rebuilt 2026-06-15 as a focused, full-screen app powered by the TRUST Index.
// The page itself is a short, indexable intro (SEO + funnel); "Launch" opens the
// full-screen experience. All scoring/selection is the proven engine in
// src/lib/trust-index*.js; the UI controller is src/lib/health-check-app.js.
import BaseLayout from "../../layouts/BaseLayout.astro";
import OwlMark from "../../components/OwlMark.astro";

// Cloudflare Turnstile site key (PUBLIC - safe to ship). The email opt-in only
// renders when this is set; until then the Health Check works fully without it.
// The matching SECRET lives on the mailer Worker (TURNSTILE_SECRET), never here.
const TURNSTILE_SITE_KEY = "0x4AAAAAADljyboyLF_0VWPj";
---
<BaseLayout
  title="Reporting Trust Health Check - Aesop Analytics"
  description="Score your reporting environment across the five TRUST pillars and get a personalized Reporting Trust Index (0-100) with a prioritized, plain-English report. Free - no email required."
  ogTitle="Reporting Trust Health Check - Aesop Analytics"
  ogDescription="Get your Reporting Trust Index (0-100) and a personalized report across 11 diagnostic areas. Free, deterministic, no email required."
  path="/resources/health-check"
>
<section class="intro">
  <div class="intro-in">
    <div class="intro-copy">
      <div class="eyebrow">Free resource · No email required</div>
      <h1>The Reporting Trust<br>Health Check</h1>
      <p class="lede">Score your organization across the five <strong>TRUST</strong> pillars and get a personalized <strong>Reporting Trust Index</strong> (0-100) - with a plain-English report on exactly where trust is breaking down and what to fix first.</p>
      <button type="button" class="launch" id="hc-launch">Launch the Health Check →</button>
      <div class="intro-meta">
        <span class="im">11 areas</span>
        <span class="im">5 TRUST pillars</span>
        <span class="im">~10 minutes</span>
        <span class="im">Runs in your browser</span>
      </div>
      <p class="fineprint">Nothing you enter is sent anywhere. The Reporting Trust Index is computed locally and deterministically - the same inputs always give the same score.</p>
    </div>
    <div class="intro-side" aria-hidden="true">
      <div class="side-label">What you get</div>
      <ul class="side-list">
        <li><strong>Your TRUST Index</strong> - one honest 0-100 number, gated so a strong area can't mask a weak one.</li>
        <li><strong>Five pillar scores</strong> - Triage, Reconcile, Unify, Standardize, Transition.</li>
        <li><strong>Your binding constraint</strong> - the one fix that moves the needle most.</li>
        <li><strong>A tailored report</strong> - findings, patterns, and where to start, specific to your profile.</li>
      </ul>
      <div class="side-note">This is the self-check. A Reporting Clarity Assessment is the same diagnosis done properly.</div>
    </div>
  </div>
</section>

<section class="below">
  <div class="below-in">
    <div class="below-label">How it works</div>
    <h2>The TRUST method, as a quick self-diagnosis.</h2>
    <div class="trust-grid">
      <div class="tg"><span class="tg-l">T</span><div><strong>Triage</strong><p>What reporting you have, and whether it earns its keep.</p></div></div>
      <div class="tg"><span class="tg-l">R</span><div><strong>Reconcile</strong><p>Whether the numbers agree and are believed.</p></div></div>
      <div class="tg"><span class="tg-l">U</span><div><strong>Unify</strong><p>Who owns each number and which system is authoritative.</p></div></div>
      <div class="tg"><span class="tg-l">S</span><div><strong>Standardize</strong><p>Whether a process keeps reporting trustworthy as it changes.</p></div></div>
      <div class="tg"><span class="tg-l">T</span><div><strong>Transition</strong><p>Whether reporting runs as a sustainable operating rhythm.</p></div></div>
    </div>
    <button type="button" class="launch sm" onclick="document.getElementById('hc-launch').click()">Launch the Health Check →</button>
  </div>
</section>

<!-- Print-only branded header/footer (hidden on screen; shown only when printing the report) -->
<div class="hc-prt-head" aria-hidden="true">
  <div class="hc-prt-brand"><OwlMark size={26} /><span class="hc-prt-wm">aesop</span><span class="hc-prt-an">Analytics</span></div>
  <div class="hc-prt-kicker">Reporting Trust Health Check</div>
</div>
<div class="hc-prt-rule" aria-hidden="true"></div>
<div class="hc-prt-meta" aria-hidden="true">Self-assessment &middot; Generated <span id="hc-prt-date"></span></div>

<!-- Full-screen app (filled + driven by health-check-app.js) -->
<div id="hc-app" class="hc-app" hidden></div>

<div class="hc-prt-foot" aria-hidden="true">
  <span>Aesop Analytics &mdash; reporting modernization &amp; data trust consulting &middot; Nashville, TN</span>
  <span>&copy; <span id="hc-prt-year"></span> &middot; Generated from the Reporting Trust Health Check at aesopanalytics.com/resources/health-check</span>
</div>
</BaseLayout>

<style>
  /* ── Intro ── */
  .intro { background:var(--navy); padding:76px 0 64px; position:relative; overflow:hidden; }
  .intro::after { content:"æ"; position:absolute; right:-2%; top:-20%; font-family:"Abril Fatface",serif; font-size:min(38vw,460px); line-height:1; color:rgba(193,140,93,.07); pointer-events:none; }
  .intro-in { max-width:1080px; margin:0 auto; padding:0 32px; position:relative; z-index:2; display:grid; grid-template-columns:1fr 340px; gap:56px; align-items:start; }
  @media(max-width:820px){ .intro-in { grid-template-columns:1fr; gap:36px; } }
  .eyebrow { font-size:12px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:var(--twine); margin-bottom:16px; }
  .intro h1 { font-family:"Newsreader",Georgia,serif; font-weight:500; font-size:clamp(38px,5.4vw,64px); line-height:1.02; color:#fff; letter-spacing:-.01em; margin-bottom:18px; }
  .lede { font-size:18px; color:#C4BDAE; font-weight:300; line-height:1.6; max-width:54ch; margin-bottom:26px; }
  .lede strong { color:#fff; font-weight:600; }
  .launch { display:inline-block; background:var(--twine); color:#fff; font-family:"DM Sans",sans-serif; font-weight:700; font-size:16px; padding:16px 30px; border:none; border-radius:6px; cursor:pointer; box-shadow:0 10px 26px rgba(193,140,93,.3); transition:transform .15s, background .15s; }
  .launch:hover { transform:translateY(-2px); background:var(--sepia); }
  .launch.sm { margin-top:28px; font-size:15px; padding:14px 26px; box-shadow:none; }
  .intro-meta { display:flex; gap:18px; flex-wrap:wrap; margin-top:24px; }
  .im { font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:.1em; color:#5A7090; display:flex; align-items:center; gap:7px; }
  .im::before { content:''; width:14px; height:1px; background:var(--twine); }
  .fineprint { font-size:12.5px; color:#5A7090; margin-top:22px; max-width:50ch; line-height:1.55; }
  .intro-side { background:var(--navy-2); border:1px solid var(--navy-3); border-radius:10px; padding:24px 22px; }
  .side-label { font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.2em; color:var(--twine); margin-bottom:16px; }
  .side-list { list-style:none; display:flex; flex-direction:column; gap:13px; margin:0 0 18px; }
  .side-list li { font-size:13.5px; color:#9AAABB; line-height:1.5; padding-left:16px; position:relative; }
  .side-list li::before { content:''; position:absolute; left:0; top:8px; width:6px; height:6px; border-radius:50%; background:var(--twine); }
  .side-list strong { color:#E8E2D6; font-weight:600; }
  .side-note { font-size:12.5px; color:#5A7090; font-style:italic; border-top:1px solid var(--navy-3); padding-top:14px; line-height:1.5; }

  /* ── Below (TRUST method) ── */
  .below { padding:64px 0 80px; }
  .below-in { max-width:1080px; margin:0 auto; padding:0 32px; }
  .below-label { font-size:11px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:var(--twine); margin-bottom:12px; }
  .below h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:clamp(24px,3.2vw,34px); color:var(--navy); letter-spacing:-.01em; margin-bottom:28px; }
  .trust-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:16px; }
  @media(max-width:820px){ .trust-grid { grid-template-columns:1fr 1fr; } }
  @media(max-width:520px){ .trust-grid { grid-template-columns:1fr; } }
  .tg { display:flex; gap:12px; align-items:flex-start; background:#fff; border:1px solid var(--line); border-radius:8px; padding:18px 16px; }
  .tg-l { font-family:"Abril Fatface",serif; font-size:26px; color:var(--twine); line-height:1; flex-shrink:0; }
  .tg strong { display:block; font-size:14px; color:var(--navy); margin-bottom:4px; }
  .tg p { font-size:12.5px; color:var(--muted); line-height:1.5; }
</style>

<style is:global>
  /* ── Full-screen app ── */
  body.hc-open { overflow:hidden; }
  .hc-app { position:fixed; inset:0; z-index:300; background:var(--paper); overflow-y:auto; -webkit-overflow-scrolling:touch; }
  .hc-app[hidden] { display:none; }

  .hc-top { position:sticky; top:0; z-index:5; display:flex; align-items:center; gap:16px; background:var(--navy); padding:14px 24px; }
  .hc-brand { display:flex; align-items:baseline; gap:10px; margin-right:auto; }
  .hc-wm { font-family:"Abril Fatface",serif; font-size:20px; color:#fff; }
  .hc-wm-an { font-size:11px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:var(--twine); }
  .hc-steps { display:flex; gap:7px; flex-wrap:wrap; }
  .hc-dot { font-size:10.5px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; color:#5A7090; padding:5px 10px; border-radius:20px; border:1px solid var(--navy-3); }
  .hc-dot.on { color:#fff; background:var(--twine); border-color:var(--twine); }
  .hc-dot.done { color:var(--twine); border-color:var(--twine); }
  .hc-x { background:none; border:1px solid var(--navy-3); color:#9AAABB; font:inherit; font-size:13px; font-weight:600; padding:7px 14px; border-radius:6px; cursor:pointer; }
  .hc-x:hover { color:#fff; border-color:#5A7090; }

  .hc-stage, .hc-report { max-width:780px; margin:0 auto; padding:40px 24px 80px; }
  .hc-report { max-width:880px; }
  .hc-stephead { margin-bottom:28px; }
  .hc-step-kicker { font-size:11px; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:var(--twine); margin-bottom:10px; }
  .hc-step-title { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:clamp(26px,4vw,38px); color:var(--navy); letter-spacing:-.01em; margin-bottom:8px; }
  .hc-step-blurb { font-size:16px; color:var(--slate); font-weight:300; line-height:1.55; }

  .hc-area { background:#fff; border:1px solid var(--line); border-radius:10px; padding:24px 24px 20px; margin-bottom:18px; }
  .hc-area-name { font-size:18px; font-weight:700; color:var(--navy); margin-bottom:6px; }
  .hc-area-desc { font-size:14px; color:var(--muted); line-height:1.55; margin-bottom:14px; }
  .hc-qs { list-style:none; border-left:2px solid var(--line); padding-left:13px; margin-bottom:20px; display:flex; flex-direction:column; gap:7px; }
  .hc-qs li { font-size:13px; color:var(--slate); font-style:italic; line-height:1.5; }
  .hc-rate { border-top:1px solid var(--line); padding-top:16px; }
  .hc-rate-top { display:flex; justify-content:space-between; align-items:baseline; font-size:13px; font-weight:600; color:var(--slate); margin-bottom:10px; }
  .hc-val { font-size:15px; font-weight:700; }
  .hc-val.low { color:var(--contessa); } .hc-val.mid { color:var(--twine); } .hc-val.high { color:var(--good); }
  .hc-slider { width:100%; accent-color:var(--twine); height:24px; cursor:pointer; }
  .hc-scale { display:flex; justify-content:space-between; font-size:11px; color:var(--muted); margin-top:4px; }

  .hc-nav { display:flex; justify-content:space-between; gap:14px; margin-top:28px; }
  .hc-btn { background:var(--twine); color:#fff; border:none; border-radius:7px; padding:14px 28px; font-family:inherit; font-size:15px; font-weight:700; cursor:pointer; transition:background .15s, transform .15s; text-decoration:none; display:inline-block; }
  .hc-btn:hover { background:var(--sepia); transform:translateY(-1px); }
  .hc-btn.ghost { background:transparent; color:var(--slate); border:1px solid var(--line); }
  .hc-btn.ghost:hover { background:var(--paper-2); color:var(--navy); transform:none; }
  .hc-btn:disabled { opacity:.4; cursor:not-allowed; }
  .hc-linkbtn { background:none; border:none; color:var(--muted); font:inherit; font-size:13px; text-decoration:underline; cursor:pointer; padding:4px; }
  .hc-linkbtn:hover { color:var(--slate); }

  /* ── Report ── */
  .hc-head { display:grid; grid-template-columns:200px 1fr; gap:36px; align-items:center; margin-bottom:36px; }
  @media(max-width:640px){ .hc-head { grid-template-columns:1fr; gap:20px; } }
  .hc-scorebox { text-align:center; }
  .hc-index { font-family:"Abril Fatface",serif; font-size:96px; line-height:.9; }
  .hc-index.b-critical { color:var(--contessa); } .hc-index.b-concern { color:var(--twine); } .hc-index.b-stable { color:var(--navy-mist); } .hc-index.b-strong { color:var(--good); }
  .hc-index-max { font-size:14px; color:var(--muted); margin-top:2px; }
  .hc-band-pill { display:inline-block; margin-top:12px; padding:7px 16px; border-radius:20px; border:1.5px solid; font-size:11.5px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; }
  .bp-critical { color:var(--contessa); border-color:var(--contessa); background:rgba(206,121,107,.1); }
  .bp-concern { color:var(--sepia); border-color:var(--twine); background:rgba(193,140,93,.1); }
  .bp-stable { color:var(--slate); border-color:var(--navy-mist); background:rgba(214,221,232,.25); }
  .bp-strong { color:var(--good); border-color:var(--good); background:rgba(74,157,110,.1); }
  .hc-head-title { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:clamp(22px,3.2vw,30px); color:var(--navy); line-height:1.15; margin-bottom:10px; }
  .hc-head-body { font-size:15.5px; color:var(--slate); line-height:1.6; }
  .hc-gate-note { margin-top:12px; font-size:13px; color:var(--sepia); background:var(--paper-2); border-left:3px solid var(--twine); padding:10px 13px; border-radius:0 6px 6px 0; line-height:1.5; }

  .hc-bars { background:#fff; border:1px solid var(--line); border-radius:10px; padding:24px 26px; margin-bottom:34px; }
  .hc-half-label { font-size:11px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:var(--slate); margin-bottom:14px; }
  .hc-half-label.op { margin-top:22px; padding-top:18px; border-top:1px dashed var(--line); }
  .hc-bar-row { display:grid; grid-template-columns:130px 1fr 32px; gap:12px; align-items:center; margin-bottom:11px; }
  @media(max-width:520px){ .hc-bar-row { grid-template-columns:96px 1fr 28px; gap:8px; } }
  .hc-bar-label { font-size:13.5px; font-weight:600; color:var(--navy); }
  .hc-bar-track { background:var(--paper-2); border-radius:3px; height:9px; overflow:hidden; }
  .hc-bar-fill { height:100%; border-radius:3px; transition:width .9s cubic-bezier(.2,.7,.2,1); }
  .hc-bar-fill.b-low { background:var(--contessa); } .hc-bar-fill.b-mid { background:var(--twine); } .hc-bar-fill.b-high { background:var(--good); }
  .hc-bar-score { font-size:13px; font-weight:700; color:var(--slate); text-align:right; }

  .hc-sec-label { font-size:11px; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:var(--twine); margin:30px 0 14px; }
  .hc-card { background:#fff; border:1px solid var(--line); border-left:4px solid var(--navy-mist); border-radius:0 9px 9px 0; padding:18px 20px; margin-bottom:12px; }
  .hc-card.sev-critical { border-left-color:var(--contessa); } .hc-card.sev-warning { border-left-color:var(--warn); } .hc-card.sev-insight { border-left-color:var(--twine); } .hc-card.sev-positive { border-left-color:var(--good); }
  .hc-card-title { font-size:16px; font-weight:700; color:var(--navy); margin-bottom:7px; line-height:1.3; }
  .hc-card-body { font-size:14px; color:var(--slate); line-height:1.6; }
  .hc-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  @media(max-width:640px){ .hc-grid { grid-template-columns:1fr; } }
  .hc-grid .hc-card { margin-bottom:0; }

  .hc-areas { border:1px solid var(--line); border-radius:10px; overflow:hidden; }
  .hc-area-row { display:grid; grid-template-columns:170px 54px 1fr; gap:14px; align-items:center; padding:13px 18px; border-bottom:1px solid var(--line); }
  .hc-area-row:last-child { border-bottom:none; }
  @media(max-width:640px){ .hc-area-row { grid-template-columns:1fr auto; gap:6px 12px; } .hc-area-rowtext { grid-column:1/-1; } }
  .hc-area-rowname { font-size:13px; font-weight:600; color:var(--navy); }
  .hc-area-chip { font-size:12px; font-weight:700; text-align:center; padding:3px 0; border-radius:6px; }
  .hc-area-chip.c-low { background:rgba(206,121,107,.14); color:var(--contessa); } .hc-area-chip.c-mid { background:rgba(193,140,93,.14); color:var(--sepia); } .hc-area-chip.c-high { background:rgba(74,157,110,.14); color:var(--good); }
  .hc-area-rowtext { font-size:13px; color:var(--slate); line-height:1.5; }

  .hc-cta { background:var(--navy); border-radius:12px; padding:30px 30px; margin:34px 0 24px; }
  .hc-cta-title { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:22px; color:#fff; line-height:1.2; margin-bottom:10px; }
  .hc-cta-body { font-size:14.5px; color:#B0BCCA; line-height:1.6; margin-bottom:22px; max-width:60ch; }
  .hc-cta-acts { display:flex; gap:14px; align-items:center; flex-wrap:wrap; }
  .hc-cta-acts .hc-linkbtn { color:#8A9FB8; }
  .hc-cta-acts .hc-linkbtn:hover { color:#fff; }
  .hc-emailform { margin-top:16px; }
  .hc-emailrow { display:flex; gap:10px; flex-wrap:wrap; }
  .hc-turnstile { margin-top:12px; min-height:65px; }
  .hc-email-input { flex:1; min-width:200px; padding:13px 14px; border:1px solid var(--navy-3); border-radius:7px; background:var(--navy-2); color:#fff; font:inherit; font-size:14px; }
  .hc-email-input::placeholder { color:#5A7090; }
  .hc-email-msg { font-size:12.5px; color:#8A9FB8; margin-top:9px; line-height:1.5; max-width:60ch; }
  .hc-foot { display:flex; gap:24px; justify-content:center; margin-top:20px; }

  /* Print-only header/footer (hidden on screen; shown only when printing the report) */
  .hc-prt-head, .hc-prt-rule, .hc-prt-meta, .hc-prt-foot, .hc-cta-printlink { display:none; }
  .hc-prt-head { align-items:center; justify-content:space-between; }
  .hc-prt-brand { display:flex; align-items:center; gap:9px; }
  .hc-prt-wm { font-family:"Abril Fatface",serif; font-size:18pt; color:var(--navy); }
  .hc-prt-an { font-family:"DM Sans",sans-serif; font-weight:600; font-size:8pt; letter-spacing:.26em; text-transform:uppercase; color:var(--twine); align-self:center; }
  .hc-prt-kicker { font-size:8.5pt; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:var(--twine); }
  .hc-prt-rule { height:2px; background:var(--navy); margin:10pt 0; }
  .hc-prt-meta { font-size:9pt; color:var(--muted); margin-bottom:14pt; }
  .hc-prt-foot { margin-top:16pt; border-top:1px solid var(--line); padding-top:8pt; }
  .hc-prt-foot span { display:block; font-size:7.5pt; color:var(--muted); line-height:1.5; }

  @media print {
    @page { margin:14mm 14mm 12mm; }

    /* Printing the REPORT: suppress site chrome + marketing siblings + in-app chrome */
    body.hc-report-view :is(nav, footer), body.hc-report-view .intro, body.hc-report-view .below,
    body.hc-report-view .hc-top, body.hc-report-view .hc-nav, body.hc-report-view .hc-foot, body.hc-report-view .hc-cta-acts, body.hc-report-view .hc-emailform { display:none !important; }
    /* Not in the report (intro / mid-questionnaire Ctrl+P): hide the app shell, print the normal page */
    body:not(.hc-report-view) .hc-app { display:none; }

    /* Show the print-only header/footer only when printing the report */
    body.hc-report-view .hc-prt-head { display:flex; }
    body.hc-report-view .hc-prt-rule, body.hc-report-view .hc-prt-meta, body.hc-report-view .hc-prt-foot { display:block; }

    /* Release the overlay scroll context so the PDF paginates full-height (the clip fix) */
    html, body.hc-report-view { overflow:visible !important; height:auto !important; }
    body.hc-report-view .hc-app { position:static; overflow:visible; }

    /* Colour fidelity (root + each background-bearing element) */
    .hc-report, .hc-index, .hc-bar-track, .hc-bar-fill, .hc-area-chip, .hc-band-pill, .hc-cta, .hc-card[class*="sev-"] { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
    .hc-index.b-stable { color:var(--navy); } /* pale mist -> ink on white */

    /* Page-break control */
    .hc-head, .hc-bars, .hc-card, .hc-area-row, .hc-cta, .hc-prt-head, .hc-prt-foot { break-inside:avoid; page-break-inside:avoid; }
    .hc-areas { overflow:visible; }
    .hc-areas-label { page-break-before:always; break-before:page; }

    /* Trim to a clean 2-3 page executive PDF */
    [data-print="drop"] { display:none !important; }
    .hc-grid .hc-card:nth-of-type(n+3) { display:none; }

    /* Keep the navy CTA legible even if the print dialog has backgrounds off */
    .hc-cta { border:1.5pt solid var(--navy); }
    .hc-cta-printlink { display:block; color:var(--twine); font-weight:700; font-size:10pt; margin-top:8pt; }

    /* Paper type sizing */
    .hc-report { max-width:none; margin:0; padding:0 0 8pt; font-size:10pt; }
    .hc-index { font-size:46pt; line-height:.85; }
