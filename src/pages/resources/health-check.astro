/* The smart data: everything the report needs, as one JSON-serializable object. */
function reportData() {
  if (Object.keys(scores).length < 10) return null;
  const total = AREAS.reduce((s,a)=>s+(scores[a.id]||0),0);
  const band = getBand(total);
  return {
    generated: new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}),
    year: new Date().getFullYear(),
    total: total,
    band: { key: band, label: BANDS[band].label, text: BANDS[band].text },
    areas: AREAS.map(a => ({ num:a.num, name:a.name, score:scores[a.id]||0, cls:cls(scores[a.id]||0) })),
    focus: [...AREAS].sort((a,b)=>(scores[a.id]||0)-(scores[b.id]||0)).slice(0,3)
      .map((a,i)=>({ rank:i+1, name:a.name, score:scores[a.id], label:a.article.label, url:'aesopanalytics.com'+a.article.href }))
  };
}

function reportBodyHTML(d) {
  const barColor = c => c==='low' ? '#CE796B' : c==='mid' ? '#C18C5D' : '#0F1F38';
  const pillColor = { critical:'#CE796B', concern:'#C18C5D', stable:'#5A7090', strong:'#4A9D6E' }[d.band.key];
  const rows = d.areas.map(a => `<tr class="rep-row">
      <td class="rep-area"><span class="rep-anum">${a.num}</span>${a.name}</td>
      <td class="rep-barcell"><div class="rep-track"><div class="rep-bar" style="width:${a.score*10}%;background:${barColor(a.cls)}"></div></div></td>
      <td class="rep-score" style="color:${barColor(a.cls)}">${a.score}<span class="rep-score-max">/10</span></td>
    </tr>`).join('');
  const focus = d.focus.map(f => `<div class="rep-focus">
      <div class="rep-focus-rank">Priority ${f.rank} focus area</div>
      <div class="rep-focus-name">${f.name}</div>
      <div class="rep-focus-score">Current score: ${f.score}/10</div>
      <div class="rep-focus-read"><strong>Recommended reading:</strong> ${f.label}<br><span class="rep-focus-url">${f.url}</span></div>
    </div>`).join('');
  return `
    <div class="rep-head">
      <div class="rep-brand">${OWL_SVG}<span class="rep-wm">aesop<span class="rep-wm-an"> Analytics</span></span></div>
      <div class="rep-kicker">Reporting Trust Health Check</div>
    </div>
    <div class="rep-rule"></div>
    <h1 class="rep-title">Your reporting trust results</h1>
    <div class="rep-meta">Self-assessment \u00b7 Generated ${d.generated}</div>
    <div class="rep-scoreblock">
      <div class="rep-scorenum">${d.total}<span class="rep-scoremax">/100</span></div>
      <div class="rep-bandwrap">
        <span class="rep-pill" style="color:${pillColor};border-color:${pillColor}">${d.band.label}</span>
        <p class="rep-bandtext">${d.band.text}</p>
      </div>
    </div>
    <div class="rep-section-label">Score by area</div>
    <table class="rep-table">${rows}</table>
    <div class="rep-page2">
      <div class="rep-section-label">Your three highest-priority focus areas</div>
      <div class="rep-focus-grid">${focus}</div>
      <div class="rep-cta">
        <div class="rep-cta-h">Want help interpreting these results?</div>
        <p class="rep-cta-p">Book a free 30-minute Reporting Trust Diagnostic \u2014 bring your scores and we'll identify the highest-impact areas together, and work out whether a structured assessment would help. <strong>aesopanalytics.com/diagnostic</strong></p>
      </div>
      <div class="rep-foot">
        <span>aesop Analytics \u2014 reporting modernization &amp; data trust consulting \u00b7 Nashville, TN</span>
        <span>\u00a9 ${d.year} Aesop Analytics \u00b7 Generated from the Reporting Trust Health Check at aesopanalytics.com/resources/health-check</span>
      </div>
    </div>`;
}

/* Fallback path (Ctrl+P / Cmd+P): in-page #report swapped in by @media print. */
function ensureRepStyle() {
  if (document.getElementById('rep-style')) return;
  const st = document.createElement('style');
  st.id = 'rep-style';
  st.textContent = '@media print{' + REPORT_CSS + '}';
  document.head.appendChild(st);
}
function buildReport() {
  const d = reportData();
  if (!d) return;
  ensureRepStyle();
  document.getElementById('report').innerHTML = reportBodyHTML(d);
}
window.addEventListener('beforeprint', buildReport);

/* Primary path (the button): print a standalone branded two-pager from a hidden iframe. */
function printReport() {
  const d = reportData();
  if (!d) { window.print(); return; }
  const doc = '<!DOCTYPE html><html lang="en"><head><meta charset="utf-8">'
    + '<title>Reporting Trust Health Check \u2014 Results</title>'
    + '<link rel="preconnect" href="https://fonts.googleapis.com">'
    + '<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>'
    + '<link href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Newsreader:opsz,wght@6..72,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">'
    + '<style>@page{margin:14mm 14mm 12mm}html,body{margin:0;padding:0;background:#fff}' + REPORT_CSS + '</style>'
    + '</head><body><div class="report-doc" style="display:block">' + reportBodyHTML(d) + '</div></body></html>';
  let fr = document.getElementById('print-frame');
  if (!fr) {
    fr = document.createElement('iframe');
    fr.id = 'print-frame';
    fr.setAttribute('aria-hidden','true');
    fr.style.cssText = 'position:fixed;right:0;bottom:0;width:0;height:0;border:0;visibility:hidden';
    document.body.appendChild(fr);
  }
  let printed = false;
  fr.onload = function() {
    const w = fr.contentWindow;
    const go = function() {
      if (printed) return; printed = true;
      try { w.focus(); w.print(); } catch(e) { window.print(); }
    };
    if (w.document.fonts && w.document.fonts.ready) {
      w.document.fonts.ready.then(function(){ setTimeout(go, 150); });
      setTimeout(go, 2500); /* safety net if fonts.ready stalls */
    } else {
      setTimeout(go, 600);
    }
  };
  fr.srcdoc = doc;
}

/* ====================== EMBEDDED-DOC REGION: END ====================== */
/* Restore a saved session (so a reload never destroys a completed check). */
(function restoreScores() {
  let saved = null;
  try { saved = JSON.parse(localStorage.getItem(HC_KEY) || 'null'); } catch(e) {}
  if (!saved || typeof saved !== 'object') return;
  Object.entries(saved).forEach(([id, val]) => {
    if (AREAS.some(a => a.id === id) && Number.isInteger(val) && val >= 1 && val <= 10) applyPick(id, val);
  });
  updateProgress();
  if (Object.keys(scores).length === 10) renderResults(false);
})();
