<script is:inline>
const fixes={};
let answered=0, auditBand='';
const TOTAL=30;
const CAT_LABELS={"01":"Purpose & Alignment","02":"Metric Definitions","03":"Data Trust & Quality","04":"Design & Usability","05":"Governance & Ownership","06":"Operational Health"};

document.querySelectorAll('.da-q').forEach(q=>{
  const fEl=q.querySelector('.da-fix-hint');
  if(fEl) fixes[q.id]={title:q.querySelector('.da-q-text').textContent.trim(),text:fEl.innerHTML};
});

function answer(n,v,btn,type){
  const q=document.getElementById('q'+n);
  if(q.dataset.val==='') answered++;
  q.dataset.val=v;
  q.querySelectorAll('.da-btn').forEach(b=>{b.classList.remove('sel-yes','sel-partial','sel-no');b.setAttribute('aria-pressed','false');});
  btn.classList.add('sel-'+type);
  btn.setAttribute('aria-pressed','true');
  q.classList.remove('answered-yes','answered-partial','answered-no');
  q.classList.add('answered-'+type);
  updateProgress();
  if(answered===TOTAL) showResults();
}

function updateProgress(){
  const pct=(answered/TOTAL)*100;
  document.getElementById('da-prog-fill').style.width=pct+'%';
  document.getElementById('da-prog-count').textContent=answered+' / '+TOTAL;
  if(answered===TOTAL){
    document.getElementById('da-prog').classList.add('complete');
    document.getElementById('da-prog-label').textContent='Audit complete — results below';
  }
}

function buildNarrative(catScores, pct){
  const sorted=Object.entries(catScores)
    .map(([cat,s])=>({cat,pct:s.total/s.max,name:CAT_LABELS[cat]}))
    .sort((a,b)=>a.pct-b.pct);
  const weakest=sorted.filter(c=>c.pct<0.6);
  const wNames=weakest.slice(0,2).map(c=>c.name.toLowerCase());
  let p1='',p2='';
  if(pct>=0.83){
    p1='This dashboard is performing well across most dimensions — scores this high are relatively uncommon. The fundamentals are sound: the data is trusted, the metrics are defined, and meaningful governance is in place.'+(weakest.length?' The one area worth continued attention is '+weakest[0].name.toLowerCase()+', which scored below what the rest of the audit would predict.':'');
    p2='The priority at this stage is maintenance: keeping governance cadences running, reviewing the dashboard semi-annually, and ensuring it evolves alongside the decisions it supports.';
  } else if(pct>=0.6){
    const urgency=weakest[0]&&weakest[0].pct<0.4?(weakest[0].name+' is the most urgent gap — without clear ownership and definitions, trust will erode the next time a number looks wrong and nobody can explain why.'):'These are not cosmetic issues; addressing them now prevents the more expensive problem of rebuilding trust after it breaks.';
    p1='The dashboard has solid foundations — it is being used and broadly trusted — but the audit surfaces structural gaps in '+wNames.join(' and ')+' that will quietly compound over time. '+urgency;
    p2='The good news: these are almost always process problems, not technical ones. They can be addressed systematically without redesigning the dashboard itself. Work through the priority fixes below and consider a governance review within the next 60 days.';
  } else if(pct>=0.33){
    p1='The dashboard has significant structural issues that are likely already affecting how much people rely on it. The gaps in '+wNames.join(' and ')+' are the core reasons dashboards get worked around. Recipients are probably verifying numbers elsewhere or simply not trusting what they see.';
    p2='Before investing more in design or data, address the governance and definition issues flagged below. A redesign on top of weak foundations produces a better-looking problem.';
  } else {
    p1='The audit results indicate that this dashboard needs fundamental work before further investment. The structural gaps — particularly in '+wNames.join(' and ')+' — suggest it may be creating the appearance of data governance without the substance.';
    p2='Pause any design or feature work and address the foundational issues first. At this score level it is worth asking directly: should this dashboard be rebuilt from scratch — or retired?';
  }
  return '<p>'+p1+'</p><p>'+p2+'</p>';
}

function showResults(){
  const r=document.getElementById('da-results');
  r.style.display='block';
  setTimeout(()=>r.scrollIntoView({behavior:'smooth',block:'start'}),100);

  let total=0;
  document.querySelectorAll('.da-q').forEach(q=>{total+=parseFloat(q.dataset.val)||0;});
  const rounded=Math.round(total*2)/2;

  const scoreEl=document.getElementById('res-score');
  let cur=0; const step=rounded/40;
  const timer=setInterval(()=>{cur=Math.min(cur+step,rounded);scoreEl.textContent=Math.round(cur*2)/2;if(cur>=rounded)clearInterval(timer);},30);

  const pct=rounded/30;
  let title, band;
  if(pct>=0.83){title='Strong — this dashboard is well-built';band='Strong';}
  else if(pct>=0.6){title='Functional — improvements will compound value';band='Functional';}
  else if(pct>=0.33){title='At risk — fundamental issues are undermining usefulness';band='At risk';}
  else{title='Critical — retire or rebuild before further investment';band='Critical';}
  auditBand=band;
  document.getElementById('res-verdict-title').textContent=title;

  const catScores={};
  document.querySelectorAll('.da-q').forEach(q=>{
    const c=q.dataset.cat;
    if(!catScores[c]) catScores[c]={total:0,max:0};
    catScores[c].total+=parseFloat(q.dataset.val)||0;
    catScores[c].max+=1;
  });

  const bd=document.getElementById('res-breakdown');
  bd.innerHTML='';
  const catLines=[];
  Object.entries(catScores).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([cat,s])=>{
    const p=s.total/s.max;
    const col=p>=0.8?'#7EB09B':p>=0.5?'#D4A844':'#CE796B';
    const row=document.createElement('div'); row.className='da-bar-row';
    const sc=s.total%1===0?s.total:s.total.toFixed(1);
    row.innerHTML='<span class="da-bar-label">'+CAT_LABELS[cat]+'</span><div class="da-bar-track"><div class="da-bar-fill" style="width:0%;background:'+col+'" data-w="'+Math.round(p*100)+'"></div></div><span class="da-bar-pct">'+sc+'/'+s.max+'</span>';
    bd.appendChild(row);
    catLines.push(CAT_LABELS[cat]+': '+sc+'/'+s.max);
  });
  setTimeout(()=>{document.querySelectorAll('.da-bar-fill').forEach(b=>{b.style.width=b.dataset.w+'%';});},100);

  document.getElementById('res-narrative').innerHTML=buildNarrative(catScores, pct);

  const fixItems=[];
  document.querySelectorAll('.da-q.answered-no').forEach(q=>{if(fixes[q.id])fixItems.push(fixes[q.id]);});
  if(fixItems.length<3) document.querySelectorAll('.da-q.answered-partial').forEach(q=>{if(fixItems.length<5&&fixes[q.id])fixItems.push(fixes[q.id]);});
  const fl=document.getElementById('fixes-label'),fe=document.getElementById('res-fixes');
  if(fixItems.length>0){
    fl.style.display='block'; fe.innerHTML='';
    fixItems.slice(0,5).forEach(f=>{
      const c=document.createElement('div'); c.className='da-fix-card';
      c.innerHTML='<h4>'+f.title+'</h4><div>'+f.text+'</div>';
      fe.appendChild(c);
    });
  }

  document.getElementById('h-score').value=rounded+'/30';
  document.getElementById('h-band').value=band;
  document.getElementById('h-cats').value=catLines.join(' | ');
  document.getElementById('h-fixes').value=fixItems.slice(0,3).map(f=>f.title).join(' | ');
}

document.getElementById('da-email-form').addEventListener('submit',async function(e){
  e.preventDefault();
  var email=document.getElementById('ef-email').value.trim();
  if(!email) return;
  var btn=document.getElementById('ef-btn');
  var errEl=document.getElementById('ef-error');
  btn.disabled=true; btn.textContent='Sending…'; errEl.style.display='none';
  try{
    var res=await fetch('https://formspree.io/f/xgobkezp',{
      method:'POST', body:new FormData(e.target), headers:{'Accept':'application/json'}
    });
    if(res.ok){
      document.getElementById('da-email-inner').style.display='none';
      document.getElementById('da-email-success').style.display='flex';
    } else { throw new Error(); }
  } catch(err){
    btn.disabled=false; btn.textContent='Email me these results →';
    errEl.style.display='block';
  }
});
</script>
