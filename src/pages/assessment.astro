---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = 'Reporting Clarity Assessment | Fixed-Fee Reporting Audit'
const description = 'A 2–3 week reporting audit: every report mapped, metric conflicts surfaced, and a prioritized 30/60/90-day fix plan. Fixed fee $5K–$9.5K. Free diagnostic.'
const ogDescription = "Reporting inventory, metric conflicts, KPI gaps, data source map, and a prioritized 30/60/90-day roadmap. You'll know exactly what to fix and in what order.";

const faqs = [
  {
    q: "Do I have to do the Assessment before anything else?",
    a: "No — but it's strongly recommended as the first paid engagement. If you already have a very clear picture of your reporting problems and just need implementation work, a Modernization Sprint or Governance Starter Kit may be the right starting point. The Diagnostic Call helps determine which path makes sense.",
  },
  {
    q: 'What does "fixed fee" mean in practice?',
    a: "The price is agreed before work begins and doesn't change based on hours worked. The scope defines what's included. If the scope needs to expand, that's a conversation — but you won't receive an unexpected invoice at the end.",
  },
  {
    q: "How much time does this require from our team?",
    a: "Typically 3–6 hours total across the engagement — a kickoff call, 2–4 stakeholder interviews of 30–45 minutes each, access to reporting environments, and the final readout session. We do the heavy lifting; your team provides access and context.",
  },
  {
    q: "What happens after the Assessment?",
    a: "You receive the full deliverable package and the readout. The 30/60/90-day roadmap is actionable immediately — you can execute the quick wins yourself. If a larger engagement makes sense, we'll propose it. There's no pressure, and the Assessment stands alone as a complete deliverable regardless of what you do next.",
  },
  {
    q: "What if the findings are better than we expected?",
    a: "That's a good outcome. An honest assessment of a reporting environment in better shape than feared is still valuable — it confirms what's working, surfaces the smaller improvements worth making, and prevents you from spending money on a large project you don't actually need.",
  },
];

const assessmentSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Reporting assessment",
  name: "Reporting Clarity Assessment",
  description:
    "A 2–3 week fixed-fee reporting audit: reporting inventory, metric conflict analysis, KPI gaps, data source map, manual burden analysis, and a prioritized 30/60/90-day modernization roadmap.",
  provider: { "@type": "ProfessionalService", name: "Aesop Analytics", url: "https://aesopanalytics.com" },
  areaServed: "US",
  offers: {
    "@type": "Offer",
    priceCurrency: "USD",
    priceSpecification: { "@type": "PriceSpecification", priceCurrency: "USD", minPrice: 5000, maxPrice: 9500 },
  },
};
---

<BaseLayout title={title} description={description} path="/assessment" ogDescription={ogDescription} schema={assessmentSchema}>

<!-- HERO -->
<section class="hero">
  <div class="hero-in">
    <div>
      <div class="eyebrow">Flagship offer · Fixed fee</div>
      <h1>Reporting Clarity Assessment</h1>
      <p>A structured 2–3 week review of your reporting estate. Know exactly where trust is breaking down — and what to fix first — before committing to a large transformation.</p>
      <div class="hero-price">
        <span class="price-badge">$5,000–$9,500</span>
        <span class="price-pill">2–3 weeks · 10 deliverables · Fixed fee</span>
      </div>
      <p class="price-note">Reduced rates available for nonprofits, referrals, and tightly-scoped engagements.</p>
      <a href="/diagnostic/" class="btn">Book a free diagnostic first →</a>
      <a href="/resources/sample-assessment/" class="btn secondary">See a sample assessment</a>
    </div>
    <div class="hero-card">
      <div class="hc-title">What you walk away with</div>
      <div class="hc-row"><span class="hc-check">✓</span><span class="hc-text"><strong>A complete reporting inventory</strong> — every dashboard, spreadsheet, and recurring report, mapped and rated</span></div>
      <div class="hc-row"><span class="hc-check">✓</span><span class="hc-text"><strong>Metric conflict list</strong> — exactly where KPI definitions diverge and who owns the dispute</span></div>
      <div class="hc-row"><span class="hc-check">✓</span><span class="hc-text"><strong>Data source map</strong> — authoritative systems, known quality issues, and ownership gaps</span></div>
      <div class="hc-row"><span class="hc-check">✓</span><span class="hc-text"><strong>Manual burden analysis</strong> — how many hours are being spent on spreadsheet reporting that could be eliminated</span></div>
      <div class="hc-row"><span class="hc-check">✓</span><span class="hc-text"><strong>30/60/90-day roadmap</strong> — prioritized, with effort estimates and owners</span></div>
      <div class="hc-row"><span class="hc-check">✓</span><span class="hc-text"><strong>Executive readout deck</strong> — board or leadership-ready summary of findings</span></div>
    </div>
  </div>
</section>

<!-- FOR WHO -->
<section class="for-who">
  <div class="wrap">
    <div class="for-who-grid">
      <div>
        <div class="sec-label">Who this is for</div>
        <h2>Companies that know something is wrong but can't quite name it.</h2>
        <p>The Assessment is designed for organizations where reporting pain is real but the specific causes are unclear — where leadership debates the numbers but nobody knows which report to trust or why they conflict.</p>
        <p>You don't need to have it figured out before starting. That's the point of the Assessment: to produce the clear picture that makes everything else possible.</p>
        <p><strong style="color:var(--navy)">Best fit:</strong> B2B companies, operations-heavy businesses, and nonprofits with 50–500 employees that have outgrown spreadsheets but haven't built a mature analytics operating model.</p>
      </div>
      <div>
        <div class="sec-label">Symptoms that indicate a fit</div>
        <div class="symptom-list">
          <div class="symptom">Leadership meetings derail into debates about whose number is right</div>
          <div class="symptom">Finance and Operations use different definitions for the same KPI</div>
          <div class="symptom">Analysts spend most of their time on manual reporting, not analysis</div>
          <div class="symptom">Multiple dashboards exist for the same function — and no one knows which is current</div>
          <div class="symptom">The data team is buried in ad hoc requests with no intake process</div>
          <div class="symptom">AI initiatives are stalled because the underlying data can't be trusted</div>
          <div class="symptom">Nobody can answer: "Which report does leadership actually use?"</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- DELIVERABLES -->
<section class="deliverables">
  <div class="wrap">
    <div class="sec-label">What's included</div>
    <h2>Ten deliverables. One coherent picture.</h2>
    <p class="intro">Every deliverable is designed to be actionable on its own — and to build toward the full roadmap. You can act on the quick wins immediately regardless of whether you move to a larger engagement.</p>
    <div class="del-grid">
      <div class="del-card"><div class="del-n">01</div><div class="del-body"><h3>Reporting Inventory</h3><p>Every dashboard, spreadsheet, and recurring report: tool, owner, audience, purpose, usage level, trust level, manual effort, and retirement candidacy.</p></div></div>
      <div class="del-card"><div class="del-n">02</div><div class="del-body"><h3>Stakeholder Pain Summary</h3><p>Structured synthesis from interviews with key stakeholders — the reporting problems as the business actually experiences them, not as IT describes them.</p></div></div>
      <div class="del-card"><div class="del-n">03</div><div class="del-body"><h3>Dashboard Usage Review</h3><p>Which reports are actually used to make decisions. Which exist but are ignored. Where the gap is between what was built and what leadership actually reaches for.</p></div></div>
      <div class="del-card"><div class="del-n">04</div><div class="del-body"><h3>Metric Conflict List</h3><p>Every place where two teams are using different definitions for the same KPI — with the specific disagreement documented and the business impact quantified where possible.</p></div></div>
      <div class="del-card"><div class="del-n">05</div><div class="del-body"><h3>KPI Definition Gaps</h3><p>Metrics that exist in dashboards without an agreed owner, a documented formula, or an authoritative source system. The structural source of most "whose number is right" arguments.</p></div></div>
      <div class="del-card"><div class="del-n">06</div><div class="del-body"><h3>Data Source Map</h3><p>The authoritative source for each critical data domain — which system, who owns it, known quality issues, downstream reports affected, and access constraints.</p></div></div>
      <div class="del-card"><div class="del-n">07</div><div class="del-body"><h3>Manual Reporting Burden Analysis</h3><p>Time cost of spreadsheet-based reporting that could be automated or eliminated. Converts abstract "we do a lot of manual work" into a concrete hours-per-week number.</p></div></div>
      <div class="del-card"><div class="del-n">08</div><div class="del-body"><h3>Quick-Win Recommendations</h3><p>Changes that can be made in the next 30 days with minimal effort — immediate trust-builders that don't require a larger project to implement.</p></div></div>
      <div class="del-card"><div class="del-n">09</div><div class="del-body"><h3>30/60/90-Day Modernization Roadmap</h3><p>Prioritized recommendations with business impact, effort level, owner, dependencies, risk, and next step. Built to be handed to leadership and acted on immediately.</p></div></div>
      <div class="del-card"><div class="del-n">10</div><div class="del-body"><h3>Executive Readout Deck</h3><p>A board or leadership-ready summary of findings — structured to present the current state, key pain themes, and recommended priorities without requiring the audience to read the full report.</p></div></div>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="process">
  <div class="process-in">
    <div class="eyebrow">How it works</div>
    <h2>Four phases. 2–3 weeks.</h2>
    <p class="sub">The Assessment follows the first two phases of the TRUST Reporting Modernization Method — structured enough to produce reliable findings, fast enough to be actionable.</p>
    <div class="process-steps">
      <div class="ps">
        <div class="ps-n">01</div>
        <h3>Kickoff &amp; Access</h3>
        <p>Align on scope, stakeholders, and success criteria. Get access to reporting environments and schedule discovery interviews.</p>
        <ul><li>Scope confirmation</li><li>Stakeholder map</li><li>Access setup</li></ul>
      </div>
      <div class="ps">
        <div class="ps-n">02</div>
        <h3>Discovery Interviews</h3>
        <p>Structured conversations with 3–6 key stakeholders — leadership, analysts, department heads. What they use, what they don't trust, and what slows decisions down.</p>
        <ul><li>Pain themes</li><li>Report usage</li><li>KPI conflicts</li></ul>
      </div>
      <div class="ps">
        <div class="ps-n">03</div>
        <h3>Inventory &amp; Analysis</h3>
        <p>Walk through the reporting environment systematically. Document every report, map sources, identify metric conflicts and ownership gaps.</p>
        <ul><li>Reporting inventory</li><li>Metric audit</li><li>Source map</li></ul>
      </div>
      <div class="ps">
        <div class="ps-n">04</div>
        <h3>Readout &amp; Roadmap</h3>
        <p>Present findings and the prioritized 30/60/90-day roadmap. Executive deck included. Next steps defined — whether that's implementation work or acting on the quick wins independently.</p>
        <ul><li>Executive readout</li><li>Roadmap</li><li>Next steps</li></ul>
      </div>
    </div>
  </div>
</section>

<!-- IS THIS RIGHT -->
<section class="fit">
  <div class="wrap">
    <h2>Is the Assessment right for you?</h2>
    <div class="fit-grid">
      <div class="fit-box yes">
        <div class="fb-label">Good fit</div>
        <div class="fit-item">You have real reporting pain but aren't sure exactly what's causing it</div>
        <div class="fit-item">Leadership debates numbers but nobody knows which report to trust</div>
        <div class="fit-item">You want a clear problem picture before committing to a large project</div>
        <div class="fit-item">There's an executive sponsor who cares about fixing this</div>
        <div class="fit-item">You can provide access to reports and 3–6 stakeholders for interviews</div>
        <div class="fit-item">50–500 employees, operations-heavy, no mature analytics operating model</div>
      </div>
      <div class="fit-box no">
        <div class="fb-label">Less ideal — here's why</div>
        <div class="fit-item">You've already done a thorough audit recently — consider starting with the Sprint instead</div>
        <div class="fit-item">No executive sponsor — the findings won't go anywhere without a business owner behind them</div>
        <div class="fit-item">You need dashboard development, not a diagnostic — start with Services</div>
        <div class="fit-item">You're a startup with fewer than 10 employees and one or two reports — this is premature</div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
})} />
<section class="faq">
  <div class="wrap">
    <h2>Assessment FAQ</h2>
    {faqs.map((f) => <div class="faq-item"><div class="fq">{f.q}</div><div class="fa">{f.a}</div></div>)}
  </div>
</section>

<!-- CONVERSION CTA -->
<section class="conversion">
  <div class="conv-in">
    <span class="eyebrow">Ready to start?</span>
    <h2>Know what you're working with before you fix it.</h2>
    <p>Every Assessment begins with a free 30-minute Reporting Trust Diagnostic — a conversation to understand your situation and confirm there's a fit before any work begins.</p>
    <div class="conv-details">
      <div class="conv-detail"><div class="cdn">$0</div><div class="cdl">Diagnostic call</div></div>
      <div class="conv-divider"></div>
      <div class="conv-detail"><div class="cdn">30</div><div class="cdl">Minutes, no pitch</div></div>
      <div class="conv-divider"></div>
      <div class="conv-detail"><div class="cdn">10</div><div class="cdl">Deliverables</div></div>
      <div class="conv-divider"></div>
      <div class="conv-detail"><div class="cdn">2–3</div><div class="cdl">Weeks to complete</div></div>
    </div>
    <a href="/diagnostic/" class="btn">Book a Reporting Trust Diagnostic →</a>
  </div>
</section>

<style>
/* HERO — conversion-focused */
  .hero { background:var(--navy); padding:80px 0; overflow:hidden; position:relative; }
.hero::after { content:"æ"; position:absolute; right:-2%; top:-18%; font-family:"Abril Fatface",serif; font-size:min(42vw,500px); line-height:1; color:rgba(193,140,93,.07); pointer-events:none; }
.hero-in { max-width:1080px; margin:0 auto; padding:0 32px; position:relative; z-index:2; display:grid; grid-template-columns:1.1fr .9fr; gap:60px; align-items:center; }
@media(max-width:760px) {
  .hero-in { grid-template-columns:1fr; gap:36px; }
}
.hero h1 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(34px,5.2vw,60px); line-height:1.04; color:#fff; margin-bottom:20px; }
.hero p { font-size:18px; color:#C4BDAE; font-weight:300; line-height:1.6; margin-bottom:28px; max-width:48ch; }
.hero-price { display:flex; gap:16px; flex-wrap:wrap; align-items:center; margin-bottom:28px; }
.price-badge { background:var(--twine); color:#fff; font-size:17px; font-weight:700; padding:8px 18px; border-radius:4px; }
.price-pill { font-size:14px; color:#8A9FB8; }
.price-note { font-size:13px; color:#8A9FB8; font-style:italic; font-weight:300; margin:-12px 0 28px; }
.btn { display:inline-block; background:var(--twine); color:#fff; font-family:"DM Sans",sans-serif; font-weight:600; padding:15px 28px; border-radius:4px; font-size:15px; transition:transform .18s,background .18s; }
.btn:hover { transform:translateY(-2px); background:var(--sepia); }
.btn.secondary { background:transparent; color:var(--cream); border:1.5px solid rgba(255,255,255,.25); margin-left:10px; }
.btn.secondary:hover { border-color:var(--twine); color:var(--twine); background:transparent; }
/* Right side: value summary card */
  .hero-card { background:var(--navy-2); border-radius:8px; padding:32px 28px; border:1px solid var(--navy-3); }
.hero-card .hc-title { font-size:14px; font-weight:700; color:var(--twine); text-transform:uppercase; letter-spacing:.14em; margin-bottom:18px; }
.hc-row { display:flex; gap:12px; padding:11px 0; border-bottom:1px solid rgba(255,255,255,.07); align-items:flex-start; }
.hc-row:last-child { border-bottom:none; }
.hc-check { color:var(--twine); font-weight:700; flex-shrink:0; font-size:14px; margin-top:1px; }
.hc-text { font-size:14.5px; color:#C4BDAE; line-height:1.4; font-weight:300; }
.hc-text strong { color:#fff; font-weight:600; }
/* FOR WHO */
  .for-who { padding:72px 0; background:var(--paper-2); border-bottom:1px solid var(--rule); }
.for-who-grid { display:grid; grid-template-columns:1fr 1fr; gap:48px; }
@media(max-width:720px) {
  .for-who-grid { grid-template-columns:1fr; gap:28px; }
}
.for-who h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(24px,3.2vw,36px); color:var(--navy); margin-bottom:16px; line-height:1.1; }
.for-who p { font-size:17px; color:var(--slate); line-height:1.65; font-weight:300; margin-bottom:16px; }
.symptom-list { display:flex; flex-direction:column; gap:0; margin-top:8px; border-top:2px solid var(--rule); }
.symptom { display:flex; gap:12px; align-items:flex-start; padding:13px 0; border-bottom:1px solid var(--line); font-size:15.5px; color:var(--ink); line-height:1.5; font-weight:400; }
.symptom::before { content:"↯"; color:var(--contessa); font-weight:700; flex-shrink:0; margin-top:1px; font-size:14px; }
/* DELIVERABLES */
  .deliverables { padding:72px 0; }
.deliverables h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(26px,3.4vw,40px); color:var(--navy); margin-bottom:14px; }
.deliverables .intro { font-size:17px; color:var(--slate); font-weight:300; max-width:58ch; margin-bottom:44px; line-height:1.6; }
.del-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
@media(max-width:660px) {
  .del-grid { grid-template-columns:1fr; }
}
.del-card { background:#fff; border:1px solid var(--line); border-radius:6px; padding:22px 20px; display:flex; gap:14px; }
.del-n { font-family:"Abril Fatface",serif; font-size:22px; color:var(--twine); min-width:36px; line-height:1; flex-shrink:0; }
.del-body h3 { font-size:15.5px; font-weight:700; color:var(--navy); margin-bottom:5px; }
.del-body p { font-size:14px; color:var(--muted); line-height:1.5; font-weight:300; }
/* PROCESS */
  .process { background:var(--navy); padding:72px 0; }
.process-in { max-width:1080px; margin:0 auto; padding:0 32px; }
.process-in .eyebrow { color:var(--twine); }
.process-in h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(26px,3.4vw,40px); color:#fff; margin-bottom:14px; }
.process-in .sub { font-size:17px; color:#C4BDAE; font-weight:400; max-width:52ch; margin-bottom:44px; line-height:1.6; }
.process-steps { display:grid; grid-template-columns:repeat(4,1fr); gap:3px; border-radius:6px; overflow:hidden; }
@media(max-width:680px) {
  .process-steps { grid-template-columns:repeat(2,1fr); }
}
.ps { background:var(--navy-2); padding:26px 22px; }
.ps-n { font-family:"Abril Fatface",serif; font-size:36px; color:var(--twine); opacity:.45; line-height:1; margin-bottom:8px; }
.ps h3 { font-size:15px; font-weight:700; color:#fff; margin-bottom:10px; }
.ps p { font-size:13.5px; color:#B8C2D0; line-height:1.55; font-weight:400; }
.ps ul { list-style:none; padding:0; margin-top:8px; }
.ps ul li { font-size:13px; color:#8FA4B8; padding:4px 0; border-top:1px solid rgba(255,255,255,.06); display:flex; gap:8px; line-height:1.4; }
.ps ul li::before { content:"·"; color:var(--twine); flex-shrink:0; }
/* IS THIS RIGHT FOR YOU */
  .fit { padding:72px 0; background:var(--paper-2); border-top:1px solid var(--rule); border-bottom:1px solid var(--rule); }
.fit h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(24px,3.2vw,36px); color:var(--navy); margin-bottom:36px; }
.fit-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
@media(max-width:640px) {
  .fit-grid { grid-template-columns:1fr; }
}
.fit-box { border-radius:6px; padding:24px; }
.fit-box.yes { background:#fff; border:1px solid var(--line); border-top:3px solid var(--navy); }
.fit-box.no { background:#fff; border:1px solid var(--line); border-top:3px solid rgba(206,118,107,.5); }
.fb-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.16em; margin-bottom:14px; }
.fit-box.yes .fb-label { color:var(--navy); }
.fit-box.no  .fb-label { color:var(--contessa); }
.fit-item { font-size:15px; color:var(--slate); padding:9px 0; border-bottom:1px solid var(--line); display:flex; gap:10px; line-height:1.45; font-weight:300; }
.fit-item:last-child { border-bottom:none; }
.fit-item::before { font-weight:700; flex-shrink:0; margin-top:1px; }
.fit-box.yes .fit-item::before { content:"✓"; color:var(--navy); }
.fit-box.no  .fit-item::before { content:"→"; color:var(--contessa); }
/* FAQ */
  .faq { padding:72px 0; }
.faq h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(24px,3.2vw,36px); color:var(--navy); margin-bottom:32px; }
.faq-item { border-bottom:1px solid var(--line); padding:20px 0; max-width:760px; }
.faq-item:first-child { border-top:2px solid var(--rule); }
.fq { font-size:17px; font-weight:700; color:var(--navy); margin-bottom:10px; }
.fa { font-size:16px; color:var(--slate); line-height:1.65; font-weight:300; }
/* CONVERSION CTA */
  .conversion { background:var(--navy); border-top:3px solid var(--twine); padding:80px 32px; }
.conv-in { max-width:680px; margin:0 auto; text-align:center; }
.conv-in .eyebrow { color:var(--twine); margin-bottom:20px; display:block; }
.conv-in h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; letter-spacing:-.01em; font-size:clamp(28px,4vw,46px); color:#fff; margin-bottom:18px; line-height:1.06; }
.conv-in p { color:#A8B4C0; font-size:17px; font-weight:300; max-width:46ch; margin:0 auto 32px; line-height:1.6; }
.conv-details { display:flex; gap:24px; justify-content:center; flex-wrap:wrap; margin-bottom:32px; }
.conv-detail { text-align:center; }
.conv-detail .cdn { font-family:"Abril Fatface",serif; font-size:36px; color:var(--twine); line-height:1; }
.conv-detail .cdl { font-size:12px; color:#8FA4B8; margin-top:4px; text-transform:uppercase; letter-spacing:.08em; font-weight:500; }
.conv-divider { width:1px; background:rgba(255,255,255,.1); align-self:stretch; }
@media(max-width:480px) {
  .conv-divider { display:none; }
}
</style>

</BaseLayout>
