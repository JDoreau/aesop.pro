---
// Seo.astro — the ONE place the document head is defined: meta, favicon,
// fonts, Open Graph, and structured data. Pages pass a full title.
// Canonical/OG/breadcrumb URLs all flow through canonicalUrl() (nav.ts) so
// they always match the sitemap's trailing-slash form.
import { site, nav, canonicalUrl } from "../data/nav.ts";

export interface Props {
  title: string;
  description: string;
  path?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}
// path defaults to the page's own route — a page that forgets to pass it can
// no longer silently claim the homepage as its canonical.
const { title, description, path = Astro.url.pathname, ogTitle, ogDescription, ogType = "website", noindex = false, schema, ogImage } = Astro.props;
const canonical = canonicalUrl(path);
const ogImageUrl = new URL(ogImage ?? "/assets/og-image.png", site.url).href;

// Breadcrumb trail, derived from the path so it can never drift from the IA.
const leafName = title.split("|")[0].split("·")[0].trim();
const segments = path.split("/").filter(Boolean);
const crumbs = [{ name: "Home", item: site.url }];
let acc = "";
segments.forEach((seg, i) => {
  acc += "/" + seg;
  const navMatch = nav.find((n) => n.href === acc);
  const isLeaf = i === segments.length - 1;
  const name = navMatch ? navMatch.label : isLeaf ? leafName : seg.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
  crumbs.push({ name, item: canonicalUrl(acc) });
});
const breadcrumbSchema = segments.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: crumbs.map((c, i) => ({ "@type": "ListItem", position: i + 1, name: c.name, item: c.item })),
    }
  : null;
const extraSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
{noindex && <meta name="robots" content="noindex, follow" />}

<!-- Google Analytics (GA4) - measurement ID G-4TVCCT0XW9. PROD-gated so dev
     and preview sessions never pollute the production property. -->
{import.meta.env.PROD && <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-4TVCCT0XW9"></script>}
{import.meta.env.PROD && <script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  // Skip the pageview on the report-render path (/resources/health-check/?r=...)
  // so the headless Browser Rendering bot can't fire phantom GA4 hits.
  if (!/[?&]r=/.test(location.search)) {
    gtag('js', new Date());
    gtag('config', 'G-4TVCCT0XW9');
  }
</script>}
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<!-- clean favicon link (the live pages have stray SVG markup trailing this tag) -->
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />

<meta property="og:title" content={ogTitle ?? title} />
<meta property="og:description" content={ogDescription ?? description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Aesop Analytics - turn mistrusted reporting into a governed decision system." />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImageUrl} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: site.name,
  description: "Reporting modernization and data trust consulting for growing companies.",
  url: site.url,
  email: site.email,
  logo: new URL("/assets/favicon.svg", site.url).href,
  image: new URL("/assets/og-image.png", site.url).href,
  slogan: "Every dataset has a moral.",
  founder: { "@type": "Person", name: "Jonathan Doreau" },
  areaServed: "US",
  address: { "@type": "PostalAddress", addressLocality: "Nashville", addressRegion: "TN", addressCountry: "US" },
  sameAs: [site.linkedin],
  knowsAbout: ["Reporting modernization", "Data trust", "KPI governance", "Business intelligence", "Data governance", "Analytics strategy"],
  priceRange: "$$$",
})} />
{path === "/" && <script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  publisher: { "@type": "Organization", name: site.name },
})} />}
{breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
{extraSchema.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
