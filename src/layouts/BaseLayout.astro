---
// BaseLayout.astro — every page renders through this. The head, the global
// stylesheets, the nav, and the footer are composed here exactly once.
// Props mirror Seo's (extended, not re-declared) and forward via spread, so
// a prop added to Seo can never silently drop here again.
import "../styles/tokens.css";
import "../styles/base.css";
import Seo from "../components/Seo.astro";
import type { Props as SeoProps } from "../components/Seo.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props extends SeoProps {}
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <Seo {...Astro.props} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav />
    <main id="main"><slot /></main>
    <Footer />
  </body>
</html>
