---
// ArticleLayout.astro — the ONE layout for articles & field studies.
// Compact 7-link nav (from nav.ts) + byline header (from props) + compact
// footer + reveal animation + article.css. Every article renders through
// this, which is what makes the legacy-header articles consistent again.
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/article.css";
import Seo from "../components/Seo.astro";
import { nav, cta, site } from "../data/nav.ts";

interface Props {
  title: string;
  description: string;
  path: string;
  kicker: string;
  headingHtml: string;
  dekHtml: string;
  meta: string[];
  author?: string;
  ogTitle?: string;
  ogDescription?: string;
}
const {
  title, description, path, kicker, headingHtml, dekHtml,
  meta = [], author = "Jonathan Doreau", ogTitle, ogDescription,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <Seo title={title} description={description} path={path} ogType="article" ogTitle={ogTitle} ogDescription={ogDescription} />
  </head>
  <body>
    <nav>
      <div class="nav-in">
        <a href="/" class="brand"><svg class="owl-mark" viewBox="0 0 192 192" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path class="owl-body" d="M38.27,123.78V68.53v-4.76h0.18C40.75,30.31,67,3.83,98.97,3.83c31.97,0,58.23,26.48,60.52,59.95h0.18v4.76v120.39h-4.56v0c-0.06,0-0.11,0-0.17,0H99.38c-3.73,0-7.38-0.38-10.93-1.06H32.93v-9.51h33.13C49.35,166.71,38.27,146.6,38.27,123.78z M98.97,13.34c-18.05,0-33.97,9.9-43.24,24.88c4.53-2.59,9.71-4.07,15.2-4.07c12.01,0,22.48,7.04,28.04,17.44c5.56-10.4,16.03-17.44,28.04-17.44c5.49,0,10.67,1.48,15.2,4.07C132.94,23.25,117.02,13.34,98.97,13.34z M127.01,43.66c-12.87,0-23.57,11.16-23.57,24.88v25.13h-8.92V68.54c0-13.72-10.7-24.88-23.57-24.88c-12.87,0-23.74,11.16-23.74,24.88c0,30.43,23.23,55.19,51.78,55.19c28.55,0,51.78-24.76,51.78-55.19C150.75,54.82,139.88,43.66,127.01,43.66z M150.75,178.35v-76.08c-9.91,17.22-27.17,29.13-47.09,30.76c3.58,22.75,20.15,40.86,41.28,45.32H150.75z M89.24,178.35h32.55c-14.41-10.03-24.61-26.36-27.16-45.3c-20.07-1.52-37.47-13.46-47.44-30.79v21.51C47.2,150.76,65.3,173.3,89.24,178.35z"/><path class="owl-eyes" d="M127.21,77.77c7.72,0,7.73-12,0-12C119.49,65.77,119.47,77.77,127.21,77.77z"/><path class="owl-eyes" d="M71.91,77.77c7.72,0,7.73-12,0-12C64.19,65.77,64.18,77.77,71.91,77.77z"/></svg><span class="nm">aesop</span><span class="an">Analytics</span></a>
        <div class="site-links">
          {nav.map((i) => (<a href={i.href} class:list={[{ "nav-accent": i.accent }]}>{i.label}</a>))}
        </div>
        <a href={cta.href} class="site-cta">{cta.label}</a>
      </div>
    </nav>

    <div class="wrap">
      <article>
        <div class="kicker reveal">{kicker}</div>
        <h1 class="reveal" style="animation-delay:.05s" set:html={headingHtml}></h1>
        <p class="dek reveal" style="animation-delay:.1s" set:html={dekHtml}></p>
        <div class="byline reveal" style="animation-delay:.16s">
          <span class="reg">By <strong>{author}</strong>, Aesop Analytics</span>
          {meta.map((m) => (<Fragment><span class="dot">&bull;</span><span class="reg">{m}</span></Fragment>))}
        </div>
      </article>
      <slot />
    </div>

    <footer class="site">
      <div class="fin">
        <div class="fbrand"><svg class="fbrand-owl" viewBox="0 0 192 192" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="var(--twine)" d="M38.27,123.78V68.53v-4.76h0.18C40.75,30.31,67,3.83,98.97,3.83c31.97,0,58.23,26.48,60.52,59.95h0.18v4.76v120.39h-4.56v0c-0.06,0-0.11,0-0.17,0H99.38c-3.73,0-7.38-0.38-10.93-1.06H32.93v-9.51h33.13C49.35,166.71,38.27,146.6,38.27,123.78z M98.97,13.34c-18.05,0-33.97,9.9-43.24,24.88c4.53-2.59,9.71-4.07,15.2-4.07c12.01,0,22.48,7.04,28.04,17.44c5.56-10.4,16.03-17.44,28.04-17.44c5.49,0,10.67,1.48,15.2,4.07C132.94,23.25,117.02,13.34,98.97,13.34z M127.01,43.66c-12.87,0-23.57,11.16-23.57,24.88v25.13h-8.92V68.54c0-13.72-10.7-24.88-23.57-24.88c-12.87,0-23.74,11.16-23.74,24.88c0,30.43,23.23,55.19,51.78,55.19c28.55,0,51.78-24.76,51.78-55.19C150.75,54.82,139.88,43.66,127.01,43.66z M150.75,178.35v-76.08c-9.91,17.22-27.17,29.13-47.09,30.76c3.58,22.75,20.15,40.86,41.28,45.32H150.75z M89.24,178.35h32.55c-14.41-10.03-24.61-26.36-27.16-45.3c-20.07-1.52-37.47-13.46-47.44-30.79v21.51C47.2,150.76,65.3,173.3,89.24,178.35z"/><path fill="#FBFAF5" d="M127.21,77.77c7.72,0,7.73-12,0-12C119.49,65.77,119.47,77.77,127.21,77.77z"/><path fill="#FBFAF5" d="M71.91,77.77c7.72,0,7.73-12,0-12C64.19,65.77,64.18,77.77,71.91,77.77z"/></svg><span class="nm">aesop</span><span class="an">Analytics</span></div>
        <div class="fmoral">{site.tagline}</div>
        <a href="/insights" class="fback">&larr; All Insights</a>
      </div>
      <div class="flegal">This site uses Google Analytics. <a href="/privacy">Privacy</a></div>
    </footer>

    <style>
      .brand { align-items:center; }
      .brand .owl-mark { height:30px; width:30px; flex-shrink:0; }
      .owl-mark .owl-body { fill:var(--navy); }
      .owl-mark .owl-eyes { fill:var(--twine); }
      footer.site .fbrand { align-items:center; }
      footer.site .fbrand-owl { height:28px; width:28px; margin-right:6px; }
    </style>

    <script>
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) {
            en.target.style.animation = "rise .7s cubic-bezier(.2,.7,.2,1) forwards";
            io.unobserve(en.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
    </script>
  </body>
</html>
