---
// ArticleLayout.astro — the ONE layout for articles & field studies.
// Compact 7-link nav (from nav.ts) + byline header (from props) + compact
// footer + reveal animation + article.css. Every article renders through
// this, which is what makes the legacy-header articles consistent again.
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/article.css";
import Seo from "../components/Seo.astro";
import { nav, cta, site, canonicalUrl } from "../data/nav.ts";
import { sections, featured } from "../data/insights.ts";
import Wordmark from "../components/Wordmark.astro";

interface Props {
  title: string;
  description: string;
  path: string;
  kicker: string;
  headingHtml: string;
  dekHtml: string;
  meta: string[];
  author?: string;
  ogTitle?: string;
  ogDescription?: string;
}
const {
  title, description, path, kicker, headingHtml, dekHtml,
  meta = [], author = "Jonathan Doreau", ogTitle, ogDescription,
} = Astro.props;
const canonical = canonicalUrl(path);
// Publish date: looked up from insights.ts by slug (one source — articles
// don't restate it). Dates are git-derived; see the Row.published comment.
const slug = path.split("/").filter(Boolean).pop();
const row = sections.flatMap((s) => s.rows).find((r) => r.slug === slug) ?? (featured.slug === slug ? featured : undefined);
const published = row?.published;
const publishedDisplay = published
  ? new Date(published + "T00:00:00").toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
  : undefined;
// JSON-LD headline: the title alone — drop the visual subtitle span and
// decode the entities Astro leaves in the raw prop string.
const headline = headingHtml
  .replace(/<span class="sub">[\s\S]*?<\/span>/g, "")
  .replace(/<[^>]+>/g, "")
  .replace(/&amp;/g, "&").replace(/&quot;/g, '"').replace(/&#39;/g, "'")
  .trim();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <Seo title={title} description={description} path={path} ogType="article" ogTitle={ogTitle} ogDescription={ogDescription} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      headline,
      description,
      author: { "@type": "Person", name: author },
      publisher: { "@type": "Organization", name: site.name, logo: { "@type": "ImageObject", url: new URL("/assets/favicon.svg", site.url).href } },
      mainEntityOfPage: canonical,
      url: canonical,
      ...(published ? { datePublished: published } : {}),
    })} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <nav>
      <div class="nav-in">
        <Wordmark variant="article-nav" href="/" />
        <div class="site-links">
          {nav.map((i) => (<a href={i.href} class:list={[{ "nav-accent": i.accent }]}>{i.label}</a>))}
        </div>
        <a href={cta.href} class="site-cta">{cta.label}</a>
      </div>
    </nav>

    <main id="main" class="wrap">
      <article>
        <div class="kicker reveal">{kicker}</div>
        <h1 class="reveal" style="animation-delay:.05s" set:html={headingHtml}></h1>
        <p class="dek reveal" style="animation-delay:.1s" set:html={dekHtml}></p>
        <div class="byline reveal" style="animation-delay:.16s">
          <span class="reg">By <strong>{author}</strong>, Aesop Analytics</span>
          {publishedDisplay && (<Fragment><span class="dot">&bull;</span><span class="reg">{publishedDisplay}</span></Fragment>)}
          {meta.map((m) => (<Fragment><span class="dot">&bull;</span><span class="reg">{m}</span></Fragment>))}
        </div>
      </article>
      <slot />
    </main>

    <section class="article-cta">
      <div class="acta-in">
        <div class="acta-eyebrow">Who's behind this</div>
        <h2>Analysis like this is what we do for clients.</h2>
        <p>Aesop Analytics is a reporting-modernization practice — we turn messy, mistrusted reporting into numbers leadership relies on. If that's a problem you're facing, a free 30-minute diagnostic is the fastest first step. No pitch, no commitment.</p>
        <a href="/diagnostic" class="acta-btn">Book a diagnostic →</a>
      </div>
    </section>

    <footer class="site">
      <div class="fin">
        <Wordmark variant="article-footer" />
        <div class="fmoral">{site.tagline}</div>
        <a href="/insights" class="fback">&larr; All Insights</a>
      </div>
      <div class="flegal">This site uses Google Analytics. <a href="/privacy">Privacy</a></div>
    </footer>

    <style>
      .article-cta { background:var(--navy); border-top:3px solid var(--twine); padding:64px 32px; text-align:center; }
      .acta-in { max-width:640px; margin:0 auto; }
      .acta-eyebrow { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.22em; color:var(--twine); margin-bottom:16px; }
      .article-cta h2 { font-family:"Newsreader",Georgia,serif; font-weight:600; font-size:clamp(24px,3.2vw,34px); line-height:1.12; color:#fff; margin-bottom:14px; letter-spacing:-.01em; }
      .article-cta p { font-size:16px; color:#A8B4C0; line-height:1.62; font-weight:300; margin-bottom:28px; }
      .acta-btn { display:inline-block; background:var(--twine); color:var(--navy); padding:13px 26px; border-radius:4px; font-size:14px; font-weight:700; letter-spacing:.02em; transition:background .2s, transform .2s; }
      .acta-btn:hover { background:var(--twine-bright); transform:translateY(-2px); }
    </style>
    <!-- The .reveal entrance animation runs from base.css at load (with its
         prefers-reduced-motion fallback). The old IntersectionObserver here
         re-applied the animation inline, which overrode that fallback for
         reduced-motion users — removed deliberately; do not re-add without a
         matchMedia gate. -->
  </body>
</html>
